            <object node="chipwoodStack02" tensionBeltNode="chipwoodStack02Tension"/>
            <object node="chipwoodStack03" tensionBeltNode="chipwoodStack03Tension"/>
            <object node="chipwoodStack04" tensionBeltNode="chipwoodStack04Tension"/>
