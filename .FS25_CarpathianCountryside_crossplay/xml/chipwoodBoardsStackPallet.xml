            <object node="chipwoodStack08" tensionBeltNode="chipwoodStack08Tension"/>
            <object node="chipwoodStack09" tensionBeltNode="chipwoodStack09Tension"/>
        </content>

        <sounds>
            <unload template="palletsFillWood" pitchScale="0.7" />
