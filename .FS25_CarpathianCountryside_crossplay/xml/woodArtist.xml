<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_productionPoint_woodArtist</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/mapIcon_woodArtist.png</image>
        <price>80000</price>
        <dailyUpkeep>25</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>630784</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>160768</indexBufferMemoryUsage>
        <textureMemoryUsage>11599872</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/woodArtist.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <buysFarmland>true</buysFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>

        <sounds>
            <place template="medImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearLevelAreaStart01" widthNode="clearLevelAreaWidth01" heightNode="clearLevelAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="clearLevelAreaStart01" widthNode="clearLevelAreaWidth01" heightNode="clearLevelAreaHeight01" groundType="concrete"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>

    <lights>
        <group weatherRequiredFlags="NIGHT" />
        <group name="$l10n_action_placeableLightShed" triggerNode="controledLightsTrigger" volumeScale="0.2">
            <sounds>
                <toggle template="lizardFloodLight" innerRadius="30" outerRadius="50"/>
            </sounds>
        </group>

        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight01" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight02" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight03" groupIndex="1"/>

        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight04" groupIndex="2"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight05" groupIndex="2"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight06" groupIndex="2"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight07" groupIndex="2"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight08" groupIndex="2"/>

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
                <light node="realLightsControledLow" groupIndex="2"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
                <light node="realLightsControledHigh" groupIndex="2"/>
            </high>
        </realLights>
    </lights>

    <animatedObjects>
        <animatedObject saveId="woodArtist_garageDoor">
            <animation duration="2.5">
                <part node="garageDoorLeft">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -120 0"/>
                </part>
                <part node="garageDoorRight">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 120 0"/>
                </part>
                <part node="occluderMesh_woodArtist_garageDoor">
                    <keyFrame time="0"    visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="trigger_garageDoor" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
            <sounds>
                <moving linkNode="garageDoorLeft" template="woodDoorSqueaksLarge"/>
                <posEnd linkNode="garageDoorLeft" template="woodDoorOpen" />
                <negEnd linkNode="garageDoorLeft" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="woodArtist_door01">
            <animation duration="1.2">
                <part node="door01">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 120 0"/>
                </part>
                <part node="occluderMesh_woodArtist_door01">
                    <keyFrame time="0"    visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="trigger_door01" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
            <sounds>
                <moving linkNode="door01" template="woodDoorSqueaksSmall" pitchScale="0.8"/>
                <posEnd linkNode="door01" template="woodDoorOpen" />
                <negEnd linkNode="door01" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="woodArtist_door02">
            <animation duration="1.2">
                <part node="door02">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 120 0"/>
                </part>
                <part node="occluderMesh_woodArtist_door02">
                    <keyFrame time="0"    visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="trigger_door02" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
            <sounds>
                <moving linkNode="door02" template="woodDoorSqueaksSmall" pitchScale="0.8"/>
                <posEnd linkNode="door02" template="woodDoorOpen" />
                <negEnd linkNode="door02" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="woodArtist_bigBarnDoor">
            <animation duration="2.5">
                <part node="bigBarnDoorLeft">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -120 0"/>
                </part>
                <part node="bigBarnDoorRight">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 120 0"/>
                </part>
                <part node="occluderMesh_woodArtist_bigBarnDoor">
                    <keyFrame time="0"    visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="trigger_bigBarnDoor" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
            <sounds>
                <moving linkNode="bigBarnDoorLeft" template="woodDoorSqueaksLarge"/>
                <posEnd linkNode="bigBarnDoorLeft" template="woodDoorOpen" />
                <negEnd linkNode="bigBarnDoorLeft" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="woodArtist_smallBarnDoor">
            <animation duration="2.5">
                <part node="smallBarnDoorLeft">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -120 0"/>
                </part>
                <part node="smallBarnDoorRight">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 120 0"/>
                </part>
                <part node="occluderMesh_woodArtist_smallBarnDoor">
                    <keyFrame time="0"    visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="trigger_smallBarnDoor" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor"/>
            <sounds>
                <moving linkNode="smallBarnDoorLeft" template="woodDoorSqueaksLarge"/>
                <posEnd linkNode="smallBarnDoorLeft" template="woodDoorOpen" />
                <negEnd linkNode="smallBarnDoorLeft" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>
    </animatedObjects>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="unloadTriggerMarkerProductionPoint" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="woodSellTriggerMarkerProductionPoint" filename="$data/shared/assets/marker/markerIconExclamationMark.i3d" adjustToGround="true" />
        <triggerMarker node="playerTriggerMarkerProductionPoint" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="false" />
        <triggerMarker node="warningStripes" />
    </triggerMarkers>

    <infoTrigger triggerNode="infoTrigger"/>

    <productionPoint>
        <productions sharedThroughputCapacity="false">
            <production id="bowl" name="$l10n_fillType_bowl" cyclesPerHour="1" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="WOOD" amount="75" />
                </inputs>
                <outputs>
                    <output fillType="BOWL" amount="75" />
                </outputs>
            </production>
            <production id="pepperGrinder" name="$l10n_fillType_pepperGrinder" cyclesPerHour="1" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="WOOD" amount="25" />
                </inputs>
                <outputs>
                    <output fillType="PEPPERGRINDER" amount="50" />
                </outputs>
            </production>
            <production id="birdHouse" name="$l10n_fillType_birdHouse" cyclesPerHour="1" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="BOARDS" amount="40" />
                </inputs>
                <outputs>
                    <output fillType="BIRDHOUSE" amount="50" />
                </outputs>
            </production>
            <production id="catTree" name="$l10n_fillType_catTree" cyclesPerHour="1" costsPerActiveHour="2">
                <inputs>
                    <input fillType="BOARDS" amount="23" />
                    <input fillType="WOOL"   amount="25" />
                </inputs>
                <outputs>
                    <output fillType="CATTREE" amount="43" />
                </outputs>
            </production>
            <production id="dogHouse" name="$l10n_fillType_dogHouse" cyclesPerHour="1" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="BOARDS" amount="45" />
                </inputs>
                <outputs>
                    <output fillType="DOGHOUSE" amount="48" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStationProductionPoint" appearsOnStats="true" supportsExtension="false" allowMissions="false" litersForFullPriceDrop="30000" fullPriceRecoverHours="48">
            <unloadTrigger exactFillRootNode="unloadTriggerProductionPoint" fillTypes="BOARDS WOOL WOOD" />
            <palletTrigger triggerNode="palletTriggerProductionPoint" fillTypes="BOARDS WOOL WOOD"/>
            <woodTrigger triggerNode="woodTriggerProductionPoint" activationTriggerNode="woodSellTriggerProductionPoint" fillTypes="WOOD"/>
        </sellingStation>

        <palletSpawner node="palletSpawner">
            <spawnPlaces>
                <spawnPlace startNode="spawnSpace1start" endNode="spawnSpace1end" />
                <spawnPlace startNode="spawnSpace2start" endNode="spawnSpace2end" />
                <spawnPlace startNode="spawnSpace3start" endNode="spawnSpace3end" />
            </spawnPlaces>
        </palletSpawner>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="WOOD"          capacity="12000" />
            <capacity fillType="BOARDS"        capacity="12000" />
            <capacity fillType="WOOL"          capacity="3000" />
            <capacity fillType="BOWL"          capacity="6000" />
            <capacity fillType="PEPPERGRINDER" capacity="6000" />
            <capacity fillType="BIRDHOUSE"     capacity="6000" />
            <capacity fillType="CATTREE"       capacity="6000" />
            <capacity fillType="DOGHOUSE"      capacity="6000" />
        </storage>

        <playerTrigger node="playerTriggerProductionPoint" />

        <sounds>
            <idle template="cooperIdle" linkNode="soundNodeProductionPoint" innerRadius="8" outerRadius="25" volumeScale="0.7" />
            <active template="cooperWork" linkNode="soundNodeProductionPoint" innerRadius="8" outerRadius="25" volumeScale="3.5" />
        </sounds>
    </productionPoint>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch01" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch02" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch03" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch04" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="propsNode" filename="placeables/sharedAssets/propsBuilding/propsBuilding_woodArtist.i3d"/>
    </dynamicallyLoadedParts>

