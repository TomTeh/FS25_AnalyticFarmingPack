<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="buyingStation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_biogasStation</name>
        <image>placeables/buyingStations/biogasStation/store_biogasStation.png</image>
        <functions>
            <function>$l10n_function_biogasStation</function>
        </functions>
        <price>5000</price>
        <dailyUpkeep>5</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>placeableMisc</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>tools</tab>
        </brush>

        <storeIconRendering>
            <settings advancedBoundingBox="true" />
        </storeIconRendering>
        <vertexBufferMemoryUsage>41728</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>12288</indexBufferMemoryUsage>
        <textureMemoryUsage>1048576</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/buyingStations/biogasStation/biogasStation.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>

        <sounds>
            <place template="smallImp" pitchScale="1.6"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="false" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas />

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>

    <hotspots>
        <hotspot type="FUEL" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>


    <buyingStation node="fillTrigger" supportsExtension="false">
        <loadTrigger triggerNode="fillTrigger" fillTypes="METHANE" fillLitersPerSecond="2" autoStart="true" infiniteCapacity="true" />
        <fillType name="METHANE" priceScale="1.0" />
    </buyingStation>

    <i3dMappings>
        <i3dMapping id="biogasStation" node="0>" />
        <i3dMapping id="fillTrigger" node="0>1" />
        <i3dMapping id="hotspotNode" node="0>2" />
        <i3dMapping id="teleportNode" node="0>3" />
        <i3dMapping id="clearAreaStart01" node="0>4|0" />
        <i3dMapping id="clearAreaWidth01" node="0>4|0|0" />
        <i3dMapping id="clearAreaHeight01" node="0>4|0|1" />
        <i3dMapping id="levelAreaStart01" node="0>5|0" />
        <i3dMapping id="levelAreaWidth01" node="0>5|0|0" />
        <i3dMapping id="levelAreaHeight01" node="0>5|0|1" />
        <i3dMapping id="testAreaStart01" node="0>6|0" />
        <i3dMapping id="testAreaEnd01" node="0>6|0|0" />
        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0>7|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd01" node="0>7|0|0" />
    </i3dMappings>
</placeable>
