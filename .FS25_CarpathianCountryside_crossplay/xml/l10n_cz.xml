        <!-- Function Texts -->
        <text name="function_roofSolarPanelsOption" text="Tato budova má možnost přidat na střechu solární panely. Cena za panel: 265 €. Příjem na panel za měsíc: 21,6 € (při odpovídajících povětrnostních podmínkách)." />
        <text name="function_heiferStable" text="Tento přístřešek je určen pro jalovice. Tady mohou vyrůst a poté by měly být přesunuty do jiné stáje. Krávy v tomto přístřešku neprodukují mléko a kejdu, ale pouze hnůj." />
        <text name="function_cowYoungShelter" text="Tento přístřešek je určen pro telata nebo jalovice. Tady mohou vyrůst a poté by měly být přesunuty do jiné stáje. Krávy v tomto přístřešku neprodukují mléko a kejdu, ale pouze hnůj." />
        <text name="function_calfHut" text="Tato bouda je určena pouze pro telata. Zde mohou vyrůst a pak se musí přesunout do jiné stáje. Krávy v tomto výběhu neprodukují mléko a kejdu, ale pouze hnůj a vyžadují mnoho ruční každodenní péče!" />
        <text name="function_bunkerSiloCC" text="Tuto silážní jámu lze plnit řezankou, trávou, vojtěškou a jetelem. Po zhutnění a zakrytí sila se obsah přemění na siláž. POZNÁMKA: Pokud používáte Maize Plus mod, změní se funkčnost tohoto sila na standardy M+." />
        <text name="function_grainStorage" text="Toto víceúčelové zařízení má velkou skladovací halu, která vám umožňuje skladovat plodiny na zemi nebo před jejich zpracováním, dostatek místa i pro vozidla. Šrotovačka vyrábí krmivo pro vaše zvířata. Obilí lze skladovat i ve velkokapacitních silech." />
        <text name="function_fillableLiquidFertilizerAndHerbicideTanks" text="Tyto nádrže lze plnit tekutým hnojivem a herbicidem." />
        <text name="function_baleStorageCC" text="Tuto budovu lze použít k uskladnění balíků." />
        <text name="function_palletStorage" text="Tuto budovu lze použít k uskladnění palet." />
        <text name="function_orchard" text="Sad produkuje ovoce. Potřebujete vodu, tekuté hnojivo a kompost." />
        <text name="function_greenhouseAdvanced" text="Pokročilé skleníky produkují zeleninu rychleji, ale vyžadují více péče - Potřeba: Voda, tekuté hnojivo a kompost." />
        <text name="function_compost" text="Kompost je vyžadován v sadech a sklenících. Lze použít i jako hnojivo na poli." />
        <text name="function_compostSilo" text="Kompostovací Jámu lze naplnit organickým odpadem. Po zhutnění a zakrytí sila se obsah mění na kompost." />
        <text name="function_heapSpawnerStoneCC" text="V této budově si můžete vyzvednout kameny zdarma. Produkuje 3000 jednotek kamene za hodinu."/>
        <text name="function_heapSpawnerLimestone" text="V této budově si můžete vyzvednout vápenec zdarma. Produkuje 2800 jednotek vápence za hodinu."/>
        <text name="function_heapSpawnerClay" text="V této budově si můžete vyzvednout jíl zdarma. Produkuje 1600 jednotek jílu za hodinu."/>
        <text name="function_heapSpawnerIronOre" text="V této budově si můžete vyzvednout železnou rudu zdarma. Produkuje 800 jednotek železné rudy za hodinu."/>
        <text name="function_rentalHouse" text="Tento dům je určen k pronájmu a generuje zisk:"/>
        <text name="function_rentalHouse01Income" text="2,500 € za měsíc"/>
        <text name="function_rentalHouse02Income" text="3,000 € za měsíc"/>
        <text name="function_rentalHouse03Income" text="2,000 € za měsíc"/>
        <text name="function_chainlinkFenceBigGatePlacement" text="POZNÁMKA K UMÍSTĚNÍ: Ujistěte se, že je brána umístěna rovnoběžně s plotem a na rovném terénu pro správnou estetiku." />
        <text name="function_decorativeGrass" text="Tato tráva neroste! Zůstává v současném stádiu – slouží jako okrasná tráva." />
        <text name="function_decorativeGardenCrops" text="Toto je dekorativní zahradní plodina, není funkční. Mění vzhled v závislosti na ročním období nebo mizí v určitých obdobích, například v zimě. (V závislosti na tom, kdy byla rostlina namalována, může sezónní růst začít až příští rok. Záleží také na tom, zda sezónní růst používáte, či nikoli. Pokud je sezónní růst vypnutý, mění vzhled každý herní den.)" />
        <text name="function_paintableField" text="Vytváří půdu pro pěstování plodin." />

