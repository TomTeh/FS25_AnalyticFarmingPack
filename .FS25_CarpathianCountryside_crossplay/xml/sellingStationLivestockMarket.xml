<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="mapCC_buySellStation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_animals_dealer</name>
        <image>placeables/sellingStations/mapIcon_sellingStationLivestockMarket.png</image>
        <price>1</price>
        <dailyUpkeep>0</dailyUpkeep>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>sellingPoints</category>
        <vertexBufferMemoryUsage>83712</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>33280</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/sellingStations/sellingStationLivestockMarket.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <ai>
        <updateAreas/>
    </ai>

    <triggerMarkers>
        <triggerMarker node="markerUnloadTrigger" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="markerLoadingManure" filename="placeables/sharedAssets/marker/markerIconBuyConsumable.i3d" adjustToGround="true" />
        <triggerMarker node="markerLoadingLiquidManure" filename="placeables/sharedAssets/marker/markerIconBuyConsumable.i3d" adjustToGround="true" />
        <triggerMarker node="markerLoadingPigFood" filename="placeables/sharedAssets/marker/markerIconBuyConsumable.i3d" adjustToGround="true" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="SHOP_ANIMAL" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <sellingStation node="0" appearsOnStats="true" supportsExtension="false" litersForFullPriceDrop="300000" fullPriceRecoverHours="48">
        <unloadTrigger exactFillRootNode="unloadTrigger" priceScale="1" fillTypeCategories="SELLINGSTATION_BALES" fillTypesExclude="COTTON WOODCHIPS" />
        <palletTrigger triggerNode="palletTrigger" priceScale="1" fillTypeCategories="SELLINGSTATION_BALES" fillTypesExclude="COTTON WOODCHIPS"/>
        <baleTrigger triggerNode="baleTrigger" deleteLitersPerSecond="10000" priceScale="1" fillTypeCategories="SELLINGSTATION_BALES" fillTypesExclude="COTTON WOODCHIPS"/>
        <unloadTrigger exactFillRootNode="unloadTriggerAI" aiNode="unloadTriggerAINode" priceScale="1" fillTypeCategories="SELLINGSTATION_BALES" fillTypesExclude="COTTON WOODCHIPS" />
    </sellingStation>

    <buyingStation node="0" supportsExtension="false">
        <loadTrigger triggerNode="loadingTriggerManure" fillTypes="MANURE" fillLitersPerSecond="1000" autoStart="true" infiniteCapacity="true"/>
        <loadTrigger triggerNode="loadingTriggerLiquidManure" fillTypes="LIQUIDMANURE" fillLitersPerSecond="1000" autoStart="true" infiniteCapacity="true"/>
        <loadTrigger triggerNode="loadingTriggerLiquidManureMS" fillTypes="LIQUIDMANURE" fillLitersPerSecond="285" dischargeNode="dischargeNodeLiquidManureMS" infiniteCapacity="true">
            <effectNode effectClass="PipeEffect" effectNode="pipeEffectLiquidManureMS" materialType="PIPE" stopDelay="0.5" maxBending="0.8" extraDistance="0.2" controlPoint="4 0 0 0"/>
        </loadTrigger>
        <loadTrigger triggerNode="loadingTriggerPigFood" fillTypes="WHEAT OAT PIGFOOD MINERAL_FEED CARROT" fillLitersPerSecond="1000" autoStart="false" dischargeNode="dischargeNodePigFood" infiniteCapacity="true">
            <effectNode effectClass="PipeEffect" effectNode="pipeEffectPigFood"      materialType="pipe"           fadeTime="0.5" maxBending="0" shapeScaleSpread="0.8 0.8 1 0" controlPoint="5.5 0 0 0"/>
            <effectNode                          effectNode="pipeEffectSmokePigFood" materialType="unloadingSmoke" fadeTime="0.5" />
        </loadTrigger>

        <fillType name="MANURE"            priceScale="1.3" />
        <fillType name="LIQUIDMANURE"      priceScale="1.3" />
        <fillType name="WHEAT"             priceScale="1.3" />
        <fillType name="OAT"               priceScale="1.3" />
        <fillType name="PIGFOOD"           priceScale="0.35" />
        <fillType name="MINERAL_FEED"      priceScale="0.35" />
        <fillType name="CARROT"            priceScale="1.3" />
    </buyingStation>

    <i3dMappings>
        <i3dMapping id="unloadTrigger" node="0>0|0" />
        <i3dMapping id="palletTrigger" node="0>0|1" />
        <i3dMapping id="baleTrigger" node="0>0|2" />
        <i3dMapping id="markerUnloadTrigger" node="0>0|3" />
        <i3dMapping id="unloadTriggerAI" node="0>0|4" />
        <i3dMapping id="unloadTriggerAINode" node="0>0|5" />
        <i3dMapping id="loadingTriggerManure" node="0>1|0" />
        <i3dMapping id="markerLoadingManure" node="0>1|1" />
        <i3dMapping id="aiNodeLoadingManure" node="0>1|2" />
        <i3dMapping id="loadingTriggerLiquidManure" node="0>2|0" />
        <i3dMapping id="markerLoadingLiquidManure" node="0>2|1" />
        <i3dMapping id="aiNodeLoadingLiquidManure" node="0>2|2" />
        <i3dMapping id="connectorCollisionLiquidManure" node="0>2|3" />
        <i3dMapping id="connectorNodeLiquidManure" node="0>2|4" />
        <i3dMapping id="loadingTriggerLiquidManureMS" node="0>2|5|0" />
        <i3dMapping id="dischargeNodeLiquidManureMS" node="0>2|5|1" />
        <i3dMapping id="pipeEffectLiquidManureMS" node="0>2|5|2" />
        <i3dMapping id="loadingTriggerPigFood" node="0>4|0" />
        <i3dMapping id="dischargeNodePigFood" node="0>4|1" />
        <i3dMapping id="pipeEffectPigFood" node="0>4|2|0" />
        <i3dMapping id="pipeEffectSmokePigFood" node="0>4|2|1" />
        <i3dMapping id="markerLoadingPigFood" node="0>4|3" />
        <i3dMapping id="aiNodeLoadingPigFood" node="0>4|4" />
        <i3dMapping id="hotspotNode" node="0>6" />
        <i3dMapping id="teleportNode" node="0>7" />
    </i3dMappings>
</placeable>
