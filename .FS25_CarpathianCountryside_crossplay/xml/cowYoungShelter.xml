            <high>
                <light node="realLightsControledHigh" groupIndex="1"/>
                <light node="realLightsTerraLedHigh" groupIndex="2"/>
            </high>
        </realLights>
    </lights>

    <animatedObjects>
        <animatedObject saveId="cowYoungShelter_gate" >
            <animation duration="3">
                <part node="calfFenceGate">
                    <keyFrame time="0.01" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -108 0"/>
                </part>
                <part node="calfFenceGateLock">
                    <keyFrame time="0.0" visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="calfFenceGate_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="calfFenceGate_sound" template="fenceMetalLoop" volumeScale="0.85"/>
                <posEnd linkNode="calfFenceGate_sound" template="fenceMetalOpen" volumeScale="0.4" />
                <negEnd linkNode="calfFenceGate_sound" template="fenceMetalClose" volumeScale="0.4" />
            </sounds>
        </animatedObject>
    </animatedObjects>

