        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="markerFood" filename="$data/shared/assets/marker/markerIconFood.i3d" adjustToGround="true" />
        <triggerMarker node="markerAnimals" filename="placeables/sharedAssets/marker/markerIconCowInOut.i3d" adjustToGround="true" />
        <triggerMarker node="markerStrawBale" filename="$data/shared/assets/marker/markerIconBales.i3d" adjustToGround="true" />
