        <unloadingStation supportsExtension="true" storageRadius="50" hideFromPricesMenu="true">
            <unloadTrigger exactFillRootNode="exactFillRootNodeStraw" fillTypes="STRAW" />
            <baleTrigger triggerNode="baleTriggerStraw" fillTypes="STRAW"/>
            <palletTrigger triggerNode="palletTriggerStraw" fillTypes="STRAW"/>
            <unloadTrigger fillTypes="MANURE" />
        </unloadingStation>

        <loadingStation supportsExtension="true" storageRadius="50" fillTypes="STRAW" />

        <animals type="COW" maxNumAnimals="50">
            <navigation rootNode="navMeshNode" filename="placeables/animalHusbandry/cowYoungShelterNavigationMesh.i3d" />
            <loadingTrigger node="animalLoadTrigger" />
        </animals>

        <food capacity="30000" >
            <dynamicFoodPlane node="fillVolumeFood" defaultFillType="FORAGE" capacity="15000" maxAllowedHeapAngle="60" maxSubDivEdgeLength="0.5"/>
            <foodPlaces>
