        <dailyUpkeep>50</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>EASYSHEDS</brand>
        <species>placeable</species>
        <category>animalpens</category>
        <brush>
            <type>placeable</type>
            <category>animals</category>
            <tab>cows</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-10" cameraYRot="-40" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>537856</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>100608</indexBufferMemoryUsage>
        <textureMemoryUsage>6291456</textureMemoryUsage>
