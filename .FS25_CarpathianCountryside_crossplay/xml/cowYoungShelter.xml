    <hotspots>
        <hotspot type="COW" teleportNode="teleportNode" />
    </hotspots>

    <lights>
        <group name="$l10n_action_placeableLightShed" triggerNode="controledLightsTrigger">
            <sounds>
                <toggle template="lizardFloodLight" innerRadius="20" outerRadius="50" volumeScale="0.2"/>
            </sounds>
        </group>
        <group name="$l10n_action_placeableLightShed" activateTime="17:30" deactivateTime="8:20"/>

        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight01" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight02" groupIndex="1"/>

        <sharedLight filename="$data/shared/assets/lights/terraLed/light150W.xml" linkNode="light150W01" groupIndex="2" color="1 0 0" />
