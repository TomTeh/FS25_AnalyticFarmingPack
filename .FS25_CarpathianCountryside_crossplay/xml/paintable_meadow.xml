<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="foliage" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_meadow</name>
        <functions>
            <function>$l10n_function_foliage</function>
        </functions>
        <image>foliage/meadow/store_meadow.dds</image>
        <price>5</price>
        <dailyUpkeep>0</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>placeableMisc</category>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <brush>
            <type>foliage</type>
            <category>landscaping</category>
            <tab>plants</tab>
            <parameters>
                <parameter>meadow</parameter> <!-- foliage painter id -->
                <parameter>4</parameter> <!-- value -->
            </parameters>
        </brush>

        <storeIconRendering>
            <settings centerIcon="true"/>
            <objectBundle>
                <object filename="foliage/meadow/meadow.i3d">
                    <node node="0|3|1|2" translation="0 0 0" rotation="0 0 0" scale="1 1 1"/>
                    <node node="0|1|0|4" translation="0.248 0 0.199" rotation="0 0 0" scale="1 1 1"/>
                    <node node="0|3|1|2" translation="-0.168 0 -0.123" rotation="0 0 0" scale="1 1 1"/>
                </object>
            </objectBundle>
        </storeIconRendering>
    </storeData>

    <!-- Used only for store icon generation and store item. Does not use this i3d reference in-game. -->
    <base>
        <filename>foliage/meadow/meadow.i3d</filename>
    </base>

    <placement>
        <testAreas>
            <testArea/>
        </testAreas>
        <sounds>
            <place/>
            <placeLayered/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea/>
    </clearAreas>

    <leveling >
        <levelAreas>
            <levelArea/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea/>
    </indoorAreas>

</placeable>
