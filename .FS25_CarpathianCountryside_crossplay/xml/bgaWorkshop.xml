<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="workshop" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_workshop</name>
        <functions>
            <function>$l10n_function_workshop</function>
        </functions>
        <image>placeables/store_defaultMapItem.png</image>
        <price>1</price>
        <dailyUpkeep>5</dailyUpkeep>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>placeableMisc</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>tools</tab>
        </brush>
        <vertexBufferMemoryUsage>1280</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>768</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/biogasPlant/bgaWorkshop.i3d</filename>
        <canBeRenamed>false</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>´

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
        </updateAreas>
    </ai>

    <hotspots>
        <hotspot type="SHOP" linkNode="hotspotNode" teleportNode="workshopMarker" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="workshopMarker" filename="$data/shared/assets/marker/markerIconWrench.i3d" adjustToGround="true" />
    </triggerMarkers>

    <workshop>
        <sellingPoint playerTriggerNode="workshopPlayerTrigger" iconNode="workshopMarker" sellTriggerNode="workshopVehicleTrigger" ownWorkshop="true" mobileWorkshop="false" />
    </workshop>

    <i3dMappings>
        <i3dMapping id="workshopMarker" node="0>0|0" />
        <i3dMapping id="workshopWarningStripes" node="0>0|1" />
        <i3dMapping id="workshopVehicleTrigger" node="0>0|2" />
        <i3dMapping id="workshopPlayerTrigger" node="0>0|3" />
        <i3dMapping id="hotspotNode" node="0>1" />
    </i3dMappings>
</placeable>
