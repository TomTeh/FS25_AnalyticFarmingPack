<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_carpenter</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/mapIcon_carpenter.png</image>
        <price>165000</price>
        <dailyUpkeep>50</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>45312</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>18432</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/carpenter.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <buysFarmland>true</buysFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
        </updateAreas>
    </ai>

    <infoTrigger triggerNode="infoTrigger"/>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="markerLoadingSilo"   filename="$data/shared/assets/marker/markerIconLoad.i3d" adjustToGround="true" />
    </triggerMarkers>

    <productionPoint>
        <productions sharedThroughputCapacity="true">
            <production id="furnitureBoards" name="$l10n_fillType_furniture" cyclesPerHour="4" costsPerActiveHour="6">
                <inputs>
                    <input fillType="BOARDS" amount="80" />
                    <input fillType="PLANKS" amount="80" />
                </inputs>
                <outputs>
                    <output fillType="FURNITURE" amount="224" />
                    <output fillType="WOODCHIPS" amount="30" />
                </outputs>
            </production>
            <production id="furnitureChipwoodBoards" name="%s (%s)" params="$l10n_fillType_furniture|$l10n_fillType_chipwoodBoards" cyclesPerHour="4" costsPerActiveHour="6">
                <inputs>
                    <input fillType="CHIPWOODBOARDS" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="FURNITURE" amount="112" />
                    <output fillType="WOODCHIPS" amount="15" />
                </outputs>
            </production>
            <production id="floorTiles" name="$l10n_fillType_floorTiles" cyclesPerHour="5" costsPerActiveHour="6">
                <inputs>
                    <input fillType="BOARDS" amount="200" />
                </inputs>
                <outputs>
                    <output fillType="FLOORTILES" amount="190" />
                    <output fillType="WOODCHIPS" amount="10" />
                </outputs>
            </production>
            <production id="shingle" name="$l10n_fillType_shingle" cyclesPerHour="5" costsPerActiveHour="6">
                <inputs>
                    <input fillType="BOARDS" amount="200" />
                </inputs>
                <outputs>
                    <output fillType="SHINGLE" amount="180" />
                    <output fillType="WOODCHIPS" amount="20" />
                </outputs>
            </production>
            <production id="chair" name="$l10n_fillType_chair" cyclesPerHour="3" costsPerActiveHour="6">
                <inputs>
                    <input fillType="BOARDS" amount="75" />
                    <input fillType="PLANKS" amount="50" />
                </inputs>
                <outputs>
                    <output fillType="CHAIR" amount="250" />
                    <output fillType="WOODCHIPS" amount="20" />
                </outputs>
            </production>
            <production id="table" name="$l10n_fillType_table" cyclesPerHour="3" costsPerActiveHour="6">
                <inputs>
                    <input fillType="BOARDS" amount="120" />
                    <input fillType="PLANKS" amount="80" />
                </inputs>
                <outputs>
                    <output fillType="TABLE" amount="200" />
                    <output fillType="WOODCHIPS" amount="20" />
                </outputs>
            </production>
            <production id="armoire" name="$l10n_fillType_armoire" cyclesPerHour="2.5" costsPerActiveHour="6">
                <inputs>
                    <input fillType="BOARDS" amount="100" />
                    <input fillType="PLANKS" amount="75" />
                    <input fillType="METAL"  amount="20" />
                </inputs>
                <outputs>
                    <output fillType="ARMOIRE" amount="350" />
                    <output fillType="WOODCHIPS" amount="20" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="false" allowMissions="false" litersForFullPriceDrop="100000" fullPriceRecoverHours="48">
            <unloadTrigger exactFillRootNode="unloadTrigger" fillTypes="BOARDS PLANKS CHIPWOODBOARDS METAL" />
            <palletTrigger triggerNode="palletTrigger" fillTypes="BOARDS PLANKS CHIPWOODBOARDS METAL"/>
        </sellingStation>

        <loadingStation>
            <loadTrigger triggerNode="loadingTrigger" fillLitersPerSecond="1000" dischargeNode="dischargeNode" fillTypes="WOODCHIPS" >
                <effectNode effectClass="PipeEffect" effectNode="pipeEffect"      materialType="pipe"           fadeTime="0.5" maxBending="0" controlPoint="3.8 0 0 0" />
                <effectNode                          effectNode="pipeEffectSmoke" materialType="unloadingSmoke" fadeTime="0.5" />
            </loadTrigger>
        </loadingStation>

        <palletSpawner node="palletSpawner">
            <spawnPlaces>
                <spawnPlace startNode="spawnSpace1start" endNode="spawnSpace1end" />
                <spawnPlace startNode="spawnSpace2start" endNode="spawnSpace2end" />
                <spawnPlace startNode="spawnSpace3start" endNode="spawnSpace3end" />
            </spawnPlaces>
        </palletSpawner>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="BOARDS"          capacity="100000" />
            <capacity fillType="PLANKS"          capacity="65000" />
            <capacity fillType="CHIPWOODBOARDS"  capacity="60000" />
            <capacity fillType="METAL"           capacity="5000" />
            <capacity fillType="FURNITURE"       capacity="20000" />
            <capacity fillType="FLOORTILES"      capacity="20000" />
            <capacity fillType="SHINGLE"         capacity="20000" />
            <capacity fillType="CHAIR"           capacity="20000" />
            <capacity fillType="TABLE"           capacity="20000" />
            <capacity fillType="ARMOIRE"         capacity="20000" />
            <capacity fillType="WOODCHIPS"       capacity="50000" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <effectNodes>
            <effectNode effectClass="ParticleEffect" effectNode="smokeChimenyEffectShape01" particleType="SMOKE_CHIMNEY" emitCountScale="75"/>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape01" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="30"/>
        </effectNodes>

        <sounds>
            <idle template="carpenterIdle" linkNode="soundNode" />
            <active template="carpenterWork" linkNode="soundNode" />
        </sounds>
    </productionPoint>

    <i3dMappings>
        <i3dMapping id="sellingStation" node="0>0" />
        <i3dMapping id="unloadTrigger" node="0>0|0" />
        <i3dMapping id="palletTrigger" node="0>0|1" />
        <i3dMapping id="unloadTriggerMarker" node="0>0|2" />
        <i3dMapping id="loadingTrigger" node="0>1|0" />
        <i3dMapping id="dischargeNode" node="0>1|1" />
        <i3dMapping id="pipeEffect" node="0>1|2|0" />
        <i3dMapping id="pipeEffectSmoke" node="0>1|2|1" />
        <i3dMapping id="markerLoadingSilo" node="0>1|3" />
        <i3dMapping id="playerTrigger" node="0>2|0" />
        <i3dMapping id="playerTriggerMarker" node="0>2|0|0" />
        <i3dMapping id="soundNode" node="0>2|1" />
        <i3dMapping id="smokeChimenyEffectShape01" node="0>2|2|0" />
        <i3dMapping id="smokeEffectShape01" node="0>2|2|1" />
        <i3dMapping id="palletSpawner" node="0>3" />
        <i3dMapping id="spawnSpace1start" node="0>3|0" />
        <i3dMapping id="spawnSpace1end" node="0>3|0|0" />
        <i3dMapping id="spawnSpace2start" node="0>3|1" />
        <i3dMapping id="spawnSpace2end" node="0>3|1|0" />
        <i3dMapping id="spawnSpace3start" node="0>3|2" />
        <i3dMapping id="spawnSpace3end" node="0>3|2|0" />
        <i3dMapping id="infoTrigger" node="0>4" />
        <i3dMapping id="hotspotNode" node="0>5" />
        <i3dMapping id="teleportNode" node="0>6" />
    </i3dMappings>
</placeable>
