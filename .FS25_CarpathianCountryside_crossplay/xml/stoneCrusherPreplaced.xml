<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://validation.gdn.giants-software.com/xml/fs25/placeable.xsd">
    <storeData>
        <name>$l10n_productionPoint_stoneCrusher</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/stoneCrusher/mapIcon_stoneCrusher.png</image>
        <price>88000</price>
        <dailyUpkeep>15</dailyUpkeep>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-10" cameraYRot="-60" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>692480</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>146176</indexBufferMemoryUsage>
        <textureMemoryUsage>5570560</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/stoneCrusher/stoneCrusherPreplaced.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
            <testArea startNode="testAreaStart2" endNode="testAreaEnd2" />
            <testArea startNode="testAreaStart3" endNode="testAreaEnd3" />
        </testAreas>

        <sounds>
            <place template="medImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30" >
        <levelAreas>
            <levelArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1" groundType="concrete"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1" />
        <indoorArea startNode="indoorAreaStart2" widthNode="indoorAreaWidth2" heightNode="indoorAreaHeight2" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="false" />
        <triggerMarker node="loadingTriggerMarker" filename="$data/shared/assets/marker/markerIconLoad.i3d" adjustToGround="true" />
        <triggerMarker node="warningStripes" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <infoTrigger triggerNode="infoTrigger"/>

    <productionPoint>
        <productions sharedThroughputCapacity="true">
            <production id="gravel" name="$l10n_fillType_gravel" cyclesPerHour="300" costsPerActiveHour="1">
                <inputs>
                    <input fillType="STONE" amount="10" />
                </inputs>
                <outputs>
                    <output fillType="GRAVEL" amount="10" />
                </outputs>

                <sounds>
                    <active template="debrisCrusherWork" linkNode="soundNode" loops="0" volumeScale="1.0" innerRadius="7" outerRadius="40" supportsReverb="false"/>
                </sounds>
            </production>
        </productions>

        <sellingStation node="sellingStation" supportsExtension="false" hideFromPricesMenu="true" allowMissions="false">
            <unloadTrigger exactFillRootNode="unloadTriggerUp" fillTypes="STONE" />
            <unloadTrigger exactFillRootNode="unloadTriggerDown" fillTypes="STONE" />
            <palletTrigger triggerNode="palletTriggerDown" fillTypes="STONE" />
        </sellingStation>

        <loadingStation>
            <loadTrigger triggerNode="loadingTrigger" fillTypes="GRAVEL" fillLitersPerSecond="2000" dischargeNode="dischargeNode" >
                <effectNode effectClass="PipeEffect" effectNode="pipeEffect"      materialType="pipe"           fadeTime="0.5" maxBending="0" controlPoint="4.8 0 0 0" />
                <effectNode                          effectNode="pipeEffectSmoke" materialType="unloadingSmoke" fadeTime="0.5" />
            </loadTrigger>
        </loadingStation>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="STONE"  capacity="40000" />
            <capacity fillType="GRAVEL" capacity="110000" />

            <fillPlane node="fillPlaneStone" fillType="STONE" minRotX="-29.65" maxRotX="0" changeVisibility="true" />
            <fillPlane node="fillPlaneGravel" fillType="GRAVEL" minY="11.29" maxY="11.65" changeVisibility="true" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <animationNodes>
            <animationNode node="stoneCrusher_conveyorBelt" class="ScrollingAnimation" shaderParameterName="offsetUV" shaderComponentScale="-1 0 0 0" scrollSpeed="-0.2" turnOnFadeTime="3" turnOffFadeTime="3" />
            <animationNode node="stoneCrusher_engineWheel01" rotSpeed="-500" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="stoneCrusher_engineWheel02" rotSpeed="-500" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="stoneCrusher_engineWheel03" rotSpeed="-320" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="stoneCrusher_engineBelt01" class="ScrollingAnimation" shaderParameterName="offsetUV" shaderComponentScale="-1 0 0 0" scrollSpeed="0.4" turnOnFadeTime="3" turnOffFadeTime="3" />
            <animationNode node="stoneCrusher_engineBelt02" class="ScrollingAnimation" shaderParameterName="offsetUV" shaderComponentScale="-1 0 0 0" scrollSpeed="-0.4" turnOnFadeTime="3" turnOffFadeTime="3" />
            <animationNode node="conveyorSmall_belt" class="ScrollingAnimation" shaderParameterName="offsetUV" shaderComponentScale="-1 0 0 0" scrollSpeed="-0.2" turnOnFadeTime="3" turnOffFadeTime="3" />
            <animationNode node="conveyorSmall_beltWheelBig01" rotSpeed="-220" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="conveyorSmall_beltWheelBig02" rotSpeed="-220" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="conveyorSmall_beltWheelSmall01" rotSpeed="-250" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="conveyorSmall_beltWheelSmall02" rotSpeed="-250" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="conveyorSmall_beltWheelSmall03" rotSpeed="-250" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="conveyorSmall_beltWheelSmall04" rotSpeed="-250" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="conveyorSmall_beltWheelSmall05" rotSpeed="-250" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="conveyorSmall_beltWheelSmall06" rotSpeed="-250" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
            <animationNode node="conveyorBig_belt" class="ScrollingAnimation" shaderParameterName="offsetUV" shaderComponentScale="-1 0 0 0" scrollSpeed="-0.2" turnOnFadeTime="3" turnOffFadeTime="3" />
            <animationNode node="conveyorBig_wheel" rotSpeed="-220" rotAxis="3" turnOnFadeTime="3" turnOffFadeTime="3"/>
        </animationNodes>

        <effectNodes>
            <effectNode effectNode="stoneCrusherEffectPreplaced" effectClass="MorphPositionEffect" materialType="belt" defaultFillType="GRAVEL" delay="0" fadeTime="6" speed="0.9" scrollLength="3" scrollSpeed="0.33" />
            <effectNode effectNode="conveyorSmallEffectPreplaced" effectClass="MorphPositionEffect" materialType="belt" defaultFillType="GRAVEL" delay="0" fadeTime="6" speed="0.9" scrollLength="10" scrollSpeed="0.33" />
            <effectNode effectNode="conveyorBigEffect" effectClass="MorphPositionEffect" materialType="belt" defaultFillType="GRAVEL" delay="0" fadeTime="6" speed="0.9" scrollLength="3" scrollSpeed="0.33" />
            <effectNode effectNode="conveyorBigEffectEnd" effectClass="MorphPositionEffect" materialType="belt" defaultFillType="GRAVEL" delay="0" fadeTime="6" speed="0.9" scrollLength="6" scrollSpeed="1.4" />
            <effectNode effectNode="effectSmoke01" effectClass="ShaderPlaneEffect" materialType="unloadingSmoke" defaultFillType="GRAVEL" fadeTime="0.5" startDelay="0.5" stopDelay="0.5" />
            <effectNode effectNode="effectSmoke02" effectClass="ShaderPlaneEffect" materialType="unloadingSmoke" defaultFillType="GRAVEL" fadeTime="0.5" startDelay="2.6" stopDelay="2.6" />
            <effectNode effectNode="effectSmoke03" effectClass="ShaderPlaneEffect" materialType="unloadingSmoke" defaultFillType="GRAVEL" fadeTime="0.5" startDelay="5.0" stopDelay="5.0" />
        </effectNodes>

        <sounds>
            <idle   file="sounds/placeables/productionPoints/ironFurnaceIdle.wav" linkNode="soundNodeEngine" loops="0" volumeScale="1.8" innerRadius="9" outerRadius="40" supportsReverb="false"/>
            <active file="sounds/placeables/productionPoints/ironFurnaceWork.wav" linkNode="soundNodeEngine" loops="0" volumeScale="1.0" innerRadius="9" outerRadius="40" supportsReverb="false"/>
        </sounds>
    </productionPoint>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="siloNode" filename="placeables/productionPoints/stoneCrusher/quarrySilo.i3d" />
        <dynamicallyLoadedPart node="1" linkNode="propsNode" filename="placeables/sharedAssets/propsBuilding/propsBuilding_quarry.i3d" />
    </dynamicallyLoadedParts>

