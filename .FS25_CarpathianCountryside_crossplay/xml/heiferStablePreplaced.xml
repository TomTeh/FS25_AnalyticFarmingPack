<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="mapCC_cowYoungHusbandry" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_animalBarnHeiferStablePreplaced</name>
        <image>placeables/animalHusbandry/store_heiferStable.png</image>
        <functions>
            <function>$l10n_function_heiferStable</function>
        </functions>
        <price>20000</price>
        <dailyUpkeep>50</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDFARMING</brand>
        <species>placeable</species>
        <category>animalpens</category>
        <brush>
            <type>placeable</type>
            <category>animals</category>
            <tab>cows</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-10" cameraYRot="140" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>442112</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>98816</indexBufferMemoryUsage>
        <textureMemoryUsage>8650752</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/animalHusbandry/heiferStable.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
            <testArea startNode="testAreaStart2" endNode="testAreaEnd2" />
        </testAreas>

        <sounds>
            <place template="medImp" />
            <placeLayered template="cowLayer" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="false" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart2" endNode="tipOcclusionUpdateAreaEnd2" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
            <updateArea startNode="tipOcclusionUpdateAreaStart2" endNode="tipOcclusionUpdateAreaEnd2" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="markerFood" filename="$data/shared/assets/marker/markerIconFood.i3d" adjustToGround="false" />
        <triggerMarker node="markerAnimals" filename="placeables/sharedAssets/marker/markerIconCowInOut.i3d" adjustToGround="false" />
        <triggerMarker node="markerStrawBale" filename="$data/shared/assets/marker/markerIconBales.i3d" adjustToGround="false" />
        <triggerMarker node="markerAdditionalPoles" filename="placeables/sharedAssets/marker/markerIconHideRoof.i3d" adjustToGround="false" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="COW" teleportNode="teleportNode" />
    </hotspots>

    <lights>
        <group name="$l10n_action_placeableLightShed" triggerNode="controledLightsTrigger">
            <sounds>
                <toggle template="lizardFloodLight" innerRadius="20" outerRadius="50" volumeScale="0.2"/>
            </sounds>
        </group>

        <sharedLight filename="placeables/sharedAssets/lights/neonLight01.xml" linkNode="neonLight01_01" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight01.xml" linkNode="neonLight01_02" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight01.xml" linkNode="neonLight01_03" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight01.xml" linkNode="neonLight01_04" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight01.xml" linkNode="neonLight01_05" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight01.xml" linkNode="neonLight01_06" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight01.xml" linkNode="neonLight01_07" groupIndex="1"/>

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
            </high>
        </realLights>
    </lights>

    <animatedObjects>
        <animatedObject saveId="heiferStable_gate1" >
            <animation duration="3">
                <part node="gate1Left">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -100 0"/>
                </part>
                <part node="gate1Right">
                    <keyFrame time="0.0" rotation="0 0 0" />
                    <keyFrame time="1.0" rotation="0 95 0" />
                </part>
            </animation>
            <controls triggerNode="gate1_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="gate1_sound" template="fenceMetalLoop" volumeScale="0.85"/>
                <posEnd linkNode="gate1_sound" template="fenceMetalOpen" volumeScale="0.4" />
                <negEnd linkNode="gate1_sound" template="fenceMetalClose" volumeScale="0.4" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="heiferStable_gate2" >
            <animation duration="3">
                <part node="gate2Left">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -91 0"/>
                </part>
                <part node="gate2Right">
                    <keyFrame time="0.0" rotation="0 0 0" />
                    <keyFrame time="1.0" rotation="0 90.5 0" />
                </part>
            </animation>
            <controls triggerNode="gate2_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="gate2_sound" template="fenceMetalLoop" volumeScale="0.85"/>
                <posEnd linkNode="gate2_sound" template="fenceMetalOpen" volumeScale="0.4" />
                <negEnd linkNode="gate2_sound" template="fenceMetalClose" volumeScale="0.4" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="heiferStable_additionalPoles" >
            <animation duration="0.2">
                <part node="heiferStablePolesAdditionalLOD0">
                    <keyFrame time="0.0" visibility="false"/>
                    <keyFrame time="1.0" visibility="true"/>
                </part>
                <part node="heiferStablePolesAdditionalLOD1">
                    <keyFrame time="0.0" visibility="false"/>
                    <keyFrame time="1.0" visibility="true"/>
                </part>
                <part node="heiferStableRoofSealing">
                    <keyFrame time="0.0" visibility="true"/>
                    <keyFrame time="1.0" visibility="false"/>
                </part>
                <part node="roofShadow">
                    <keyFrame time="0.0" visibility="true"/>
                    <keyFrame time="1.0" visibility="false"/>
                </part>
            </animation>
            <controls triggerNode="additionalPoles_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_heiferStableAddPoles" negText="action_heiferStableRemovePoles" />
        </animatedObject>
    </animatedObjects>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch01" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
    </dynamicallyLoadedParts>

    <infoTrigger triggerNode="infoTrigger" />

    <husbandry saveId="Animals_COW" hasStatistics="false">
        <storage node="storageNode" fillTypes="STRAW MANURE" isExtension="false">
            <capacity fillType="STRAW" capacity="40000" />
            <capacity fillType="MANURE" capacity="0" />
        </storage>

        <unloadingStation supportsExtension="true" storageRadius="90" hideFromPricesMenu="true">
            <unloadTrigger exactFillRootNode="exactFillRootNodeStraw" fillTypes="STRAW" />
            <baleTrigger triggerNode="baleTriggerStraw" fillTypes="STRAW"/>
            <palletTrigger triggerNode="palletTriggerStraw" fillTypes="STRAW"/>
            <unloadTrigger fillTypes="MANURE" />
        </unloadingStation>

        <loadingStation supportsExtension="true" storageRadius="90" fillTypes="STRAW" />

        <animals type="COW" maxNumAnimals="50">
            <navigation rootNode="navMeshNode" filename="placeables/animalHusbandry/heiferStableNavigationMesh.i3d" />
            <loadingTrigger node="animalLoadTrigger" />
        </animals>

        <food capacity="30000" >
            <dynamicFoodPlane node="fillVolumeFood" defaultFillType="FORAGE" maxAllowedHeapAngle="60" maxSubDivEdgeLength="0.5"/>
            <foodPlaces>
                <foodPlace node="foodPlace1" />
                <foodPlace node="foodPlace2" />
                <foodPlace node="foodPlace3" />
                <foodPlace node="foodPlace4" />
                <foodPlace node="foodPlace5" />
                <foodPlace node="foodPlace6" />
                <foodPlace node="foodPlace7" />
                <foodPlace node="foodPlace8" />
                <foodPlace node="foodPlace9" />
                <foodPlace node="foodPlace10" />
            </foodPlaces>
            <unloadTrigger exactFillRootNode="exactFillRootNodeFood"/>
            <baleTrigger triggerNode="baleTriggerFood"/>
            <palletTrigger triggerNode="palletTriggerFood"/>
        </food>

        <water automaticWaterSupply="true" />

        <straw>
            <manure factor="1.5" />
            <strawPlane node="strawPlane" minY="-0.275" maxY="-0.03" changeVisibility="true" colorChange="false" />
        </straw>
    </husbandry>

