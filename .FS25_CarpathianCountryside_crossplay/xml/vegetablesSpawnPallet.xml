<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="pallet" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>$l10n_storeItem_vegetablesPallet</name>
        <image>objects/pallets/vegetablesSpawnPallet/store_vegetablesSpawnPallet.png</image>
        <price>130</price>
        <category>pallets</category>
        <brand>NONE</brand>
        <showInStore>false</showInStore>
        <canBeSold>true</canBeSold>
        <allowLeasing>false</allowLeasing>
        <financeCategory>OTHER</financeCategory>
        <vertexBufferMemoryUsage>48896</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>9472</indexBufferMemoryUsage>
        <textureMemoryUsage>655360</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_pallet</typeDesc>
        <filename>objects/pallets/vegetablesSpawnPallet/vegetablesSpawnPallet.i3d</filename>
        <size width="1.7" length="1.3" height="1.25" />
        <canBeReset>false</canBeReset>
        <components maxMass="600">
            <component centerOfMass="0 0.1 0" solverIterationCount="10" mass="150"/>
        </components>
        <showInVehicleMenu>false</showInVehicleMenu>
        <mapHotspot available="false" />
        <input allowed="false"/>
    </base>

    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration>
                <fillUnits removeVehicleIfEmpty="true">
                    <fillUnit unitTextOverride="$l10n_unit_literShort" fillTypeCategories="BULK" capacity="2000" ignoreFillLimit="true">
                        <exactFillRootNode node="exactFillRootNode" extraEffectDistance="0.75"/>
                    </fillUnit>
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>

    <fillVolume>
        <fillVolumeConfigurations>
            <fillVolumeConfiguration>
                <volumes>
                    <volume node="fillVolume" maxAllowedHeapAngle="8" fillUnitIndex="1" />
                </volumes>
            </fillVolumeConfiguration>
        </fillVolumeConfigurations>
    </fillVolume>

    <fillTriggerVehicle triggerNode="fillTrigger" fillUnitIndex="1" litersPerSecond="200"/>

    <dynamicMount triggerNode="dynamicMountTrigger" triggerForceAcceleration="3" additionalMountDistance="0.785" jointTransY="0.106" jointLimitToRotY="true"/>

    <tensionBeltObject>
        <meshNodes>
            <meshNode node="vegetablesPallet_vis"/>
        </meshNodes>
    </tensionBeltObject>

    <i3dMappings>
        <i3dMapping id="fillablePallet_main_component1" node="0>" />
        <i3dMapping id="vegetablesPallet_vis" node="0>0" />
        <i3dMapping id="dynamicMountTrigger" node="0>0|0" />
        <i3dMapping id="dischargeNode" node="0>0|1" />
        <i3dMapping id="exactFillRootNode" node="0>0|2|0" />
        <i3dMapping id="fillVolume" node="0>0|2|1" />
        <i3dMapping id="fillTrigger" node="0>0|2|2" />
    </i3dMappings>
</vehicle>
