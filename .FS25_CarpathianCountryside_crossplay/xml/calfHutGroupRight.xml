    <storeData>
        <name>$l10n_placeableObject_calfHutGroupRight</name>
        <image>placeables/animalHusbandry/store_calfHutGroupRight.png</image>
        <price>1500</price>
        <functions>
            <function>$l10n_function_calfHut</function>
        </functions>
        <lifetime>1000</lifetime>
        <dailyUpkeep>15</dailyUpkeep>
        <rotation>0</rotation>
        <brand>LIZARDFARMING</brand>
        <species>placeable</species>
        <category>animalpens</category>
        <brush>
            <type>placeable</type>
            <category>animals</category>
            <tab>cows</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-20" cameraYRot="140" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>194816</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>50688</indexBufferMemoryUsage>
        <textureMemoryUsage>5111808</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/animalHusbandry/calfHutGroup.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
            <placeLayered template="cowLayer" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStartRight" widthNode="clearAreaWidthRight" heightNode="clearAreaHeightRight"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStartRight" widthNode="levelAreaWidthRight" heightNode="levelAreaHeightRight" groundType="concrete"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="markerAnimals" filename="placeables/sharedAssets/marker/markerIconCowInOut.i3d" adjustToGround="false" />
        <triggerMarker node="markerFoodRight" filename="$data/shared/assets/marker/markerIconFood.i3d" adjustToGround="false" />
        <triggerMarker node="markerWaterRight" filename="$data/shared/assets/marker/markerIconWater.i3d" adjustToGround="false" />
        <triggerMarker node="markerFenceRight" filename="$data/shared/assets/marker/markerIconExclamationMark.i3d" adjustToGround="false" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="COW" linkNode="mapPosition" teleportNode="teleportNode" />
    </hotspots>

    <animatedObjects>
        <animatedObject saveId="calfHutGroupRight_fence" >
            <animation duration="3">
                <part node="fenceTransform">
                    <keyFrame time="0.2" translation="0 0 0" />
                    <keyFrame time="1.0" translation="-3.7 0 0" />
                </part>
                <part node="railingFeedRight">
                    <keyFrame time="0.0" translation="1.7 0 -1.9" rotation="0 0 0" />
                    <keyFrame time="0.2" translation="1.7 0 -2.1" rotation="0 -2.78 0" />
                </part>
                <part node="railingSideLeft">
                    <keyFrame time="0.0" translation="1.7 0 1.9" rotation="0 0 0" />
                    <keyFrame time="0.2" translation="1.7 0 2.1" rotation="0 2.78 0" />
                </part>
                <part node="markers">
                    <keyFrame time="0.0" visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="triggerRight" posAction="ACTIVATE_HANDTOOL" posText="action_moveFenceClean" negText="action_moveFenceBack" />
            <sounds>
                <moving linkNode="soundNode" template="metalDoorsLoop" volumeScale="0.4" />
                <posEnd linkNode="soundNode" template="fenceMetalOpen" volumeScale="0.2" />
                <negEnd linkNode="soundNode" template="fenceMetalOpen" volumeScale="0.2" />
            </sounds>
        </animatedObject>
    </animatedObjects>

    <infoTrigger triggerNode="infoTriggerRight" />

    <husbandry saveId="Animals_COW" hasStatistics="false">
        <storage node="storageNode" fillTypes="STRAW WATER MANURE" isExtension="false">
            <capacity fillType="STRAW" capacity="1800" />
            <capacity fillType="WATER" capacity="400" />
            <capacity fillType="MANURE" capacity="3000" />

            <fillPlane node="manurePlane" fillType="MANURE" changeVisibility="true" minY="-0.21" maxY="0.0"/>
        </storage>

        <unloadingStation supportsExtension="false" storageRadius="1" hideFromPricesMenu="true">
            <unloadTrigger exactFillRootNode="exactFillRootNode_strawRight" fillTypes="STRAW" />
            <baleTrigger triggerNode="baleTrigger_strawRight" fillTypes="STRAW" />
            <palletTrigger triggerNode="palletTrigger_strawRight" fillTypes="STRAW"/>
            <unloadTrigger exactFillRootNode="exactFillRootNode_waterRight" fillTypes="WATER" />
            <palletTrigger triggerNode="palletTrigger_waterRight" fillTypes="WATER"/>
        </unloadingStation>

        <loadingStation supportsExtension="false" storageRadius="1">
            <loadTrigger triggerNode="loadTriggerManure" fillTypes="MANURE" autoStart="true" fillLitersPerSecond="250"/>
        </loadingStation>

        <animals type="COW" maxNumAnimals="5">
            <navigation rootNode="navMeshNode" filename="placeables/animalHusbandry/calfHutGroupNavigationMesh.i3d" />
            <loadingTrigger node="animalLoadTrigger" />
        </animals>

        <food capacity="1600" >
            <dynamicFoodPlane node="foodVolume_foodRight" defaultFillType="FORAGE"/>
            <unloadTrigger exactFillRootNode="exactFillRootNode_foodRight" />
            <baleTrigger triggerNode="baleTrigger_foodRight"/>
            <palletTrigger triggerNode="palletTrigger_foodRight"/>
        </food>

        <water automaticWaterSupply="false" >
            <waterPlane node="waterPlanes_waterRight" minY="-0.07" maxY="0.0" changeVisibility="true" />
        </water>

        <straw>
            <manure factor="1.5" />
            <strawPlane node="strawPlane" minY="-0.155" maxY="0.0" changeVisibility="true" />
        </straw>
    </husbandry>

