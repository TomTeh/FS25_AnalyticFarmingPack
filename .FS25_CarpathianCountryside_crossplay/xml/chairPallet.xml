<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="pallet" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://validation.gdn.giants-software.com/xml/fs25/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>$l10n_storeItem_chairPallet</name>
        <image>objects/pallets/chairPallet/store_chairPallet.png</image>
        <price>1550</price>
        <category>pallets</category>
        <brand>NONE</brand>
        <showInStore>false</showInStore>
        <canBeSold>false</canBeSold>
        <financeCategory>OTHER</financeCategory>

        <storeIconRendering>
            <settings centerIcon="true" cameraXRot="-15" cameraYRot="35"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>27136</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>6656</indexBufferMemoryUsage>
        <textureMemoryUsage>851968</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_pallet</typeDesc>
        <filename>objects/pallets/chairPallet/chairPallet.i3d</filename>
        <size width="1.3" length="0.9" height="1.3" />
        <canBeReset>false</canBeReset>
        <components maxMass="600">
            <component centerOfMass="0 0.2 0" solverIterationCount="10" mass="400"/>
        </components>
        <showInVehicleMenu>false</showInVehicleMenu>
        <mapHotspot available="false" />
        <input allowed="false"/>
    </base>

    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration>
                <fillUnits removeVehicleIfEmpty="true">
                    <fillUnit unitTextOverride="$l10n_unit_pieces" fillTypes="CHAIR" capacity="1000" ignoreFillLimit="true"/>
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>

    <pallet fillUnitIndex="1" linkNode="chairPallet_main_component1">
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletNew_diffuse.dds"/>
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletMiddle_diffuse.dds"/>
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletOld_diffuse.dds"/>

        <content>
            <object node="chair01" tensionBeltNode="chair01Tension"/>
            <object node="chair02" tensionBeltNode="chair02Tension"/>
            <object node="chair03" tensionBeltNode="chair03Tension"/>
            <object node="chair04" tensionBeltNode="chair04Tension"/>
        </content>

        <sounds>
            <unload template="palletsFillWood" pitchScale="0.7" volumeScale="2.5" supportsReverb="false"/>
        </sounds>
    </pallet>

    <dynamicMount triggerNode="dynamicMountTrigger" triggerForceAcceleration="4" additionalMountDistance="1.255" jointTransY="0.106" jointLimitToRotY="true"/>

    <i3dMappings>
        <i3dMapping id="chairPallet_main_component1" node="0>" />
        <i3dMapping id="dynamicMountTrigger" node="0>0" />
        <i3dMapping id="chair01" node="0>1|0" />
        <i3dMapping id="chair01Tension" node="0>1|0|0" />
        <i3dMapping id="chair02" node="0>1|1" />
        <i3dMapping id="chair02Tension" node="0>1|1|0" />
        <i3dMapping id="chair03" node="0>1|2" />
        <i3dMapping id="chair03Tension" node="0>1|2|0" />
        <i3dMapping id="chair04" node="0>1|3" />
        <i3dMapping id="chair04Tension" node="0>1|3|0" />
    </i3dMappings>
</vehicle>
