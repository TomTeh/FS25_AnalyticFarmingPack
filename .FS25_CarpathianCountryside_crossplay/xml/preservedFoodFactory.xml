<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_preservedFoodFactory</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/mapIcon_preservedFoodFactory.png</image>
        <price>330000</price>
        <dailyUpkeep>120</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>67328</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>18944</indexBufferMemoryUsage>
        <textureMemoryUsage>131072</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/preservedFoodFactory.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <buysFarmland>true</buysFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
        </updateAreas>
        <splines>
            <spline node="aiSpline" />
        </splines>
    </ai>

    <infoTrigger triggerNode="infoTrigger"/>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarkerStorage" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarkerVolume" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="false" />
        <triggerMarker node="unloadTriggerMarkerGrain" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="markerLoadingOrganicWaste" filename="$data/shared/assets/marker/markerIconLoad.i3d" adjustToGround="true" />
    </triggerMarkers>

    <productionPoint>
        <productions sharedThroughputCapacity="false">
            <production id="preservedFoodCarrots" name="$l10n_fillType_preservedFoodCarrots" cyclesPerHour="10" costsPerActiveHour="4">
                <inputs>
                    <input fillType="CARROT" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="PRESERVEDCARROTS" amount="45" />
                    <output fillType="ORGANICWASTE" amount="5" />
                </outputs>
            </production>

            <production id="preservedFoodParsnip" name="$l10n_fillType_preservedFoodParsnip" cyclesPerHour="10" costsPerActiveHour="4">
                <inputs>
                    <input fillType="PARSNIP" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="PRESERVEDPARSNIP" amount="45" />
                    <output fillType="ORGANICWASTE" amount="5" />
                </outputs>
            </production>

            <production id="preservedFoodBeetRoot" name="$l10n_fillType_preservedFoodBeetRoot" cyclesPerHour="10" costsPerActiveHour="4">
                <inputs>
                    <input fillType="BEETROOT" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="PRESERVEDBEETROOT" amount="45" />
                    <output fillType="ORGANICWASTE" amount="5" />
                </outputs>
            </production>

            <production id="preservedFoodCannedPea" name="$l10n_fillType_cannedPea" cyclesPerHour="10" costsPerActiveHour="2">
                <inputs>
                    <input fillType="PEA" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="CANNED_PEAS" amount="45" />
                    <output fillType="ORGANICWASTE" amount="5" />
                </outputs>
            </production>

            <production id="preservedFoodSpinachBags" name="$l10n_fillType_spinachBag" cyclesPerHour="10" costsPerActiveHour="2">
                <inputs>
                    <input fillType="SPINACH" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="SPINACH_BAGS" amount="45" />
                    <output fillType="ORGANICWASTE" amount="3" />
                </outputs>
            </production>

            <production id="preservedFoodRiceBags" name="%s (%s)" params="$l10n_fillType_riceBag|$l10n_fillType_riceLongGrain" cyclesPerHour="10" costsPerActiveHour="2">
                <inputs>
                    <input fillType="RICELONGGRAIN" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="RICE_BAGS" amount="45" />
                </outputs>
            </production>

            <production id="preservedFoodRiceBoxes" name="%s (%s)" params="$l10n_fillType_riceBox|$l10n_fillType_rice" cyclesPerHour="10" costsPerActiveHour="2">
                <inputs>
                    <input fillType="RICE" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="RICE_BOXES" amount="55" />
                </outputs>
            </production>

            <production id="preservedFoodjarredGreenbean" name="$l10n_fillType_jarredGreenBean" cyclesPerHour="10" costsPerActiveHour="2">
                <inputs>
                    <input fillType="GREENBEAN" amount="100" />
                </inputs>
                <outputs>
                    <output fillType="JARRED_GREENBEAN" amount="45" />
                    <output fillType="ORGANICWASTE" amount="4" />
                </outputs>
            </production>

            <production id="preservedFoodFermentedNapaCabbage" name="$l10n_fillType_fermentedNapaCabbage" cyclesPerHour="10" costsPerActiveHour="5">
                <inputs>
                    <input fillType="NAPACABBAGE"  amount="20" />
                    <input fillType="GARLIC"       amount="2" />
                    <input fillType="SPRING_ONION" amount="2" />
                    <input fillType="CHILLI"       amount="2" />
                </inputs>
                <outputs>
                    <output fillType="FERMENTEDNAPACABBAGE" amount="42" />
                    <output fillType="ORGANICWASTE" amount="3" />
                </outputs>
            </production>

            <production id="noodleSoupFlour" name="%s (%s)" params="$l10n_fillType_noodleSoup|$l10n_fillType_flour" cyclesPerHour="10" costsPerActiveHour="2">
                <inputs>
                    <input fillType="FLOUR" amount="55" />
                    <input fillType="EGG"   amount="10" />
                </inputs>
                <outputs>
                    <output fillType="NOODLESOUP" amount="40" />
                </outputs>
            </production>
            <production id="noodleSoupRiceFlour" name="%s (%s)" params="$l10n_fillType_noodleSoup|$l10n_fillType_riceFlour" cyclesPerHour="10" costsPerActiveHour="1">
                <inputs>
                    <input fillType="RICEFLOUR" amount="42" />
                    <input fillType="EGG"       amount="10" />
                </inputs>
                <outputs>
                    <output fillType="NOODLESOUP" amount="40" />
                </outputs>
            </production>

            <production id="riceRollsRiceLongGrain" name="%s (%s)" params="$l10n_fillType_riceRolls|$l10n_fillType_riceLongGrain" cyclesPerHour="10" costsPerActiveHour="5">
                <inputs>
                    <input fillType="RICELONGGRAIN" amount="60" />
                </inputs>
                <outputs>
                    <output fillType="RICEROLLS" amount="30" />
                </outputs>
            </production>
            <production id="riceRollsRice" name="%s (%s)" params="$l10n_fillType_riceRolls|$l10n_fillType_rice" cyclesPerHour="10" costsPerActiveHour="7">
                <inputs>
                    <input fillType="RICE" amount="56" />
                </inputs>
                <outputs>
                    <output fillType="RICEROLLS" amount="50" />
                </outputs>
            </production>

            <production id="pickles" name="$l10n_fillType_pickles" cyclesPerHour="22" costsPerActiveHour="4">
                <inputs>
                    <input fillType="CUCUMBER" amount="10" />
                    <input fillType="SUGAR" amount="1" />
                    <input fillType="CARROT" amount="1" />
                    <input fillType="ONION" amount="1" />
                </inputs>
                <outputs>
                    <output fillType="PICKLES" amount="10" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="false" litersForFullPriceDrop="300000" fullPriceRecoverHours="48">
            <unloadTrigger exactFillRootNode="unloadTriggerStorage" aiNode="unloadTriggerAINodeStorage" fillTypes="CARROT PARSNIP BEETROOT PEA SPINACH RICELONGGRAIN RICE GREENBEAN ONION NAPACABBAGE GARLIC SPRING_ONION CHILLI CUCUMBER FLOUR RICEFLOUR EGG SUGAR"/>
            <palletTrigger triggerNode="palletTriggerStorage" aiNode="unloadTriggerAINodeStorage" fillTypes="CARROT PARSNIP BEETROOT PEA SPINACH RICELONGGRAIN RICE GREENBEAN ONION NAPACABBAGE GARLIC SPRING_ONION CHILLI CUCUMBER FLOUR RICEFLOUR EGG SUGAR"/>
            <unloadTrigger exactFillRootNode="unloadTriggerVolume" fillTypes="CARROT PARSNIP BEETROOT PEA SPINACH GREENBEAN"/>
            <unloadTrigger exactFillRootNode="unloadTriggerGrain" fillTypes="RICELONGGRAIN RICE"/>
        </sellingStation>

        <loadingStation>
            <loadTrigger triggerNode="loadingTriggerOrganicWaste" fillLitersPerSecond="1000" dischargeNode="dischargeNodeOrganicWaste" fillTypes="ORGANICWASTE" >
                <effectNode effectClass="PipeEffect" effectNode="pipeEffectOrganicWaste"      materialType="pipe"           fadeTime="0.5" maxBending="0" controlPoint="4.6 0 0 0" />
                <effectNode                          effectNode="pipeEffectSmokeOrganicWaste" materialType="unloadingSmoke" fadeTime="0.5" />
            </loadTrigger>
        </loadingStation>

        <palletSpawner node="palletSpawner">
            <spawnPlaces>
                <spawnPlace startNode="spawnSpace1start" endNode="spawnSpace1end" />
                <spawnPlace startNode="spawnSpace2start" endNode="spawnSpace2end" />
                <spawnPlace startNode="spawnSpace3start" endNode="spawnSpace3end" />
                <spawnPlace startNode="spawnSpace4start" endNode="spawnSpace4end" />
            </spawnPlaces>
        </palletSpawner>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="CARROT"               capacity="300000" />
            <capacity fillType="PARSNIP"              capacity="300000" />
            <capacity fillType="BEETROOT"             capacity="300000" />
            <capacity fillType="PEA"                  capacity="300000" />
            <capacity fillType="SPINACH"              capacity="300000" />
            <capacity fillType="ONION"                capacity="4000" />
            <capacity fillType="RICELONGGRAIN"        capacity="300000" />
            <capacity fillType="RICE"                 capacity="300000" />
            <capacity fillType="GREENBEAN"            capacity="300000" />
            <capacity fillType="NAPACABBAGE"          capacity="48000" />
            <capacity fillType="GARLIC"               capacity="4800" />
            <capacity fillType="SPRING_ONION"         capacity="4800" />
            <capacity fillType="CHILLI"               capacity="4800" />
            <capacity fillType="CUCUMBER"             capacity="30000" />
            <capacity fillType="FLOUR"                capacity="140000" />
            <capacity fillType="RICEFLOUR"            capacity="110000" />
            <capacity fillType="EGG"                  capacity="24000" />
            <capacity fillType="SUGAR"                capacity="4000" />
            <capacity fillType="PRESERVEDCARROTS"     capacity="110000" />
            <capacity fillType="PRESERVEDPARSNIP"     capacity="110000" />
            <capacity fillType="PRESERVEDBEETROOT"    capacity="110000" />
            <capacity fillType="CANNED_PEAS"          capacity="110000" />
            <capacity fillType="SPINACH_BAGS"         capacity="110000" />
            <capacity fillType="RICE_BAGS"            capacity="110000" />
            <capacity fillType="RICE_BOXES"           capacity="110000" />
            <capacity fillType="JARRED_GREENBEAN"     capacity="110000" />
            <capacity fillType="FERMENTEDNAPACABBAGE" capacity="110000" />
            <capacity fillType="NOODLESOUP"           capacity="96000" />
            <capacity fillType="RICEROLLS"            capacity="120000" />
            <capacity fillType="PICKLES"              capacity="30000" />
            <capacity fillType="ORGANICWASTE"        capacity="125000" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <effectNodes>
            <effectNode effectClass="ParticleEffect" effectNode="smokeChimenyEffectShape01" particleType="SMOKE_CHIMNEY" emitCountScale="75"/>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape01" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="40"/>
        </effectNodes>

        <sounds>
            <idle template="preservedFoodIdle" linkNode="soundNode" innerRadius="20" outerRadius="60" />
            <active template="preservedFoodWork" linkNode="soundNode" innerRadius="20" outerRadius="60" />
        </sounds>
    </productionPoint>

    <i3dMappings>
        <i3dMapping id="sellingStation" node="0>0" />
        <i3dMapping id="unloadTriggerStorage" node="0>0|0" />
        <i3dMapping id="palletTriggerStorage" node="0>0|1" />
        <i3dMapping id="unloadTriggerMarkerStorage" node="0>0|2" />
        <i3dMapping id="unloadTriggerAINodeStorage" node="0>0|3" />
        <i3dMapping id="unloadTriggerVolume" node="0>0|4" />
        <i3dMapping id="unloadTriggerMarkerVolume" node="0>0|5" />
        <i3dMapping id="unloadTriggerGrain" node="0>0|6" />
        <i3dMapping id="unloadTriggerMarkerGrain" node="0>0|7" />
        <i3dMapping id="aiSpline" node="0>0|8" />
        <i3dMapping id="loadingTrigger" node="0>1" />
        <i3dMapping id="loadingTriggerOrganicWaste" node="0>1|0" />
        <i3dMapping id="dischargeNodeOrganicWaste" node="0>1|1" />
        <i3dMapping id="pipeEffectOrganicWaste" node="0>1|2|0" />
        <i3dMapping id="pipeEffectSmokeOrganicWaste" node="0>1|2|1" />
        <i3dMapping id="markerLoadingOrganicWaste" node="0>1|3" />
        <i3dMapping id="playerTrigger" node="0>2|0" />
        <i3dMapping id="playerTriggerMarker" node="0>2|0|0" />
        <i3dMapping id="soundNode" node="0>2|1" />
        <i3dMapping id="smokeChimenyEffectShape01" node="0>2|2|0" />
        <i3dMapping id="smokeEffectShape01" node="0>2|2|1" />
        <i3dMapping id="palletSpawner" node="0>3" />
        <i3dMapping id="spawnSpace1start" node="0>3|0" />
        <i3dMapping id="spawnSpace1end" node="0>3|0|0" />
        <i3dMapping id="spawnSpace2start" node="0>3|1" />
        <i3dMapping id="spawnSpace2end" node="0>3|1|0" />
        <i3dMapping id="spawnSpace3start" node="0>3|2" />
        <i3dMapping id="spawnSpace3end" node="0>3|2|0" />
        <i3dMapping id="spawnSpace4start" node="0>3|3" />
        <i3dMapping id="spawnSpace4end" node="0>3|3|0" />
        <i3dMapping id="infoTrigger" node="0>4" />
        <i3dMapping id="hotspotNode" node="0>5" />
        <i3dMapping id="teleportNode" node="0>6" />
    </i3dMappings>
</placeable>
