<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="heapSpawner" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://validation.gdn.giants-software.com/xml/fs25/placeable.xsd">
    <storeData>
        <name>$l10n_productionPoint_quarryClay</name>
        <functions>
            <function>$l10n_function_heapSpawnerClay</function>
        </functions>
        <image>placeables/productionPoints/quarry/mapIcon_quarryClay.png</image>
        <price>1</price>
        <dailyUpkeep>2</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>8192</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>3840</indexBufferMemoryUsage>
        <textureMemoryUsage>131072</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/quarry/quarryClayPreplaced.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1" />
    </indoorAreas>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas></updateAreas>
    </ai>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <heapSpawner>
        <spawnArea fillType="CLAY" litersPerHour="1600" >
            <area startNode="spawnAreaStart1" widthNode="spawnAreaWidth1" heightNode="spawnAreaHeight1" />

            <effectNodes>
                <effectNode effectNode="effectParticle" effectClass="ParticleEffect" particleType="UNLOADING" materialType="unloadingParticle" defaultFillType="CLAY" emitCountScale="0.1" speed="0.1" fadeScale="0.1" />
                <effectNode effectNode="effectSmoke" materialType="unloadingSmoke" fadeTime="0.5" useFruitColor="true"/>
            </effectNodes>

            <sounds>
                <dropping file="$data/sounds/tools/fillTypes/fillWoodchipLoop_01.wav" linkNode="soundNode" loops="0" innerRadius="4" outerRadius="30" supportsReverb="false" pitchScale="1.0">
                    <volume indoor="0.2" outdoor="0.8"/>
                </dropping>
            </sounds>
        </spawnArea>
    </heapSpawner>

    <i3dMappings>
        <i3dMapping id="spawnAreaStart1" node="0>0|0|0" />
        <i3dMapping id="spawnAreaWidth1" node="0>0|0|1" />
        <i3dMapping id="spawnAreaHeight1" node="0>0|0|2" />
        <i3dMapping id="effectParticle" node="0>0|1|0" />
        <i3dMapping id="effectSmoke" node="0>0|1|1" />
        <i3dMapping id="soundNode" node="0>0|2|0" />
        <i3dMapping id="hotspotNode" node="0>1" />
        <i3dMapping id="teleportNode" node="0>2" />
        <i3dMapping id="indoorAreaStart1" node="0>3|0" />
        <i3dMapping id="indoorAreaWidth1" node="0>3|0|0" />
        <i3dMapping id="indoorAreaHeight1" node="0>3|0|1" />
    </i3dMappings>
</placeable>
