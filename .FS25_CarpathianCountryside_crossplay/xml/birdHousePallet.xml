        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletOld_diffuse.dds"/>

        <content>
            <object node="birdHouse01" tensionBeltNode="birdHouse01Tension"/>
            <object node="birdHouse02" tensionBeltNode="birdHouse02Tension"/>
            <object node="birdHouse03" tensionBeltNode="birdHouse03Tension"/>
            <object node="birdHouse04" tensionBeltNode="birdHouse04Tension"/>
            <object node="birdHouse05" tensionBeltNode="birdHouse05Tension"/>
            <object node="birdHouse06" tensionBeltNode="birdHouse06Tension"/>
            <object node="birdHouse07" tensionBeltNode="birdHouse07Tension"/>
        </content>

        <sounds>
            <unload template="palletsFillWood" pitchScale="1" volumeScale="2.5" supportsReverb="false"/>
        </sounds>
    </pallet>

    <dynamicMount triggerNode="dynamicMountTrigger" triggerForceAcceleration="4" additionalMountDistance="0.554" jointTransY="0.106" jointLimitToRotY="true"/>

