        <sharedLight filename="placeables/sharedAssets/lights/neonLight02.xml" linkNode="neonLight02_07" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight02.xml" linkNode="neonLight02_08" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight02.xml" linkNode="neonLight02_09" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight02.xml" linkNode="neonLight02_10" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/neonLight02.xml" linkNode="neonLight02_11" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight01" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 45" />
        </sharedLight>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight02" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 45" />
        </sharedLight>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight03" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 65" />
        </sharedLight>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight04" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 55" />
        </sharedLight>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight05" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 55" />
        </sharedLight>

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
            </high>
        </realLights>
    </lights>

    <infoTrigger triggerNode="infoTrigger"/>

    <productionPoint>
        <productions sharedThroughputCapacity="true">
            <production id="metal" name="%s" params="$l10n_fillType_metal" cyclesPerHour="1" costsPerActiveHour="5">
                <inputs>
                    <input fillType="IRONORE" amount="660" />
                </inputs>
                <outputs>
                    <output fillType="METAL" amount="460" />
                    <output fillType="BLASTFURNACESLAG" amount="200" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" supportsExtension="false" hideFromPricesMenu="true" allowMissions="false">
            <unloadTrigger exactFillRootNode="unloadTrigger" aiNode="unloadTriggerAINode" fillTypes="IRONORE" />
            <palletTrigger triggerNode="palletTrigger" aiNode="unloadTriggerAINode" fillTypes="IRONORE" />
        </sellingStation>

        <loadingStation>
            <loadTrigger triggerNode="loadingTrigger" fillLitersPerSecond="2000" dischargeNode="dischargeNode" fillTypes="BLASTFURNACESLAG" >
                <effectNode effectClass="PipeEffect" effectNode="pipeEffect"      materialType="pipe"           fadeTime="0.5" maxBending="0" controlPoint="4.3 0 0 0" />
                <effectNode                          effectNode="pipeEffectSmoke" materialType="unloadingSmoke" fadeTime="0.5" />
            </loadTrigger>
        </loadingStation>

        <palletSpawner>
            <spawnPlaces>
                <spawnPlace startNode="palletAreaStart1" endNode="palletAreaEnd1" fillTypes="METAL"/>
                <spawnPlace startNode="palletAreaStart2" endNode="palletAreaEnd2" fillTypes="METAL"/>
            </spawnPlaces>
        </palletSpawner>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="IRONORE"          capacity="60000" />
            <capacity fillType="METAL"            capacity="20000" />
            <capacity fillType="BLASTFURNACESLAG" capacity="90000" />

            <fillPlane node="fillPlaneIronOre" fillType="IRONORE" minY="-1.39" maxY="0" changeVisibility="true" />
            <fillPlane node="fillPlaneBlastFurnaceSlag" fillType="BLASTFURNACESLAG" minY="9.338" maxY="9.65" changeVisibility="true" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <animationNodes>
            <animationNode node="conveyorBelt" class="ScrollingAnimation" shaderParameterName="offsetUV" shaderComponentScale="-1 0 0 0" scrollSpeed="-0.4" turnOnFadeTime="3" turnOffFadeTime="3" />
        </animationNodes>

        <effectNodes>
            <effectNode effectNode="effectBelt" effectClass="MorphPositionEffect" materialType="belt" defaultFillType="IRONORE" delay="0" fadeTime="2" speed="0.9" scrollLength="9" scrollSpeed="0.2" />
            <effectNode effectNode="smokeEffectChimneyShape01" effectClass="ParticleEffect" particleType="SMOKE_CHIMNEY" emitCountScale="50"/>
            <effectNode effectNode="smokeEffectShape01" effectClass="ParticleEffect" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="50"/>
            <effectNode effectNode="smokeEffectShape02" effectClass="ParticleEffect" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="50"/>
            <effectNode effectNode="siloEffect" effectClass="MorphPositionEffect" materialType="belt" defaultFillType="BLASTFURNACESLAG" delay="0" fadeTime="6" speed="0.9" scrollLength="6" scrollSpeed="1.4" />
        </effectNodes>

        <sounds>
            <idle   file="sounds/placeables/productionPoints/ironFurnaceIdle.wav" linkNode="soundNode" loops="0" volumeScale="2.3" innerRadius="7" outerRadius="50" supportsReverb="false"/>
            <active file="sounds/placeables/productionPoints/ironFurnaceWork.wav" linkNode="soundNode" loops="0" volumeScale="1.8" innerRadius="7" outerRadius="40" supportsReverb="false"/>
        </sounds>
    </productionPoint>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="siloNode" filename="placeables/productionPoints/stoneCrusher/quarrySilo.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="propsNode" filename="placeables/sharedAssets/propsBuilding/propsBuilding_ironFurnace.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="propsNode" filename="placeables/sharedAssets/props/props_ironFurnace.i3d" />
