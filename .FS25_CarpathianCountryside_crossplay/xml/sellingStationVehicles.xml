<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="workshop" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_sellingStation_vehicleShop</name>
        <image>placeables/sellingStations/mapIcon_sellingStationVehicles.png</image>
        <price>1</price>
        <dailyUpkeep>0</dailyUpkeep>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>placeableMisc</category>
        <vertexBufferMemoryUsage>1024</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>512</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/sellingStations/sellingStationVehicles.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas></updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="$data/shared/assets/marker/markerIconWrench.i3d" adjustToGround="true" />
    </triggerMarkers>	

    <hotspots>
        <hotspot type="SHOP" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <workshop>
        <sellingPoint playerTriggerNode="playerInteractionTrigger" iconNode="workshopMarker" sellTriggerNode="vehicleTrigger" ownWorkshop="false" />
    </workshop>

    <i3dMappings>
        <i3dMapping id="vehicleTrigger" node="0>0" />
        <i3dMapping id="playerInteractionTrigger" node="0>1" />
        <i3dMapping id="workshopMarker" node="0>1|0" />
        <i3dMapping id="playerTriggerMarker" node="0>1|0|0" />
        <i3dMapping id="hotspotNode" node="0>2" />
        <i3dMapping id="teleportNode" node="0>3" />
    </i3dMappings>
</placeable>
