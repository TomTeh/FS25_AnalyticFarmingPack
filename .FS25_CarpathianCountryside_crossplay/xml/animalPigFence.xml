<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="newFence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_animalPigFence</name>
        <functions>
            <function>$l10n_function_decoration</function>
        </functions>
        <image>placeables/fences/store_animalPigFence.png</image>
        <price>100</price>
        <dailyUpkeep>0</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDFARMING</brand>
        <species>PLACEABLE</species>
        <category>fences</category>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>

        <brush>
            <type>newFence</type>
            <category>decoration</category>
            <tab>newFences</tab>
        </brush>

        <storeIconRendering>
            <settings centerIcon="true"/>
            <objectBundle>
                <object filename="placeables/fences/animalPigFence.i3d">
                    <!-- poles -->
                    <node node="1|0" translation="0 0 0" rotation="0 90 0" scale="1 1 1"/>
                    <node node="1|1" translation="2 0 0" rotation="0 90 0" scale="1 1 1"/>
                    <node node="1|3" translation="4 0 0" rotation="0 90 0" scale="1 1 1"/>

                    <!-- panels -->
                    <node node="2|0" translation="0 0 0" rotation="0 90 0" scale="1 1 1"/>
                    <node node="2|1" translation="2 0 0" rotation="0 90 0" scale="1 1 1"/>
                </object>
            </objectBundle>
        </storeIconRendering>
        <vertexBufferMemoryUsage>242176</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>80640</indexBufferMemoryUsage>
        <textureMemoryUsage>1638400</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/fences/animalPigFence.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <sounds>
            <place template="fenceWoodImp" />
            <destroy template="destroyFence" />
        </sounds>
    </placement>

    <fence>
        <segment id="SEGMENT" class="FenceSegment" maxVerticalAngle="45">
            <poles>
                <pole node="pole01" radius="0.0"/>
                <pole node="pole02" radius="0.0"/>
                <pole node="pole03" radius="0.0"/>
                <pole node="pole04" radius="0.0"/>
            </poles>
            <panels maxScale="1.5">
                <panel node="panel01" length="2" />
                <panel node="panel02" length="2" />
                <panel node="panel03" length="2" />
                <panel node="panel04" length="2" />
            </panels>
        </segment>
        <segment id="GATE2m" class="FenceGate" maxVerticalAngle="45">
            <gate node="gate2m" length="2.26">
                <animatedObject saveId="animalPigFence_gate2m" >
                    <animation duration="1.2">
                        <part node="gate2mOpenALock">
                            <keyFrame time="0.0" translation="0.12 1.049 1.951"/>
                            <keyFrame time="0.05" translation="0.12 1.049 1.82"/>
                        </part>
                        <part node="gate2mOpenA">
                            <keyFrame time="0.05" rotation="0 0 0"/>
                            <keyFrame time="1.0" rotation="0 -90 0"/>
                        </part>
                    </animation>
                    <controls triggerNode="gate2mTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
                    <sounds>
                        <moving linkNode="gate2mSoundNode" template="fenceLoop" />
                        <posEnd linkNode="gate2mSoundNode" template="fenceOpen" />
                        <negEnd linkNode="gate2mSoundNode" template="fenceClose" />
                    </sounds>
                </animatedObject>
            </gate>
        </segment>
        <segment id="GATE4m" class="FenceGate" maxVerticalAngle="45">
            <gate node="gate4m" length="4.35">
                <animatedObject saveId="animalPigFence_gate4m" useAIBlockingRegion="true" >
                    <animation duration="1.5">
                        <part node="gate4mOpenALock">
                            <keyFrame time="0.0" translation="0.12 1.049 1.963"/>
                            <keyFrame time="0.05" translation="0.12 1.049 1.812"/>
                        </part>
                        <part node="gate4mOpenA">
                            <keyFrame time="0.05" rotation="0 0 0"/>
                            <keyFrame time="1.0" rotation="0 -90 0"/>
                        </part>
                        <part node="gate4mOpenB">
                            <keyFrame time="0.05" rotation="0 0 0"/>
                            <keyFrame time="1.0" rotation="0 90 0"/>
                        </part>
                    </animation>
                    <controls triggerNode="gate4mTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
                    <sounds>
                        <moving linkNode="gate4mSoundNode" template="fenceLoop" />
                        <posEnd linkNode="gate4mSoundNode" template="fenceOpen" />
                        <negEnd linkNode="gate4mSoundNode" template="fenceClose" />
                    </sounds>
                </animatedObject>
            </gate>
        </segment>
        <segment id="GATE6m" class="FenceGate" maxVerticalAngle="45">
            <gate node="gate6m" length="6">
                <animatedObject saveId="animalPigFence_gate6m" useAIBlockingRegion="true" >
                    <animation duration="1.5">
                        <part node="gate6mOpenALock">
                            <keyFrame time="0.0" translation="0.12 1.049 2.778"/>
                            <keyFrame time="0.05" translation="0.12 1.049 2.645"/>
                        </part>
                        <part node="gate6mOpenA">
                            <keyFrame time="0.05" rotation="0 0 0"/>
                            <keyFrame time="1.0" rotation="0 -90 0"/>
                        </part>
                        <part node="gate6mOpenB">
                            <keyFrame time="0.05" rotation="0 0 0"/>
                            <keyFrame time="1.0" rotation="0 90 0"/>
                        </part>
                    </animation>
                    <controls triggerNode="gate6mTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
                    <sounds>
                        <moving linkNode="gate6mSoundNode" template="fenceLoop" />
                        <posEnd linkNode="gate6mSoundNode" template="fenceOpen" />
                        <negEnd linkNode="gate6mSoundNode" template="fenceClose" />
                    </sounds>
                </animatedObject>
            </gate>
        </segment>
    </fence>

    <i3dMappings>
        <i3dMapping id="gate2m" node="0>0" />
        <i3dMapping id="gate2mOpenA" node="0>0|2" />
        <i3dMapping id="gate2mOpenALock" node="0>0|2|0|0|0" />
        <i3dMapping id="gate2mTrigger" node="0>0|3" />
        <i3dMapping id="gate2mSoundNode" node="0>0|4" />
        <i3dMapping id="gate4m" node="0>1" />
        <i3dMapping id="gate4mOpenA" node="0>1|2" />
        <i3dMapping id="gate4mOpenALock" node="0>1|2|0|0|0" />
        <i3dMapping id="gate4mOpenB" node="0>1|3" />
        <i3dMapping id="gate4mTrigger" node="0>1|4" />
        <i3dMapping id="gate4mSoundNode" node="0>1|5" />
        <i3dMapping id="gate6m" node="0>2" />
        <i3dMapping id="gate6mOpenA" node="0>2|2" />
        <i3dMapping id="gate6mOpenALock" node="0>2|2|0|0|0" />
        <i3dMapping id="gate6mOpenB" node="0>2|3" />
        <i3dMapping id="gate6mTrigger" node="0>2|4" />
        <i3dMapping id="gate6mSoundNode" node="0>2|5" />
        <i3dMapping id="pole01" node="1>0" />
        <i3dMapping id="pole02" node="1>1" />
        <i3dMapping id="pole03" node="1>2" />
        <i3dMapping id="pole04" node="1>3" />
        <i3dMapping id="panel01" node="2>0" />
        <i3dMapping id="panel02" node="2>1" />
        <i3dMapping id="panel03" node="2>2" />
        <i3dMapping id="panel04" node="2>3" />
    </i3dMappings>
</placeable>
