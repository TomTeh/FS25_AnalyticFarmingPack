<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="pallet" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://validation.gdn.giants-software.com/xml/fs25/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>$l10n_storeItem_armoirePallet</name>
        <image>objects/pallets/armoirePallet/store_armoirePallet.png</image>
        <price>2200</price>
        <category>pallets</category>
        <brand>NONE</brand>
        <showInStore>false</showInStore>
        <canBeSold>false</canBeSold>
        <financeCategory>OTHER</financeCategory>

        <storeIconRendering>
            <settings centerIcon="true" cameraXRot="-15" cameraYRot="35"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>26112</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>6144</indexBufferMemoryUsage>
        <textureMemoryUsage>720896</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_pallet</typeDesc>
        <filename>objects/pallets/armoirePallet/armoirePallet.i3d</filename>
        <size width="2.54" length="1.76" height="2.6" />
        <canBeReset>false</canBeReset>
        <components maxMass="600">
            <component centerOfMass="0 0.2 0" solverIterationCount="10" mass="600"/>
        </components>
        <showInVehicleMenu>false</showInVehicleMenu>
        <mapHotspot available="false" />
        <input allowed="false"/>
    </base>

    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration>
                <fillUnits removeVehicleIfEmpty="true">
                    <fillUnit unitTextOverride="$l10n_unit_pieces" fillTypes="ARMOIRE" capacity="1000" ignoreFillLimit="true"/>
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>

    <pallet fillUnitIndex="1" linkNode="palletLinkNode01 palletLinkNode02 palletLinkNode03 palletLinkNode04">
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletNew_diffuse.dds"/>
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletMiddle_diffuse.dds"/>
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletOld_diffuse.dds"/>

        <content>
            <object node="armoire01" tensionBeltNode="armoire01Tension"/>
            <object node="armoire02" tensionBeltNode="armoire02Tension"/>
        </content>

        <sounds>
            <unload template="palletsFillWood" pitchScale="0.7" volumeScale="2.5" supportsReverb="false"/>
        </sounds>
    </pallet>

    <dynamicMount triggerNode="dynamicMountTrigger" triggerForceAcceleration="4" additionalMountDistance="2.44" jointTransY="0.107" jointLimitToRotY="true"/>

    <i3dMappings>
        <i3dMapping id="dynamicMountTrigger" node="0>0" />
        <i3dMapping id="armoire01" node="0>1|0" />
        <i3dMapping id="armoire01Tension" node="0>1|0|0" />
        <i3dMapping id="armoire02" node="0>1|1" />
        <i3dMapping id="armoire02Tension" node="0>1|1|0" />
        <i3dMapping id="straps" node="0>1|2" />
        <i3dMapping id="palletLinkNode01" node="0>2" />
        <i3dMapping id="palletLinkNode02" node="0>3" />
        <i3dMapping id="palletLinkNode03" node="0>4" />
        <i3dMapping id="palletLinkNode04" node="0>5" />
    </i3dMappings>
</vehicle>
