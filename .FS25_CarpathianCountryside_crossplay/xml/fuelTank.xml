<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="silo" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_fuelTank</name>
        <image>placeables/fuelTank/store_fuelTank.png</image>
        <functions>
            <function>$l10n_function_dieselTank</function>
        </functions>
        <price>20000</price>
        <dailyUpkeep>60</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDENERGY</brand>
        <species>placeable</species>
        <category>dieselTanks</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>containers</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-10" cameraYRot="-130" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>156416</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>34304</indexBufferMemoryUsage>
        <textureMemoryUsage>3014656</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/fuelTank/fuelTank.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>

        <sounds>
            <place template="siloImp" pitchScale="1.4"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart1" widthNode="clearAreaWidth1" heightNode="clearAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart1" widthNode="levelAreaWidth1" heightNode="levelAreaHeight1" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="loadingMarker"       filename="placeables/sharedAssets/marker/markerIconFuel.i3d" adjustToGround="true" />
        <triggerMarker node="refillTriggerMarker" filename="placeables/sharedAssets/marker/markerIconBuyConsumable.i3d" adjustToGround="true" />
    </triggerMarkers>

    <lights>
        <group weatherRequiredFlags="NIGHT" />

        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight" groupIndex="1"/>

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
            </high>
        </realLights>
    </lights>

    <hotspots>
        <hotspot type="FUEL" linkNode="hotspotNode" teleportNode="refillTriggerMarker" />
    </hotspots>

    <infoTrigger triggerNode="infoTrigger"/>

    <silo playerActionTrigger="refillPlayerTrigger" sellWarningText="$l10n_info_tankNotEmpty">
        <loadingStation node="loadingTrigger" supportsExtension="false">
            <loadTrigger triggerNode="loadingTrigger" fillTypes="DIESEL" fillLitersPerSecond="20" dischargeNode="dischargeNode" startFillText="$l10n_action_refuel" stopFillText="$l10n_action_stopRefuel"/>
        </loadingStation>

        <unloadingStation supportsExtension="false">
            <unloadTrigger exactFillRootNode="exactFillRootNode" fillTypes="DIESEL"/>
        </unloadingStation>

        <storages>
            <storage node="storageNode" fillTypes="DIESEL" capacity="35000" isExtension="false">
                <startFillLevel fillType="DIESEL" fillLevel="0" />
            </storage>
        </storages>
    </silo>

    <i3dMappings>
        <i3dMapping id="propsBordersNode" node="0>1|0" />
        <i3dMapping id="propsPreplacedNode" node="0>1|1" />
        <i3dMapping id="industrialWallLight" node="0>2|0|0" />
        <i3dMapping id="realLightsLow" node="0>2|1|0" />
        <i3dMapping id="realLightsHigh" node="0>2|1|1" />
        <i3dMapping id="storageNode" node="0>3|0" />
        <i3dMapping id="hotspotNode" node="0>3|1" />
        <i3dMapping id="exactFillRootNode" node="0>3|2|0" />
        <i3dMapping id="loadingTrigger" node="0>3|3|0" />
        <i3dMapping id="dischargeNode" node="0>3|3|1" />
        <i3dMapping id="loadingMarker" node="0>3|3|2" />
        <i3dMapping id="infoTrigger" node="0>3|4" />
        <i3dMapping id="aiNode" node="0>3|5" />
        <i3dMapping id="refillPlayerTrigger" node="0>3|6" />
        <i3dMapping id="refillTriggerMarker" node="0>3|6|0" />
        <i3dMapping id="clearAreaStart1" node="0>4|0" />
        <i3dMapping id="clearAreaWidth1" node="0>4|0|0" />
        <i3dMapping id="clearAreaHeight1" node="0>4|0|1" />
        <i3dMapping id="levelAreaStart1" node="0>5|0" />
        <i3dMapping id="levelAreaWidth1" node="0>5|0|0" />
        <i3dMapping id="levelAreaHeight1" node="0>5|0|1" />
        <i3dMapping id="indoorAreaStart1" node="0>6|0" />
        <i3dMapping id="indoorAreaWidth1" node="0>6|0|0" />
        <i3dMapping id="indoorAreaHeight1" node="0>6|0|1" />
        <i3dMapping id="tipOcclusionUpdateAreaStart1" node="0>7|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd1" node="0>7|0|0" />
        <i3dMapping id="testAreaStart1" node="0>8|0" />
        <i3dMapping id="testAreaEnd1" node="0>8|0|0" />
    </i3dMappings>
</placeable>
