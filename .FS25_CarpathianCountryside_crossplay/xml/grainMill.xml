<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_grainMill</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/mapIcon_grainMill.png</image>
        <price>255000</price>
        <dailyUpkeep>80</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>2816</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>1536</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/grainMill.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <buysFarmland>true</buysFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
        </updateAreas>
    </ai>

    <infoTrigger triggerNode="infoTrigger" />

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart filename="placeables/sharedAssets/grainPit.i3d" node="1" linkNode="grainPitLinkNode" />
    </dynamicallyLoadedParts>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="false" />
    </triggerMarkers>

    <productionPoint>
        <productions sharedThroughputCapacity="false">
            <production id="flourWheat" name="%s %s" params="$l10n_fillType_wheat|$l10n_fillType_flour" cyclesPerHour="158" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="WHEAT" amount="5" />
                </inputs>
                <outputs>
                    <output fillType="FLOUR" amount="4" />
                </outputs>
            </production>
            <production id="flourBarley" name="%s %s" params="$l10n_fillType_barley|$l10n_fillType_flour" cyclesPerHour="30" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="BARLEY" amount="30" />
                </inputs>
                <outputs>
                    <output fillType="FLOUR" amount="22" />
                </outputs>
            </production>
            <production id="flourRye" name="%s %s" params="$l10n_fillType_rye|$l10n_fillType_flour" cyclesPerHour="30" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="RYE" amount="28" />
                </inputs>
                <outputs>
                    <output fillType="FLOUR" amount="20" />
                </outputs>
            </production>
            <production id="flourOat" name="%s %s" params="$l10n_fillType_oat|$l10n_fillType_flour" cyclesPerHour="75" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="OAT" amount="15" />
                </inputs>
                <outputs>
                    <output fillType="FLOUR" amount="15" />
                </outputs>
            </production>
            <production id="flourSorghum" name="%s %s" params="$l10n_fillType_sorghum|$l10n_fillType_flour" cyclesPerHour="75" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="SORGHUM" amount="15" />
                </inputs>
                <outputs>
                    <output fillType="FLOUR" amount="13" />
                </outputs>
            </production>
            <production id="flourRiceLongGrain" name="%s (%s)" params="$l10n_fillType_riceFlour|$l10n_fillType_riceLongGrain" cyclesPerHour="45" costsPerActiveHour="3">
                <inputs>
                    <input fillType="RICELONGGRAIN" amount="15" />
                </inputs>
                <outputs>
                    <output fillType="RICEFLOUR" amount="13" />
                </outputs>
            </production>
            <production id="flourRice" name="%s (%s)" params="$l10n_fillType_riceFlour|$l10n_fillType_rice" cyclesPerHour="45" costsPerActiveHour="1.5">
                <inputs>
                    <input fillType="RICE" amount="9" />
                </inputs>
                <outputs>
                    <output fillType="RICEFLOUR" amount="15" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="false" litersForFullPriceDrop="200000" fullPriceRecoverHours="48">
            <unloadTrigger exactFillRootNode="unloadTrigger" fillTypes="WHEAT BARLEY RYE OAT SORGHUM RICELONGGRAIN RICE"/>
            <palletTrigger triggerNode="palletTrigger" fillTypes="WHEAT BARLEY RYE OAT SORGHUM RICELONGGRAIN RICE" />
            <unloadTrigger exactFillRootNode="unloadTriggerAI" aiNode="unloadTriggerAINode" fillTypes="WHEAT BARLEY RYE OAT SORGHUM RICELONGGRAIN RICE" />
        </sellingStation>

        <palletSpawner node="palletSpawner">
            <spawnPlaces>
                <spawnPlace startNode="spawnSpace1start" endNode="spawnSpace1end" />
                <spawnPlace startNode="spawnSpace2start" endNode="spawnSpace2end" />
            </spawnPlaces>
        </palletSpawner>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="WHEAT"         capacity="200000" />
            <capacity fillType="BARLEY"        capacity="200000" />
            <capacity fillType="RYE"        capacity="200000" />
            <capacity fillType="OAT"           capacity="200000" />
            <capacity fillType="SORGHUM"       capacity="200000" />
            <capacity fillType="RICELONGGRAIN" capacity="200000" />
            <capacity fillType="RICE"          capacity="100000" />
            <capacity fillType="FLOUR"         capacity="150000" />
            <capacity fillType="RICEFLOUR"     capacity="150000" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <effectNodes>
            <effectNode effectClass="ParticleEffect" effectNode="smokeChimenyEffectShape01" particleType="SMOKE_CHIMNEY" emitCountScale="75"/>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape01" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="40"/>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape02" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="40"/>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape03" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="40"/>
        </effectNodes>

        <sounds>
            <idle template="grainMillIdle" linkNode="soundNode" />
            <active template="grainMillWork" linkNode="soundNode" />
        </sounds>
    </productionPoint>

    <i3dMappings>
        <i3dMapping id="sellingStation" node="0>0" />
        <i3dMapping id="unloadTrigger" node="0>0|0" />
        <i3dMapping id="palletTrigger" node="0>0|1" />
        <i3dMapping id="unloadTriggerMarker" node="0>0|2" />
        <i3dMapping id="grainPitLinkNode" node="0>0|3" />
        <i3dMapping id="unloadTriggerAI" node="0>0|4" />
        <i3dMapping id="unloadTriggerAINode" node="0>0|5" />
        <i3dMapping id="playerTrigger" node="0>1|0" />
        <i3dMapping id="playerTriggerMarker" node="0>1|0|0" />
        <i3dMapping id="soundNode" node="0>1|1" />
        <i3dMapping id="smokeChimenyEffectShape01" node="0>1|2|0" />
        <i3dMapping id="smokeEffectShape01" node="0>1|2|1" />
        <i3dMapping id="smokeEffectShape02" node="0>1|2|2" />
        <i3dMapping id="smokeEffectShape03" node="0>1|2|3" />
        <i3dMapping id="palletSpawner" node="0>2" />
        <i3dMapping id="spawnSpace1start" node="0>2|0" />
        <i3dMapping id="spawnSpace1end" node="0>2|0|0" />
        <i3dMapping id="spawnSpace2start" node="0>2|1" />
        <i3dMapping id="spawnSpace2end" node="0>2|1|0" />
        <i3dMapping id="infoTrigger" node="0>3" />
        <i3dMapping id="hotspotNode" node="0>4" />
        <i3dMapping id="teleportNode" node="0>5" />
    </i3dMappings>
</placeable>
