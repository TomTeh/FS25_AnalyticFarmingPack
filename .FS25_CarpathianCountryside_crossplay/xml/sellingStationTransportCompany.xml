<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="warehouse" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_transportCompany</name>
        <image>placeables/sellingStations/mapIcon_sellingStationTransportCompany.png</image>
        <price>1</price>
        <dailyUpkeep>0</dailyUpkeep>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>sellingPoints</category>
        <vertexBufferMemoryUsage>16128</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>1792</indexBufferMemoryUsage>
        <textureMemoryUsage>131072</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/sellingStations/sellingStationTransportCompany.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <ai>
        <updateAreas/>
        <splines>
            <spline node="aiSpline" />
        </splines>
    </ai>

    <triggerMarkers>
        <triggerMarker node="unloadTriggerMarkerGrain1" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="false" />
        <triggerMarker node="unloadTriggerMarkerGrain2" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="false" />
        <triggerMarker node="unloadTriggerMarkerRootCrops1" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarkerRootCrops2" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarkerProducts" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="palletBuyingActivationTriggerMarker" filename="$data/shared/assets/marker/markerIconShopping.i3d" adjustToGround="true"/>
    </triggerMarkers>

    <hotspots>
        <hotspot type="UNLOADING" linkNode="hotspotNode" teleportNode="teleportNode" />
        <hotspot type="SHOP" linkNode="palletBuyingActivationTriggerMarker" teleportNode="palletBuyingActivationTriggerMarker" />
    </hotspots>

    <sellingStation node="0" appearsOnStats="true" supportsExtension="false" litersForFullPriceDrop="300000" fullPriceRecoverHours="48">
        <unloadTrigger exactFillRootNode="unloadTriggerGrain" priceScale="1" fillTypeCategories="SELLINGSTATION_TRANSPORTCOMPANY_GRAIN" />
        <palletTrigger triggerNode="palletTriggerGrain" priceScale="1" fillTypeCategories="SELLINGSTATION_TRANSPORTCOMPANY_GRAIN" />

        <unloadTrigger exactFillRootNode="unloadTriggerRootCrops" aiNode="unloadTriggerAINodeRootCrops" priceScale="1" fillTypeCategories="ROOT_CROPS VEGETABLES SELLINGSTATION_TRANSPORTCOMPANY_GENERAL SELLINGSTATION_FIELDFRUITS SELLINGSTATION_TRANSPORTCOMPANY_GRAIN PRODUCT SELLINGSTATION_PRODUCTS SELLINGSTATION_PRODUCTSFOOD SELLINGSTATION_TRANSPORTCOMPANY_PALLET" />
        <palletTrigger triggerNode="palletTriggerRootCrops" aiNode="unloadTriggerAINodeRootCrops" priceScale="1" fillTypeCategories="ROOT_CROPS VEGETABLES SELLINGSTATION_TRANSPORTCOMPANY_GENERAL SELLINGSTATION_FIELDFRUITS SELLINGSTATION_TRANSPORTCOMPANY_GRAIN PRODUCT SELLINGSTATION_PRODUCTS SELLINGSTATION_PRODUCTSFOOD SELLINGSTATION_TRANSPORTCOMPANY_PALLET" />
        <baleTrigger triggerNode="baleTriggerRootCrops" deleteLitersPerSecond="10000" aiNode="unloadTriggerAINodeRootCrops" priceScale="1" fillTypeCategories="ROOT_CROPS VEGETABLES SELLINGSTATION_TRANSPORTCOMPANY_GENERAL SELLINGSTATION_FIELDFRUITS SELLINGSTATION_TRANSPORTCOMPANY_GRAIN PRODUCT SELLINGSTATION_PRODUCTS SELLINGSTATION_PRODUCTSFOOD SELLINGSTATION_TRANSPORTCOMPANY_PALLET" />

        <unloadTrigger exactFillRootNode="unloadTriggerProducts" priceScale="1" fillTypeCategories="PRODUCT SELLINGSTATION_PRODUCTS SELLINGSTATION_PRODUCTSFOOD SELLINGSTATION_TRANSPORTCOMPANY_PALLET" />
        <palletTrigger triggerNode="palletTriggerProducts" priceScale="1" fillTypeCategories="PRODUCT SELLINGSTATION_PRODUCTS SELLINGSTATION_PRODUCTSFOOD SELLINGSTATION_TRANSPORTCOMPANY_PALLET" />

        <fillType name="SEEDS" priceScale="0.6" supportsGreatDemand="true" disablePriceDrop="false" />
    </sellingStation>

    <palletBuyingStation triggerNode="palletBuyingActivationTrigger">
        <fillType name="BOARDS"               priceScale="1.3" />
        <fillType name="PLANKS"               priceScale="1.3" />
