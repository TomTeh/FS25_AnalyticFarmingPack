<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_sugarMill</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/mapIcon_sugarMill.png</image>
        <price>280000</price>
        <dailyUpkeep>90</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>45824</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>18688</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/sugarMill.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <buysFarmland>true</buysFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
        </updateAreas>
    </ai>

    <infoTrigger triggerNode="infoTrigger" />

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="false" />
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="markerLoadingSilo"   filename="$data/shared/assets/marker/markerIconLoad.i3d" adjustToGround="true" />
    </triggerMarkers>

    <productionPoint>
        <productions sharedThroughputCapacity="true">
            <production id="sugarbeet_sugar" name="%s (%s)" params="$l10n_fillType_sugar|$l10n_fillType_sugarBeet" cyclesPerHour="750" costsPerActiveHour="7">
                <inputs>
                    <input fillType="SUGARBEET" amount="2" />
                </inputs>
                <outputs>
                    <output fillType="SUGAR" amount="1.1" />
                    <output fillType="SUGARBEET_CUT" amount="0.4" />
                </outputs>
            </production>
            <production id="sugarcane_sugar" name="%s (%s)" params="$l10n_fillType_sugar|$l10n_fillType_sugarCane" cyclesPerHour="750" costsPerActiveHour="7">
                <inputs>
                    <input fillType="SUGARCANE" amount="2" />
                </inputs>
                <outputs>
                    <output fillType="SUGAR" amount="1" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="false" litersForFullPriceDrop="300000" fullPriceRecoverHours="48">
            <unloadTrigger exactFillRootNode="unloadTrigger" fillTypes="SUGARBEET SUGARCANE" />
            <palletTrigger triggerNode="palletTrigger" fillTypes="SUGARBEET SUGARCANE"/>
            <unloadTrigger exactFillRootNode="unloadTriggerAI" aiNode="unloadTriggerAINode" fillTypes="SUGARBEET SUGARCANE" />
        </sellingStation>

        <loadingStation>
            <loadTrigger triggerNode="loadingTrigger" fillLitersPerSecond="1000" dischargeNode="dischargeNode" fillTypes="SUGARBEET_CUT" >
                <effectNode effectClass="PipeEffect" effectNode="pipeEffect"      materialType="pipe"           fadeTime="0.5" maxBending="0" controlPoint="4.0 0 0 0" />
                <effectNode                          effectNode="pipeEffectSmoke" materialType="unloadingSmoke" fadeTime="0.5" />
            </loadTrigger>
        </loadingStation>

        <palletSpawner node="palletSpawner">
            <spawnPlaces>
                <spawnPlace startNode="spawnSpace1start" endNode="spawnSpace1end" />
                <spawnPlace startNode="spawnSpace2start" endNode="spawnSpace2end" />
            </spawnPlaces>
        </palletSpawner>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="SUGARBEET"      capacity="400000" />
            <capacity fillType="SUGARCANE"      capacity="400000" />
            <capacity fillType="SUGAR"          capacity="100000" />
            <capacity fillType="SUGARBEET_CUT"  capacity="100000" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <effectNodes>
            <effectNode effectClass="ParticleEffect" effectNode="smokeChimenyEffectShape01" particleType="SMOKE_CHIMNEY" emitCountScale="75"/>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape01" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="30"/>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape02" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="30"/>
        </effectNodes>

        <sounds>
            <idle template="sugarMillIdle" linkNode="soundNode" />
            <active template="sugarMillWork" linkNode="soundNode" />
        </sounds>
    </productionPoint>

    <i3dMappings>
        <i3dMapping id="sellingStation" node="0>0" />
        <i3dMapping id="unloadTrigger" node="0>0|0" />
        <i3dMapping id="palletTrigger" node="0>0|1" />
        <i3dMapping id="unloadTriggerMarker" node="0>0|2" />
        <i3dMapping id="unloadTriggerAI" node="0>0|3" />
        <i3dMapping id="unloadTriggerAINode" node="0>0|4" />
        <i3dMapping id="loadingTrigger" node="0>1|0" />
        <i3dMapping id="dischargeNode" node="0>1|1" />
        <i3dMapping id="pipeEffect" node="0>1|2|0" />
        <i3dMapping id="pipeEffectSmoke" node="0>1|2|1" />
        <i3dMapping id="markerLoadingSilo" node="0>1|3" />
        <i3dMapping id="playerTrigger" node="0>2|0" />
        <i3dMapping id="playerTriggerMarker" node="0>2|0|0" />
        <i3dMapping id="soundNode" node="0>2|1" />
        <i3dMapping id="smokeChimenyEffectShape01" node="0>2|2|0" />
        <i3dMapping id="smokeEffectShape01" node="0>2|2|1" />
        <i3dMapping id="smokeEffectShape02" node="0>2|2|2" />
        <i3dMapping id="palletSpawner" node="0>3" />
        <i3dMapping id="spawnSpace1start" node="0>3|0" />
        <i3dMapping id="spawnSpace1end" node="0>3|0|0" />
        <i3dMapping id="spawnSpace2start" node="0>3|1" />
        <i3dMapping id="spawnSpace2end" node="0>3|1|0" />
        <i3dMapping id="infoTrigger" node="0>4" />
        <i3dMapping id="hotspotNode" node="0>5" />
        <i3dMapping id="teleportNode" node="0>6" />
    </i3dMappings>
</placeable>
