<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<feedingRobot xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/feedingRobot.xsd">
    <filename>$data/placeables/lely/vectorGarage/lelyVectorGarage.i3d</filename>

    <robot node="vectorRobot" triggerNode="vectorTrigger" maxSpeed="5" acceleration="1" deceleration="2">
        <door node="robotDoor" duration="2" maxY="0.75" />
        <mixer recipe="forage">
            <animationNodes>
                <animationNode node="mixer" rotSpeed="-180" rotAxis="2" />
            </animationNodes>
        </mixer>
        <fillPlane node="fillVolume" capacity="18000" />
        <dischargeEffects>
            <effectNode effectNode="dischargeEffect" materialType="unloading" materialTypeId="1" defaultFillType="silage" delay="0" fadeInTime="0.5" fadeOutTime="0.1" extraDistance="0"/>
        </dischargeEffects>
        <sounds>
            <driving template="feedingRobotLoop" linkNode="vectorRobot" />
            <discharging template="manureFill" volumeScale="1.75" linkNode="vectorRobot" />
        </sounds>
    </robot>

    <playerTrigger node="playerDetectionTrigger" />

    <unloadingSpots>
        <unloadingSpot capacity="432000" fillTypes="SILAGE" markerNode="marker3">
            <unloadTrigger exactFillRootNode="exactFillRootNodeSilage"/>
            <baleTrigger triggerNode="baleTriggerSilage" />
            <fillPlane node="fillPlaneSilage" minY="-1.2" maxY="0" />
        </unloadingSpot>
        <unloadingSpot capacity="183000" fillTypes="STRAW" markerNode="marker2">
            <unloadTrigger exactFillRootNode="exactFillRootNodeStraw" />
            <baleTrigger triggerNode="baleTriggerStraw"/>
            <fillPlane node="fillPlaneStraw" minY="-1.2" maxY="0" />
        </unloadingSpot>
        <unloadingSpot capacity="183000" fillTypes="DRYGRASS_WINDROW" markerNode="marker1">
            <unloadTrigger exactFillRootNode="exactFillRootNodeHay" />
            <baleTrigger triggerNode="baleTriggerHay"/>
            <fillPlane node="fillPlaneHay" minY="-1.2" maxY="0" />
        </unloadingSpot>
        <unloadingSpot capacity="50000" fillTypes="MINERAL_FEED" markerNode="marker4">
            <unloadTrigger exactFillRootNode="exactFillRootNodeMineralFeed" />
            <palletTrigger triggerNode="palletTriggerMineralFeed"/>
        </unloadingSpot>
    </unloadingSpots>

    <stateMachine>
        <states>
            <state name="LOADING" class="FeedingRobotStateLoading"/>
            <state name="PAUSED" class="FeedingRobotStatePaused" >
                <objectChange node="fabric" visibilityActive="false" />
                <objectChange node="fabricCollision" rigidBodyTypeActive="NONE" />
            </state>
            <state name="FILLING" class="FeedingRobotStateFilling" deltaFillLevel="18000">
                <objectChange node="fabric" visibilityActive="true" />
                <objectChange node="fabricCollision" rigidBodyTypeActive="STATIC" />
                <animatedObject index="2" direction="1" time="1" reset="true"/>
            </state>
            <state name="STARTING" class="FeedingRobotStateStarting" >
                <animatedObject index="1" direction="1" time="1" />
                <objectChange node="fabric" visibilityActive="false" />
                <objectChange node="fabricCollision" rigidBodyTypeActive="NONE" />
            </state>
            <state name="DRIVING" class="FeedingRobotStateDriving" resetRobotOnDeactivate="false" />
            <state name="FINISHED" class="FeedingRobotStateFinished">
                <animatedObject index="1" direction="-1" time="0" />
            </state>
        </states>
        <transitions>
            <transition from="LOADING" to="PAUSED" />
            <transition from="PAUSED" to="FILLING" />
            <transition from="FILLING" to="STARTING" />
            <transition from="STARTING" to="DRIVING" />
            <transition from="DRIVING" to="FINISHED" />
            <transition from="FINISHED" to="PAUSED" />
        </transitions>
    </stateMachine>

    <animatedObjects>
        <animatedObject>
            <animation>
                <part node="door">
                    <keyFrame time="0"  translation="0 0 0"/>
                    <keyFrame time="0.4"  translation="0 0 0"/>
                    <keyFrame time="2.4"  translation="0 2.7 0"/>
                    <keyFrame time="2.8"  translation="0 2.7 0"/>
                </part>
                <shader node="door" parameterName="visibilityCutThreshold">
                    <keyFrame time="0"   values="0 - - -" />
                    <keyFrame time="0.4" values="0 - - -" />
                    <keyFrame time="2.4" values="1 - - -" />
                    <keyFrame time="2.8" values="1 - - -" />
                </shader>
            </animation>
            <sounds>
                <moving linkNode="door" template="rollingGarageDoor" />
                <posEnd linkNode="door" template="slidingGateMetalOpen" />
                <negEnd linkNode="door" template="slidingGateMetalClose" />
            </sounds>
        </animatedObject>
        <animatedObject>
            <animation>
                <part node="crane">
                    <keyFrame time="0.0"  translation="0 0 0" />
                    <keyFrame time="3.0"  translation="0 0 3" />
                    <!-- 4s shovel -->
                    <keyFrame time="7.0"  translation="0 0 3" />
                    <keyFrame time="11.0" translation="0 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="15.0" translation="0 0 0" />
                    <keyFrame time="22.5" translation="0 0 3" />
                    <!-- 4s shovel -->
                    <keyFrame time="26.5" translation="0 0 3" />
                    <keyFrame time="34.0" translation="0 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="38.0" translation="0 0 0" />
                    <keyFrame time="48.0" translation="0 0 3" />
                    <!-- 4s shovel -->
                    <keyFrame time="52.0" translation="0 0 3" />
                    <keyFrame time="62.0" translation="0 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="68.0" translation="0 0 0" />
                </part>
                <part node="craneMotor">
                    <keyFrame time="0.0"  translation="0 0 0" />
                    <keyFrame time="3.0"  translation="6 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="7.0"  translation="6 0 0" />
                    <keyFrame time="11.0" translation="0 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="15.0" translation="0 0 0" />
                    <keyFrame time="22.5" translation="15 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="26.5" translation="15 0 0" />
                    <keyFrame time="34.0" translation="0 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="38.0" translation="0 0 0" />
                    <keyFrame time="48.0" translation="20 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="52.0" translation="20 0 0" />
                    <keyFrame time="62.0" translation="0 0 0" />
                    <!-- 4s shovel -->
                    <keyFrame time="68.0" translation="0 0 0" />
                </part>
                <part node="shovel">
                    <keyFrame time="0"   translation="0 0 0" />
                    <!-- 3s movement -->
                    <keyFrame time="3.2" translation="0 0 0" />
                    <keyFrame time="4.8" translation="0 -2.282 0" />
                    <keyFrame time="5.2" translation="0 -2.282 0" />
                    <keyFrame time="6.8" translation="0 0 0" />
                    <!-- 3s movement -->
                    <keyFrame time="11.2" translation="0 0 0" />
                    <keyFrame time="12.5" translation="0 -0.6 0" />
                    <keyFrame time="13.5" translation="0 -0.6 0" />
                    <keyFrame time="14.8" translation="0 0 0" />

                    <!-- 7.5s movement -->
                    <keyFrame time="22.7" translation="0 0 0" />
                    <keyFrame time="24.3" translation="0 -2.282 0" />
                    <keyFrame time="24.7" translation="0 -2.282 0" />
                    <keyFrame time="26.3" translation="0 0 0" />
                    <!-- 7.5s movement -->
                    <keyFrame time="34.2" translation="0 0 0" />
                    <keyFrame time="35.5" translation="0 -0.6 0" />
                    <keyFrame time="36.5" translation="0 -0.6 0" />
                    <keyFrame time="37.8" translation="0 0 0" />

                    <!-- 10s movement -->
                    <keyFrame time="48.2" translation="0 0 0" />
                    <keyFrame time="49.8" translation="0 -2.282 0" />
                    <keyFrame time="50.2" translation="0 -2.282 0" />
                    <keyFrame time="51.8" translation="0 0 0" />
                    <!-- 10s movement -->
                    <keyFrame time="62.2" translation="0 0 0" />
                    <keyFrame time="63.5" translation="0 -0.6 0" />
                    <keyFrame time="64.5" translation="0 -0.6 0" />
                    <keyFrame time="65.8" translation="0 0 0" />

                    <keyFrame time="68.0" translation="0 0 0" />
                </part>
                <part node="shoveLeft">
                    <keyFrame time="0" rotation="0 0 0" />
                    <!-- fill -->
                    <keyFrame time="3.2" rotation="0 0 0" />
                    <keyFrame time="3.5" rotation="-35 0 0" />
                    <keyFrame time="4.7" rotation="-35 0 0" />
                    <keyFrame time="5.0" rotation="0 0 0" />
                    <!-- empty -->
                    <keyFrame time="12.7" rotation="0 0 0" />
                    <keyFrame time="13.3" rotation="-35 0 0" />
                    <keyFrame time="13.8" rotation="-35 0 0" />
                    <keyFrame time="14.6" rotation="0 0 0" />

                    <!-- fill -->
                    <keyFrame time="22.7" rotation="0 0 0" />
                    <keyFrame time="23.0" rotation="-35 0 0" />
                    <keyFrame time="24.2" rotation="-35 0 0" />
                    <keyFrame time="24.5" rotation="0 0 0" />
                    <!-- empty -->
                    <keyFrame time="35.7" rotation="0 0 0" />
                    <keyFrame time="36.3" rotation="-35 0 0" />
                    <keyFrame time="36.8" rotation="-35 0 0" />
                    <keyFrame time="37.6" rotation="0 0 0" />

                    <!-- fill -->
                    <keyFrame time="48.2" rotation="0 0 0" />
                    <keyFrame time="48.5" rotation="-35 0 0" />
                    <keyFrame time="49.7" rotation="-35 0 0" />
                    <keyFrame time="50.0" rotation="0 0 0" />
                    <!-- empty -->
                    <keyFrame time="63.7" rotation="0 0 0" />
                    <keyFrame time="64.3" rotation="-35 0 0" />
                    <keyFrame time="64.8" rotation="-35 0 0" />
                    <keyFrame time="65.6" rotation="0 0 0" />

                    <keyFrame time="68" rotation="0 0 0" />
                </part>
                <part node="shovelRight">
                    <keyFrame time="0" rotation="0 0 0" />
                    <!-- fill -->
                    <keyFrame time="3.2" rotation="0 0 0" />
                    <keyFrame time="3.5" rotation="35 0 0" />
                    <keyFrame time="4.7" rotation="35 0 0" />
                    <keyFrame time="5.0" rotation="0 0 0" />
                    <!-- empty -->
                    <keyFrame time="12.7" rotation="0 0 0" />
                    <keyFrame time="13.3" rotation="35 0 0" />
                    <keyFrame time="13.8" rotation="35 0 0" />
                    <keyFrame time="14.6" rotation="0 0 0" />

                    <!-- fill -->
                    <keyFrame time="22.7" rotation="0 0 0" />
                    <keyFrame time="23.0" rotation="35 0 0" />
                    <keyFrame time="24.2" rotation="35 0 0" />
                    <keyFrame time="24.5" rotation="0 0 0" />
                    <!-- empty -->
                    <keyFrame time="35.7" rotation="0 0 0" />
                    <keyFrame time="36.3" rotation="35 0 0" />
                    <keyFrame time="36.8" rotation="35 0 0" />
                    <keyFrame time="37.6" rotation="0 0 0" />

                    <!-- fill -->
                    <keyFrame time="48.2" rotation="0 0 0" />
                    <keyFrame time="48.5" rotation="35 0 0" />
                    <keyFrame time="49.7" rotation="35 0 0" />
                    <keyFrame time="50.0" rotation="0 0 0" />
                    <!-- empty -->
                    <keyFrame time="63.7" rotation="0 0 0" />
                    <keyFrame time="64.3" rotation="35 0 0" />
                    <keyFrame time="64.8" rotation="35 0 0" />
                    <keyFrame time="65.6" rotation="0 0 0" />

                    <keyFrame time="68" rotation="0 0 0" />
                </part>
            </animation>
            <sounds >
                <moving linkNode="craneMotor" template="vectorLoop" />
            </sounds>
        </animatedObject>
    </animatedObjects>

    <i3dMappings>
        <i3dMapping id="crane" node="0>0|0" />
        <i3dMapping id="craneMotor" node="0>0|0|0|0" />
        <i3dMapping id="shovel" node="0>0|0|0|0|0|0" />
        <i3dMapping id="shoveLeft" node="0>0|0|0|0|0|0|0" />
        <i3dMapping id="shovelRight" node="0>0|0|0|0|0|0|1" />
        <i3dMapping id="vectorRobot" node="0>1" />
        <i3dMapping id="vectorTrigger" node="0>1|5" />
        <i3dMapping id="mixer" node="0>1|6" />
        <i3dMapping id="robotDoor" node="0>1|7|0" />
        <i3dMapping id="dischargeEffect" node="0>1|8" />
        <i3dMapping id="fillVolume" node="0>1|9" />
        <i3dMapping id="exactFillRootNodeSilage" node="0>2|0|0" />
        <i3dMapping id="baleTriggerSilage" node="0>2|0|1" />
        <i3dMapping id="fillPlaneSilage" node="0>2|0|2" />
        <i3dMapping id="marker3" node="0>2|0|3" />
        <i3dMapping id="iconSilageDecal" node="0>2|0|3|0" />
        <i3dMapping id="exactFillRootNodeStraw" node="0>2|1|0" />
        <i3dMapping id="marker2" node="0>2|1|1" />
        <i3dMapping id="iconStrawDecal" node="0>2|1|1|0" />
        <i3dMapping id="fillPlaneStraw" node="0>2|1|2" />
        <i3dMapping id="baleTriggerStraw" node="0>2|1|3" />
        <i3dMapping id="exactFillRootNodeHay" node="0>2|2|0" />
        <i3dMapping id="marker1" node="0>2|2|1" />
        <i3dMapping id="iconHayDecal" node="0>2|2|1|0" />
        <i3dMapping id="fillPlaneHay" node="0>2|2|2" />
        <i3dMapping id="baleTriggerHay" node="0>2|2|3" />
        <i3dMapping id="exactFillRootNodeMineralFeed" node="0>2|3|0" />
        <i3dMapping id="marker4" node="0>2|3|1" />
        <i3dMapping id="iconMineralFeedDecal" node="0>2|3|1|0" />
        <i3dMapping id="palletTriggerMineralFeed" node="0>2|3|2" />
        <i3dMapping id="warningStripes01" node="0>2|4" />
        <i3dMapping id="door" node="0>3|0" />
        <i3dMapping id="playerDetectionTrigger" node="0>4" />
        <i3dMapping id="fabricCollision" node="0>5" />
