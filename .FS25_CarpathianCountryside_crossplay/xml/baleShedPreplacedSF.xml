<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="mapCC_objectStorage" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_baleShed</name>
        <functions>
            <function>$l10n_function_garage</function>
            <function>$l10n_function_objectStorage</function>
            <function>$l10n_function_roofSolarPanelsOption</function>
        </functions>
        <image>placeables/shed/store_baleShed.dds</image>
        <price>20000</price>
        <dailyUpkeep>10</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDBUILDING</brand>
        <species>placeable</species>
        <category>sheds</category>

        <storeIconRendering>
            <settings cameraXRot="-12" cameraYRot="-40" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>520704</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>82688</indexBufferMemoryUsage>
        <textureMemoryUsage>4587520</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/shed/baleShed.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart1" widthNode="clearAreaWidth1" heightNode="clearAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart1" widthNode="levelAreaWidth1" heightNode="levelAreaHeight1" groundType="concrete"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <lights>
        <group name="$l10n_action_placeableLightShed" triggerNode="controledLightsTrigger">
            <sounds>
                <toggle template="lizardFloodLight" innerRadius="30" outerRadius="50" volumeScale="0.5"/>
            </sounds>
        </group>

        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight01" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight02" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight03" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight04" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight05" groupIndex="1"/>

        <realLights>
            <low>
                <light node="realLightsControledLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsControledHigh" groupIndex="1"/>
            </high>
        </realLights>
    </lights>

    <animatedObjects>
        <animatedObject saveId="baleShed_objectStorageConfig">
            <animation duration="0.2">
                <part node="objectTrigger">
                    <keyFrame time="0" translation="0 0 -2.45" />
                    <keyFrame time="1.0" translation="0 -50 -2.45" />
                </part>
                <part node="playerTrigger">
                    <keyFrame time="0" translation="-21.2 0.5 4.7" />
                    <keyFrame time="1.0" translation="-21.2 -50 4.7" />
                </part>
                <part node="infoTrigger">
                    <keyFrame time="0" translation="0 3 0" />
                    <keyFrame time="1.0" translation="0 -50 0" />
                </part>
                <part node="markers">
                    <keyFrame time="0" visibility="true" />
                    <keyFrame time="1.0" visibility="false" />
                </part>
                <part node="objectStorageCollisions">
                    <keyFrame time="0" translation="0 0 0" />
                    <keyFrame time="1.0" translation="0 -50 0" />
                </part>
            </animation>
            <controls triggerNode="objectStorageConfig_triggerSF" posAction="ACTIVATE_HANDTOOL" posText="action_configureObjectStorageOff" negText="action_configureObjectStorageOn" />
        </animatedObject>
    </animatedObjects>

    <hotspots>
        <hotspot type="UNLOADING" linkNode="hotspotNode" teleportNode="teleportNode"/>
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="warningStripesSF" />
        <triggerMarker node="objectTriggerMarkerSF" filename="placeables/sharedAssets/marker/markerIconStorageIn.i3d" adjustToGround="true" />
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconStorageOut.i3d" adjustToGround="true" />
        <triggerMarker node="objectStorageConfig_markerSF" filename="$data/shared/assets/marker/markerIconWrench.i3d" adjustToGround="true" />
    </triggerMarkers>

    <infoTrigger triggerNode="infoTrigger"/>

    <objectStorage supportsBales="true" supportsPallets="true" capacity="1200" maxUnloadAmount="60" maxLength="8.5" maxWidth="6" maxHeight="6">
        <playerTrigger node="playerTrigger" />
        <objectTrigger node="objectTrigger" />
        <storageAreas>
            <storageArea startNode="storageAreaStart01" endNode="storageAreaEnd01" maxHeight="6"/>
        </storageAreas>
        <spawnAreas>
            <spawnArea startNode="spawnAreaStart01" endNode="spawnAreaEnd01"/>
        </spawnAreas>
    </objectStorage>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch01" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="stopCrossing01" filename="$data/placeables/mapUS/objectStorage/stopCrossing.i3d"/>
