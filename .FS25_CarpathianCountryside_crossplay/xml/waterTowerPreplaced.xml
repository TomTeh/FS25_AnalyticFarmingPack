<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="buyingStation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_waterTower</name>
        <image>placeables/waterTower/store_waterTower.png</image>
        <functions>
            <function>$l10n_function_waterTower</function>
        </functions>
        <price>50000</price>
        <dailyUpkeep>5</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDENERGY</brand>
        <species>placeable</species>
        <category>waterTanks</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>containers</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-10" cameraYRot="0" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>129280</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>26880</indexBufferMemoryUsage>
        <textureMemoryUsage>4456448</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/waterTower/waterTower.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
            <testArea startNode="testAreaStart2" endNode="testAreaEnd2" />
        </testAreas>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart1" widthNode="clearAreaWidth1" heightNode="clearAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart1" widthNode="levelAreaWidth1" heightNode="levelAreaHeight1" groundType="dirt"/>
        </levelAreas>
    </leveling>

    <indoorAreas/>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="loadingMarkerPreplaced" filename="placeables/sharedAssets/marker/markerIconBuyConsumable.i3d" adjustToGround="true" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="LOADING" linkNode="fillTriggerPreplaced" teleportNode="loadingMarkerPreplaced" />
    </hotspots>

    <lights>
        <group weatherRequiredFlags="NIGHT" />

        <lightShape node="beaconGlass" groupIndex="1" />

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1" />
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1" />
            </high>
        </realLights>
    </lights>

    <buyingStation node="fillTriggerPreplaced" supportsExtension="false" >
        <loadTrigger triggerNode="fillTriggerPreplaced" fillTypes="WATER" fillLitersPerSecond="400" autoStart="true" />
        <fillType name="water" priceScale="0.4" statsName="purchaseWater" />
    </buyingStation>

    <deletedNodes>
        <deletedNode node="fillTrigger" />
    </deletedNodes>

    <i3dMappings>
        <i3dMapping id="beaconGlass" node="0>1|1" />
        <i3dMapping id="realLightsLow" node="0>1|2" />
        <i3dMapping id="realLightsHigh" node="0>1|3" />
        <i3dMapping id="water" node="0>2" />
        <i3dMapping id="fillTrigger" node="0>2|0" />
        <i3dMapping id="aiNode" node="0>2|1" />
        <i3dMapping id="loadingMarker" node="0>2|2" />
        <i3dMapping id="fillTriggerPreplaced" node="0>2|3" />
        <i3dMapping id="aiNodePreplaced" node="0>2|4" />
        <i3dMapping id="loadingMarkerPreplaced" node="0>2|5" />
        <i3dMapping id="clearAreaStart1" node="0>3|0" />
        <i3dMapping id="clearAreaWidth1" node="0>3|0|0" />
        <i3dMapping id="clearAreaHeight1" node="0>3|0|1" />
        <i3dMapping id="levelAreaStart1" node="0>4|0" />
        <i3dMapping id="levelAreaWidth1" node="0>4|0|0" />
        <i3dMapping id="levelAreaHeight1" node="0>4|0|1" />
        <i3dMapping id="tipOcclusionUpdateAreaStart1" node="0>5|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd1" node="0>5|0|0" />
        <i3dMapping id="testAreaStart1" node="0>6|0" />
        <i3dMapping id="testAreaEnd1" node="0>6|0|0" />
        <i3dMapping id="testAreaStart2" node="0>6|1" />
        <i3dMapping id="testAreaEnd2" node="0>6|1|0" />
        <i3dMapping id="collisions" node="0>7" />
    </i3dMappings>
</placeable>
