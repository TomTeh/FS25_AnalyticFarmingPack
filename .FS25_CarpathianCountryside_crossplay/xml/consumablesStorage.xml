<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="mapCC_objectStorage" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_consumablesStorage</name>
        <functions>
            <function>$l10n_function_garageBulk</function>
            <function>$l10n_function_garage</function>
            <function>$l10n_function_palletStorage</function>
            <function>$l10n_function_roofSolarPanelsOption</function>
        </functions>
        <image>placeables/shed/store_consumablesStorage.dds</image>
        <price>128000</price>
        <dailyUpkeep>40</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDBUILDING</brand>
        <species>placeable</species>
        <category>sheds</category>

        <storeIconRendering>
            <settings cameraXRot="-10" cameraYRot="40" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>556544</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>111104</indexBufferMemoryUsage>
        <textureMemoryUsage>7733248</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/shed/consumablesStorage.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" placementRotationSnapAngle="90" placementPositionSnapSize="0.5" >
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
        </testAreas>

        <sounds>
            <place template="medImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearArea1Start" widthNode="clearArea1Width" heightNode="clearArea1Height"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelArea1Start" widthNode="levelArea1Width" heightNode="levelArea1Height" groundType="concrete"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorArea1Start" widthNode="indoorArea1Width" heightNode="indoorArea1Height"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateArea1Start" endNode="tipOcclusionUpdateArea1End" />
        </updateAreas>
    </ai>

    <lights>
        <group weatherRequiredFlags="NIGHT" />
        <group name="$l10n_action_placeableLightShed" triggerNode="controledLightsTrigger">
            <sounds>
                <toggle template="lizardFloodLight" innerRadius="40" outerRadius="50" volumeScale="0.2"/>
            </sounds>
        </group>

        <sharedLight filename="placeables/sharedAssets/lights/warehouseHangingLamp.xml" linkNode="warehouseHangingLamp01" groupIndex="2"/>
        <sharedLight filename="placeables/sharedAssets/lights/warehouseHangingLamp.xml" linkNode="warehouseHangingLamp02" groupIndex="2"/>
        <sharedLight filename="placeables/sharedAssets/lights/warehouseHangingLamp.xml" linkNode="warehouseHangingLamp03" groupIndex="2"/>

        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight01" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight02" groupIndex="1"/>

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
                <light node="realLightsControledLow" groupIndex="2"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
                <light node="realLightsControledHigh" groupIndex="2"/>
            </high>
        </realLights>
    </lights>

    <animatedObjects>
        <animatedObject saveId="consumablesBuilding_gate1">
            <animation duration="3">
                <part node="gateRight1">
                    <keyFrame time="0.03" rotation="-90 0 0"/>
                    <keyFrame time="1.0" rotation="-90 160 0"/>
                </part>
                <part node="gateLeft1">
                    <keyFrame time="0.03" rotation="-90 0 0"/>
                    <keyFrame time="1.0" rotation="-90 -160 0"/>
                </part>
                <part node="gateHandle1">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="0.03" rotation="-35 0 0"/>
                    <keyFrame time="0.06" rotation="0 0 0"/>
                </part>
                <part node="occluderMesh_gate1">
                    <keyFrame time="0.0" visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="gate1_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="gate1_sound" template="metalDoorsLoop" volumeScale="0.6" />
                <posEnd linkNode="gate1_sound" template="metalDoorsOpen" volumeScale="0.7" />
                <negEnd linkNode="gate1_sound" template="metalDoorsClose" volumeScale="1" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="consumablesBuilding_gate2">
            <animation duration="3">
                <part node="gateRight2">
                    <keyFrame time="0.03" rotation="-90 0 0"/>
                    <keyFrame time="1.0" rotation="-90 160 0"/>
                </part>
                <part node="gateLeft2">
                    <keyFrame time="0.03" rotation="-90 0 0"/>
                    <keyFrame time="1.0" rotation="-90 -160 0"/>
                </part>
                <part node="gateHandle2">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="0.03" rotation="-35 0 0"/>
                    <keyFrame time="0.06" rotation="0 0 0"/>
                </part>
                <part node="occluderMesh_gate2">
                    <keyFrame time="0.0" visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="gate2_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="gate2_sound" template="metalDoorsLoop" volumeScale="0.6" />
                <posEnd linkNode="gate2_sound" template="metalDoorsOpen" volumeScale="0.7" />
                <negEnd linkNode="gate2_sound" template="metalDoorsClose" volumeScale="1" />
            </sounds>
        </animatedObject>
        <animatedObject saveId="consumablesBuilding_objectStorageConfig">
            <animation duration="0.2">
                <part node="objectTrigger">
                    <keyFrame time="0" translation="9.5 -0.1 13.9" />
                    <keyFrame time="1.0" translation="9.5 -50 13.9" />
                </part>
                <part node="playerTrigger">
                    <keyFrame time="0" translation="6.5 -0.1 7.3" />
                    <keyFrame time="1.0" translation="6.5 -50 7.3" />
                </part>
                <part node="infoTrigger">
                    <keyFrame time="0" translation="3.75 2 7.23" />
                    <keyFrame time="1.0" translation="3.75 -50 7.23" />
                </part>
                <part node="markers">
                    <keyFrame time="0" visibility="true" />
                    <keyFrame time="1.0" visibility="false" />
                </part>
                <part node="objectStorageCollisions">
                    <keyFrame time="0" translation="0 0 0" />
                    <keyFrame time="1.0" translation="0 -50 0" />
                </part>
            </animation>
            <controls triggerNode="objectStorageConfig_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_configureObjectStorageOff" negText="action_configureObjectStorageOn" />
        </animatedObject>
    </animatedObjects>

    <hotspots>
        <hotspot type="UNLOADING" linkNode="hotspotNode" teleportNode="teleportNode"/>
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="warningStripes" />
        <triggerMarker node="objectTriggerMarker" filename="placeables/sharedAssets/marker/markerIconStorageIn.i3d" adjustToGround="true" />
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconStorageOut.i3d" adjustToGround="true" />
        <triggerMarker node="objectStorageConfig_marker" filename="$data/shared/assets/marker/markerIconWrench.i3d" adjustToGround="true" />
    </triggerMarkers>

    <infoTrigger triggerNode="infoTrigger"/>

    <objectStorage supportsBales="false" supportsPallets="true" capacity="200" maxUnloadAmount="30" maxLength="6" maxWidth="4" maxHeight="3.3">
        <playerTrigger node="playerTrigger" />
        <objectTrigger node="objectTrigger" />
        <storageAreas>
            <storageArea startNode="storageAreaStart01" endNode="storageAreaEnd01" maxHeight="3.5"/>
            <storageArea startNode="storageAreaStart02" endNode="storageAreaEnd02" maxHeight="3.5"/>
        </storageAreas>
        <spawnAreas>
            <spawnArea startNode="spawnAreaStart01" endNode="spawnAreaEnd01"/>
        </spawnAreas>
    </objectStorage>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch01" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch02" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch03" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="propsBuildingNode" filename="placeables/sharedAssets/propsBuilding/propsBuilding_farmBuildings.i3d"/>
        <dynamicallyLoadedPart node="0" linkNode="propsDecoNode" filename="placeables/sharedAssets/props/cabinetWorkbecnches.i3d"/>
        <dynamicallyLoadedPart node="0" linkNode="propsDecoNode" filename="placeables/sharedAssets/props/props_consumablesStorage.i3d"/>
        <dynamicallyLoadedPart node="0" linkNode="stopCrossing01" filename="$data/placeables/mapUS/objectStorage/stopCrossing.i3d"/>
        <dynamicallyLoadedPart node="0" linkNode="stopCrossing02" filename="$data/placeables/mapUS/objectStorage/stopCrossing.i3d"/>
    </dynamicallyLoadedParts>

    <deletedNodes>
        <deletedNode node="consumablesStorage_p1_dyeable_LOD0" />
        <deletedNode node="consumablesStorage_p1_dyeable_LOD1" />
    </deletedNodes>

    <solarPanels>
        <solarPanelsConfigurations>
            <solarPanelsConfiguration name="$l10n_ui_none" isActive="false"/>
            <solarPanelsConfiguration name="117 A" isActive="true" price="31005" incomePerHour="105" >
                <objectChange node="solarPanels01" visibilityActive="true"/>
            </solarPanelsConfiguration>
            <solarPanelsConfiguration name="117 B" isActive="true" price="31005" incomePerHour="105" >
                <objectChange node="solarPanels02" visibilityActive="true"/>
            </solarPanelsConfiguration>
            <solarPanelsConfiguration name="234" isActive="true" price="62010" incomePerHour="210" >
                <objectChange node="solarPanels01" visibilityActive="true"/>
                <objectChange node="solarPanels02" visibilityActive="true"/>
            </solarPanelsConfiguration>
        </solarPanelsConfigurations>
    </solarPanels>

