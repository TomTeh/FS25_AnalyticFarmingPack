<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="factory" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_pianoFactory</name>
        <functions>
            <function>$l10n_function_sellingPoint</function>
        </functions>
        <image>placeables/productionPoints/mapIcon_pianoFactory.png</image>
        <price>120000</price>
        <dailyUpkeep>30</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>sellingPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>sellingPoints</tab>
        </brush>
        <vertexBufferMemoryUsage>1536</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>768</indexBufferMemoryUsage>
        <textureMemoryUsage>131072</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/pianoFactory.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <buysFarmland>true</buysFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas></updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="false"/>
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true"/>
    </triggerMarkers>

    <hotspots>
        <hotspot type="UNLOADING_PALLET" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <infoTrigger triggerNode="infoTrigger" showAllPlayers="true" />

    <factory playerTrigger="playerTrigger">
        <item reward="20000" linkNode="pianoLinkNode" filename="$data/placeables/mapEU/pianoFactory/piano/piano.i3d">
            <progressiveVisibilityMesh>
                <mesh node="0>" id="piano" indexMin="0" indexMax="52" />
            </progressiveVisibilityMesh>
        </item>

        <production>
            <input  fillType="BOARDS" amount="5000" usagePerHour="52.1" />
            <output fillType="PIANO" />
        </production>

        <sounds>
            <active linkNode="soundNode" template="pianoFactory" innerRadius="5.00" outerRadius="30.00" fadeOut="0.1" loops="0"/>
        </sounds>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="BOARDS" capacity="20000" />
        </storage>
    </factory>

    <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="false" allowMissions="false" litersForFullPriceDrop="30000" fullPriceRecoverHours="48">
        <palletTrigger triggerNode="palletTrigger" fillTypes="BOARDS"/>

        <fillType name="BOARDS" priceScale="1.03" supportsGreatDemand="true" disablePriceDrop="false" />
    </sellingStation>

    <i3dMappings>
        <i3dMapping id="sellingStation" node="0>0" />
        <i3dMapping id="palletTrigger" node="0>0|0" />
        <i3dMapping id="unloadTriggerMarker" node="0>0|1" />
        <i3dMapping id="playerTrigger" node="0>1|0" />
        <i3dMapping id="playerTriggerMarker" node="0>1|0|0" />
        <i3dMapping id="pianoLinkNode" node="0>1|1" />
        <i3dMapping id="soundNode" node="0>1|2" />
        <i3dMapping id="infoTrigger" node="0>2" />
        <i3dMapping id="hotspotNode" node="0>3" />
        <i3dMapping id="teleportNode" node="0>4" />
    </i3dMappings>
</placeable>
