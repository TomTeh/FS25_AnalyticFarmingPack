            <effectMesh node="0|0|10" numRows="24" rowLength="10" skipPositions="0" boundingBox="5 5 5"/>
            <effectMesh node="0|0|11" numRows="24" rowLength="25" skipPositions="0" boundingBox="5 5 5"/>
        </effectMeshes>

        <effectMaterials rootNode="0|1">
            <effectMaterial node="0|1|0" fillTypes="GRASS_WINDROW" />
            <effectMaterial node="0|1|1" fillTypes="DRYGRASS_WINDROW" />
            <effectMaterial node="0|1|2" fillTypes="ALFALFA_WINDROW" />
            <effectMaterial node="0|1|3" fillTypes="DRYALFALFA_WINDROW" />
        </effectMaterials>

        <customShaderDefaults>
            <customShaderVariation name="alphaMapGradient"/>
            <customShaderParameter name="visibilityX"   value="1.5 -1.5 0.0 0.0"/>
            <customShaderParameter name="sizeScale"     value="1.0 1.0 0.0 0.0"/>
            <customShaderMap name="shapeArray" filename="$data/effects/pickup/sharedPickupArrayIN.dds"/>
            <customShaderMap name="alphaMap"   filename="$data/effects/pickup/shared/gradient_diffuse.png"/>
        </customShaderDefaults>
    </motionPathEffect>

    <motionPathEffect effectClass="TypedMotionPathEffect" effectType="PICKUPOUT" filename="effects/pickup/pickupOUT.i3d">
        <effectGeneration rootNode="0|2"/>
        <typeDefinition fillTypes="GRASS_WINDROW DRYGRASS_WINDROW ALFALFA_WINDROW DRYALFALFA_WINDROW" speedScale="0.65"/>

        <effectMeshes>
            <effectMesh node="0|0|0" numRows="4" rowLength="22" skipPositions="1" boundingBox="3 6 6"/>
        </effectMeshes>

        <effectMaterials rootNode="0|3">
            <effectMaterial node="0|1|0" fillTypes="GRASS_WINDROW" />
            <effectMaterial node="0|1|1" fillTypes="DRYGRASS_WINDROW" />
            <effectMaterial node="0|1|2" fillTypes="ALFALFA_WINDROW" />
            <effectMaterial node="0|1|3" fillTypes="DRYALFALFA_WINDROW" />
        </effectMaterials>

        <customShaderDefaults>
            <customShaderVariation name="rotateByLife_cosOffsetY_alphaMapGradient"/>
            <customShaderParameter name="rotateSpeed"   value="5.0 0 0 0"/>
            <customShaderMap name="shapeArray" filename="$data/effects/pickup/sharedPickupArrayOUT.dds"/>
            <customShaderMap name="alphaMap"   filename="$data/effects/pickup/shared/gradient_diffuse.png"/>
        </customShaderDefaults>
    </motionPathEffect>

