<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<motionPathEffects xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../shared/xml/schema/mapMotionPathEffects.xsd">
    <motionPathEffect effectClass="TypedMotionPathEffect" effectType="PICKUPIN" filename="effects/pickup/pickupIN.i3d">
        <effectGeneration rootNode="0|0"/>
        <typeDefinition fillTypes="GRASS_WINDROW DRYGRASS_WINDROW ALFALFA_WINDROW DRYALFALFA_WINDROW" speedScale="1.4"/>

        <effectMeshes>
            <effectMesh node="0|0|0"  numRows="6"  rowLength="18" skipPositions="0" boundingBox="4 4 4"/>
            <effectMesh node="0|0|1"  numRows="9"  rowLength="11" skipPositions="0" boundingBox="3 4 4"/>
            <effectMesh node="0|0|2"  numRows="10" rowLength="5"  skipPositions="0" boundingBox="3 4 4"/>
            <effectMesh node="0|0|3"  numRows="10" rowLength="15" skipPositions="0" boundingBox="3 4 4"/>
            <effectMesh node="0|0|4"  numRows="10" rowLength="10" skipPositions="0" boundingBox="3 4 4"/>
            <effectMesh node="0|0|5"  numRows="12" rowLength="10" skipPositions="0" boundingBox="3 4 4"/>
            <effectMesh node="0|0|6"  numRows="14" rowLength="10" skipPositions="0" boundingBox="3 4 4"/>
            <effectMesh node="0|0|7"  numRows="14" rowLength="25" skipPositions="0" boundingBox="5 5 5"/>
            <effectMesh node="0|0|8"  numRows="16" rowLength="15" skipPositions="0" boundingBox="4 4 4"/>
