<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_spinnery</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/mapIcon_spinnery.png</image>
        <price>140000</price>
        <dailyUpkeep>40</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>2304</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>1280</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/spinnery.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <buysFarmland>true</buysFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
        </updateAreas>
    </ai>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="false" />
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
    </triggerMarkers>

    <infoTrigger triggerNode="infoTrigger" />

    <productionPoint>
        <productions sharedThroughputCapacity="true">
            <production id="fabric_wool" name="%s %s" params="$l10n_fillType_fabric|$l10n_fillType_wool" cyclesPerHour="90" costsPerActiveHour="7">
                <inputs>
                    <input fillType="WOOL" amount="3" />
                </inputs>
                <outputs>
                    <output fillType="FABRIC" amount="1" />
                </outputs>
            </production>
            <production id="fabric_cotton" name="%s %s" params="$l10n_fillType_fabric|$l10n_fillType_cotton" cyclesPerHour="125" costsPerActiveHour="6">
                <inputs>
                    <input fillType="COTTON" amount="9" />
                </inputs>
                <outputs>
                    <output fillType="FABRIC" amount="3" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="false" allowMissions="false" litersForFullPriceDrop="75000" fullPriceRecoverHours="48">
            <unloadTrigger exactFillRootNode="unloadTrigger" fillTypes="WOOL COTTON"/>
            <palletTrigger triggerNode="palletTrigger" fillTypes="WOOL COTTON" />
            <baleTrigger triggerNode="baleTrigger" fillTypes="WOOL COTTON" deleteLitersPerSecond="4000" />
        </sellingStation>

        <palletSpawner node="palletSpawner">
            <spawnPlaces>
                <spawnPlace startNode="spawnSpace1start" endNode="spawnSpace1end" />
                <spawnPlace startNode="spawnSpace2start" endNode="spawnSpace2end" />
                <spawnPlace startNode="spawnSpace3start" endNode="spawnSpace3end" />
            </spawnPlaces>
        </palletSpawner>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="WOOL"   capacity="100000" />
            <capacity fillType="COTTON" capacity="150000" />
            <capacity fillType="FABRIC" capacity="50000" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <effectNodes>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape01" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="30"/>
            <effectNode effectClass="ParticleEffect" effectNode="smokeEffectShape02" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="30"/>
        </effectNodes>

        <sounds>
            <idle template="spinneryIdle" linkNode="soundNode" />
            <active template="spinneryWork" linkNode="soundNode" />
        </sounds>
    </productionPoint>

    <i3dMappings>
        <i3dMapping id="sellingStation" node="0>0" />
        <i3dMapping id="unloadTrigger" node="0>0|0" />
        <i3dMapping id="palletTrigger" node="0>0|1" />
        <i3dMapping id="baleTrigger" node="0>0|2" />
        <i3dMapping id="unloadTriggerMarker" node="0>0|3" />
        <i3dMapping id="playerTrigger" node="0>1|0" />
        <i3dMapping id="playerTriggerMarker" node="0>1|0|0" />
        <i3dMapping id="soundNode" node="0>1|1" />
        <i3dMapping id="smokeEffectShape01" node="0>1|2|0" />
        <i3dMapping id="smokeEffectShape02" node="0>1|2|1" />
        <i3dMapping id="palletSpawner" node="0>2" />
        <i3dMapping id="spawnSpace1start" node="0>2|0" />
        <i3dMapping id="spawnSpace1end" node="0>2|0|0" />
        <i3dMapping id="spawnSpace2start" node="0>2|1" />
        <i3dMapping id="spawnSpace2end" node="0>2|1|0" />
        <i3dMapping id="spawnSpace3start" node="0>2|2" />
        <i3dMapping id="spawnSpace3end" node="0>2|2|0" />
        <i3dMapping id="infoTrigger" node="0>3" />
        <i3dMapping id="hotspotNode" node="0>4" />
        <i3dMapping id="teleportNode" node="0>5" />
    </i3dMappings>
</placeable>
