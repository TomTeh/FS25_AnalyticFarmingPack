<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<motionPathEffects xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../shared/xml/schema/mapMotionPathEffects.xsd">
    <motionPathEffect effectClass="TypedMotionPathEffect" effectType="STRAW_CHOPPER" filename="effects/chopper/strawChopper.i3d">
        <effectGeneration rootNode="0|0"/>
        <typeDefinition fillTypes="DRYGRASS_WINDROW DRYALFALFA_WINDROW"/>

        <effectMeshes>
            <effectMesh node="0|0|0" numRows="8"  rowLength="6"  skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|1" numRows="8"  rowLength="12" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|2" numRows="16" rowLength="12" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|3" numRows="16" rowLength="18" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|4" numRows="16" rowLength="22" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|5" numRows="20" rowLength="31" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|6" numRows="29" rowLength="31" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
        </effectMeshes>

        <effectMaterials rootNode="0|1">

<!--  CHOPPER  (spreading straw from the end of the harvester) -->

            <effectMaterial materialType="CHOPPER" node="0|1|0|0" fillTypes="DRYGRASS_WINDROW" speedScale="1.0">
                <customShaderParameter name="sizeScale" value="0.75 3.75 0.0 0.0"/>
            </effectMaterial>
            <effectMaterial materialType="CHOPPER" node="0|1|0|1" fillTypes="DRYALFALFA_WINDROW" speedScale="1.0">
                <customShaderParameter name="sizeScale" value="0.75 3.75 0.0 0.0"/>
            </effectMaterial>
        </effectMaterials>

        <customShaderDefaults>
            <customShaderVariation name="subUV_alphaMap"/>
        </customShaderDefaults>
    </motionPathEffect>

<!--  BASE GAME -->
    <motionPathEffect effectClass="TypedMotionPathEffect" effectType="STRAW_CHOPPER" filename="$data/effects/chopper/strawChopper.i3d">
        <effectGeneration rootNode="0|0"/>
        <typeDefinition fillTypes="RYE"/>

        <effectMeshes>
            <effectMesh node="0|0|0" numRows="8"  rowLength="6"  skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|1" numRows="8"  rowLength="12" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|2" numRows="16" rowLength="12" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|3" numRows="16" rowLength="18" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|4" numRows="16" rowLength="22" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|5" numRows="20" rowLength="31" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
            <effectMesh node="0|0|6" numRows="29" rowLength="31" skipPositions="0" boundingBox="16 5 14" boundingBoxCenter="0 0 -7"/>
        </effectMeshes>

        <effectMaterials rootNode="0|1">

<!--  CHOPPER  (spreading straw from the end of the harvester) -->

            <effectMaterial materialType="CHOPPER" node="0|1|0|0" fillTypes="RYE" speedScale="1.0">
                <customShaderParameter name="sizeScale" value="0.75 3.75 0.0 0.0"/>
            </effectMaterial>

<!--  CHAFFER (spreading straw from the sides of the harvester) -->

            <effectMaterial materialType="CHAFFER" node="0|1|1|0" fillTypes="RYE" speedScale="1.0">
                <customShaderParameter name="sizeScale" value="0.25 3.75 0.0 0.0"/>
            </effectMaterial>

<!--  DROP  (dropping straw on the ground) -->

            <effectMaterial materialType="DROP" node="0|1|2|0" fillTypes="RYE" speedScale="1.0">
                <customShaderParameter name="sizeScale" value="1.0 2.5 0.0 0.0"/>
                <customShaderParameter name="keepNormals" value="1 0 0 0"/>
            </effectMaterial>
        </effectMaterials>

        <customShaderDefaults>
            <customShaderVariation name="subUV_alphaMap"/>
        </customShaderDefaults>
    </motionPathEffect>
</motionPathEffects>
