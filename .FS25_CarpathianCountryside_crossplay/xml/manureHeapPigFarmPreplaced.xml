<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="mapCC_bunkerAndManureHeap" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_manureHeapPigFarm</name>
        <functions>
            <function>$l10n_function_manureHeap</function>
            <function>$l10n_function_roofSolarPanelsOption</function>
        </functions>
        <image>placeables/modularWalls/store_manureHeapPigFarm.png</image>
        <price>34000</price>
        <dailyUpkeep>20</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>EASYSHEDS</brand>
        <species>placeable</species>
        <category>silos</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>siloExtensions</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-20" cameraYRot="-130" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>391680</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>63488</indexBufferMemoryUsage>
        <textureMemoryUsage>2424832</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/modularWalls/easyShed01WithWalls.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
            <testArea startNode="testAreaStart2" endNode="testAreaEnd2" />
        </testAreas>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart2" widthNode="clearAreaWidth2" heightNode="clearAreaHeight2"/>
    </clearAreas>

    <leveling requireLeveling="false" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart1" widthNode="levelAreaWidth2" heightNode="levelAreaHeight2"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart2" widthNode="indoorAreaWidth2" heightNode="indoorAreaHeight2" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart2" endNode="tipOcclusionUpdateAreaEnd2" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart2" endNode="tipOcclusionUpdateAreaEnd2" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="loadingTriggerMarker" filename="$data/shared/assets/marker/markerIconLoad.i3d" adjustToGround="true" />
        <triggerMarker node="warningStripes" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="LOADING" linkNode="mapPosition" teleportNode="teleportNode" />
    </hotspots>

    <lights>
        <group name="$l10n_action_placeableLightShed" triggerNode="controledLightsTrigger">
            <sounds>
                <toggle template="lizardFloodLight" innerRadius="40" outerRadius="50" volumeScale="0.2"/>
            </sounds>
        </group>

        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight01" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/industrialWallLight.xml" linkNode="industrialWallLight02" groupIndex="1"/>

        <realLights>
            <low>
                <light node="realLightsControledLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsControledHigh" groupIndex="1"/>
            </high>
        </realLights>
    </lights>

    <infoTrigger triggerNode="infoTrigger" />

    <manureHeap node="manureHeap" capacity="800000" isExtension="false" needsBarn="false" >
        <area startNode="tipAreaStart" widthNode="tipAreaWidth" heightNode="tipAreaHeight" activationTriggerNode="activationTrigger" />
        <clearArea startNode="clearAreaStart" widthNode="clearAreaWidth" heightNode="clearAreaHeight" />

        <loadingStation storageRadius="10" supportsExtension="false">
            <loadTrigger triggerNode="loadingTrigger" aiNode="loadingTriggerAINode" fillTypes="MANURE" fillLitersPerSecond="2000" />
        </loadingStation>
    </manureHeap>

    <bunkerSilo isExtendable="false" acceptedFillTypes="CHAFF GRASS_WINDROW DRYGRASS_WINDROW" inputFillType="CHAFF" outputFillType="SILAGE" distanceToCompactedFillLevel="100" openingLength="5" >
        <area startNode="siloAreaStart" widthNode="siloAreaWidth" heightNode="siloAreaHeight" />
        <innerArea startNode="siloInnerAreaStart" widthNode="siloInnerAreaWidth" heightNode="siloInnerAreaHeight" />
        <interactionTrigger node="siloAreaTrigger" />
        <wallLeft node="wallLeft" collision="wallLeftCollision"/>
        <wallRight node="wallRight" collision="wallRightCollision"/>
    </bunkerSilo>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="easyShed01Node" filename="placeables/sharedAssets/easyShed01.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch01" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
    </dynamicallyLoadedParts>

    <solarPanels>
        <solarPanelsConfigurations>
            <solarPanelsConfiguration name="$l10n_ui_none" isActive="false"/>
            <solarPanelsConfiguration name="195" isActive="true" price="51940" incomePerHour="176" >
                <objectChange node="solarPanels" visibilityActive="true"/>
            </solarPanelsConfiguration>
        </solarPanelsConfigurations>
    </solarPanels>

