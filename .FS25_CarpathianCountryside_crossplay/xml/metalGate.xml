<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="simplePlaceable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_metalGate</name>
        <functions>
            <function>$l10n_function_decoration</function>
        </functions>
        <image>placeables/fences/store_metalGate.dds</image>
        <price>1800</price>
        <dailyUpkeep>0</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDBUILDING</brand>
        <species>placeable</species>
        <category>fences</category>
        <brush>
            <type>placeable</type>
            <category>decoration</category>
            <tab>newFences</tab>
        </brush>
        <vertexBufferMemoryUsage>49664</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>8704</indexBufferMemoryUsage>
        <textureMemoryUsage>1638400</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/fences/metalGate.i3d</filename>
        <canBeRenamed>false</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testArea3Start" endNode="testArea3End" />
        </testAreas>

        <sounds>
            <place template="fenceMetalImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearLevelAreaStart3" widthNode="clearLevelAreaWidth3" heightNode="clearLevelAreaHeight3"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="clearLevelAreaStart3" widthNode="clearLevelAreaWidth3" heightNode="clearLevelAreaHeight3" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
            <updateArea startNode="testArea3Start" endNode="testArea3End" />
        </updateAreas>
    </ai>

    <animatedObjects>
        <animatedObject saveId="mainGate">
            <animation duration="5">
                <part node="mainGateRight">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 99 0"/>
                </part>
                <part node="mainGateLeft">
                    <keyFrame time="0.005" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -99 0"/>
                </part>
            </animation>
            <controls triggerNode="mainGate_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="mainGate_sound" file="sounds/placeables/gates/metalGate.wav" loops="0" innerRadius="5" outerRadius="18" fadeOut="0.1" >
                    <randomization minVolume="-0.1" maxVolume="0.1" minPitch="-0.1" maxPitch="0.1" isInside="true" isOutside="true" />
                    <volume indoor="4.2" outdoor="4.2" />
                </moving>
                <posEnd linkNode="mainGate_sound" template="metalDoorsOpen" innerRadius="5" outerRadius="18" />
                <negEnd linkNode="mainGate_sound" file="sounds/placeables/gates/metalGate_closed.wav" innerRadius="5" outerRadius="18" >
                    <randomization minVolume="-0.1" maxVolume="0.1" minPitch="-0.1" maxPitch="0.1" isInside="true" isOutside="true" />
                    <volume indoor="4.0" outdoor="4.0" />
                </negEnd>
            </sounds>
        </animatedObject>
    </animatedObjects>

    <deletedNodes>
        <deletedNode node="doorLeft_group" />
        <deletedNode node="doorRight_group" />
        <deletedNode node="hingeMiddle01" />
        <deletedNode node="hingeMiddle02" />
        <deletedNode node="gatePole01" />
        <deletedNode node="gatePole02" />
    </deletedNodes>

    <i3dMappings>
        <i3dMapping id="mainGateRight" node="0>0|0" />
        <i3dMapping id="mainGateLeft" node="0>0|1" />
        <i3dMapping id="mainGate_trigger" node="0>0|2" />
        <i3dMapping id="mainGate_sound" node="0>0|3" />
        <i3dMapping id="doorLeft_group" node="0>1" />
        <i3dMapping id="doorLeft" node="0>1|0" />
        <i3dMapping id="doorLeft_handle" node="0>1|0|0" />
        <i3dMapping id="doorLeft_trigger" node="0>1|1" />
        <i3dMapping id="doorLeft_sound" node="0>1|2" />
        <i3dMapping id="doorRight_group" node="0>2" />
        <i3dMapping id="doorRight" node="0>2|0" />
        <i3dMapping id="doorRight_handle" node="0>2|0|0" />
        <i3dMapping id="doorRight_trigger" node="0>2|1" />
        <i3dMapping id="doorRight_sound" node="0>2|2" />
        <i3dMapping id="hingeMiddle01" node="0>3" />
        <i3dMapping id="hingeMiddle02" node="0>4" />
        <i3dMapping id="hingeRight" node="0>5" />
        <i3dMapping id="hingeLeft" node="0>6" />
        <i3dMapping id="gatePole01" node="0>7" />
        <i3dMapping id="gatePole02" node="0>8" />
        <i3dMapping id="clearLevelAreaStart1" node="0>9|0" />
        <i3dMapping id="clearLevelAreaWidth1" node="0>9|0|0" />
        <i3dMapping id="clearLevelAreaHeight1" node="0>9|0|1" />
        <i3dMapping id="clearLevelAreaStart2" node="0>9|1" />
        <i3dMapping id="clearLevelAreaWidth2" node="0>9|1|0" />
        <i3dMapping id="clearLevelAreaHeight2" node="0>9|1|1" />
        <i3dMapping id="clearLevelAreaStart3" node="0>9|2" />
        <i3dMapping id="clearLevelAreaWidth3" node="0>9|2|0" />
        <i3dMapping id="clearLevelAreaHeight3" node="0>9|2|1" />
        <i3dMapping id="tipOcclusionUpdateAreaStart1" node="0>10|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd1" node="0>10|0|0" />
        <i3dMapping id="testArea1Start" node="0>11|0" />
        <i3dMapping id="testArea1End" node="0>11|0|0" />
        <i3dMapping id="testArea2Start" node="0>11|1" />
        <i3dMapping id="testArea2End" node="0>11|1|0" />
        <i3dMapping id="testArea3Start" node="0>11|2" />
        <i3dMapping id="testArea3End" node="0>11|2|0" />
    </i3dMappings>
</placeable>
