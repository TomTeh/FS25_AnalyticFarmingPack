<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="pallet" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://validation.gdn.giants-software.com/xml/fs25/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>$l10n_storeItem_tablePallet</name>
        <image>objects/pallets/tablePallet/store_tablePallet.png</image>
        <price>2450</price>
        <category>pallets</category>
        <brand>NONE</brand>
        <showInStore>false</showInStore>
        <canBeSold>false</canBeSold>
        <financeCategory>OTHER</financeCategory>

        <storeIconRendering>
            <settings centerIcon="true" cameraXRot="-15" cameraYRot="35"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>20992</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>5888</indexBufferMemoryUsage>
        <textureMemoryUsage>1441792</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_pallet</typeDesc>
        <filename>objects/pallets/tablePallet/tablePallet.i3d</filename>
        <size width="2.5" length="0.9" height="0.6" lengthOffset="0" />
        <canBeReset>false</canBeReset>
        <components maxMass="600">
            <component centerOfMass="0 0.2 0" solverIterationCount="10" mass="500"/>
        </components>
        <showInVehicleMenu>false</showInVehicleMenu>
        <mapHotspot available="false" />
        <input allowed="false"/>
    </base>

    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration>
                <fillUnits removeVehicleIfEmpty="true">
                    <fillUnit unitTextOverride="$l10n_unit_pieces" fillTypes="TABLE" capacity="1000" ignoreFillLimit="true"/>
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>

    <pallet fillUnitIndex="1" linkNode="palletLinkNode01 palletLinkNode02">
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletNew_diffuse.dds"/>
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletMiddle_diffuse.dds"/>
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletOld_diffuse.dds"/>

        <content>
            <object node="table01" tensionBeltNode="table_Tension01"/>
            <object node="table02" tensionBeltNode="table_Tension02"/>
            <object node="table03" tensionBeltNode="table_Tension03"/>
            <object node="table04" tensionBeltNode="table_Tension04"/>
        </content>

        <sounds>
            <unload template="palletsFillWood" pitchScale="0.7" volumeScale="2.5" supportsReverb="false"/>
        </sounds>
    </pallet>

    <dynamicMount triggerNode="dynamicMountTrigger" triggerForceAcceleration="4" additionalMountDistance="0.55" jointTransY="0.106" jointLimitToRotY="true"/>

    <i3dMappings>
        <i3dMapping id="tablePallet_main_component1" node="0>" />
        <i3dMapping id="dynamicMountTrigger" node="0>0" />
        <i3dMapping id="table01" node="0>1|0" />
        <i3dMapping id="table_Tension01" node="0>1|0|2" />
        <i3dMapping id="table02" node="0>1|1" />
        <i3dMapping id="table_Tension02" node="0>1|1|0" />
        <i3dMapping id="table03" node="0>1|2" />
        <i3dMapping id="table_Tension03" node="0>1|2|0" />
        <i3dMapping id="table04" node="0>1|3" />
        <i3dMapping id="table_Tension04" node="0>1|3|0" />
        <i3dMapping id="palletLinkNode01" node="0>2" />
        <i3dMapping id="palletLinkNode02" node="0>3" />
    </i3dMappings>
</vehicle>
