<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="objectStorage" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_palletRack</name>
        <functions>
            <function>$l10n_function_objectStorage</function>
        </functions>
        <image>placeables/shed/store_vehicleShelter3_palletRack.dds</image>
        <price>2000</price>
        <dailyUpkeep>5</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>placeableMisc</category>

        <storeIconRendering>
            <settings cameraXRot="-10" cameraYRot="-130" advancedBoundingBox="true"/>
            <objectBundle>
                <object filename="placeables/shed/vehicleShelter3Preplaced_palletRack.i3d">
                    <node node="0" translation="22.3 0 0" rotation="0 0 0" scale="1 1 1"/>
                </object>
            </objectBundle>
        </storeIconRendering>
        <vertexBufferMemoryUsage>44800</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>8448</indexBufferMemoryUsage>
        <textureMemoryUsage>1048576</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/shed/vehicleShelter3Preplaced_palletRack.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
        </sounds>
    </placement>

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <hotspots>
        <hotspot type="UNLOADING" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="warningStripes" />
        <triggerMarker node="objectTriggerMarker" filename="placeables/sharedAssets/marker/markerIconStorageIn.i3d" adjustToGround="true" />
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconStorageOut.i3d" adjustToGround="true" />
        <triggerMarker node="objectStorageConfig_marker" filename="$data/shared/assets/marker/markerIconWrench.i3d" adjustToGround="true" />
    </triggerMarkers>

    <infoTrigger triggerNode="infoTrigger"/>

    <animatedObjects>
        <animatedObject saveId="vehicleShelter3Preplaced_palletRack_objectStorageConfig">
            <animation duration="0.2">
                <part node="objectTrigger">
                    <keyFrame time="0" translation="-18.75 -0.1 0" />
                    <keyFrame time="1.0" translation="-18.75 -10 0" />
                </part>
                <part node="playerTrigger">
                    <keyFrame time="0" translation="-17.5 -0.1 -4" />
                    <keyFrame time="1.0" translation="-17.5 -10 -4" />
                </part>
                <part node="infoTrigger">
                    <keyFrame time="0" translation="-16.75 2.8 0" />
                    <keyFrame time="1.0" translation="-16.75 -7 0" />
                </part>
                <part node="markers">
                    <keyFrame time="0" visibility="true" />
                    <keyFrame time="1.0" visibility="false" />
                </part>
                <part node="rackCollisions_front">
                    <keyFrame time="0" translation="0 0 0" />
                    <keyFrame time="1.0" translation="0 -10 0" />
                </part>
            </animation>
            <controls triggerNode="objectStorageConfig_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_configureObjectStorageOff" negText="action_configureObjectStorageOn" />
        </animatedObject>
    </animatedObjects>

    <objectStorage supportsBales="false" supportsPallets="true" capacity="50" maxUnloadAmount="15" maxLength="5.4" maxWidth="2.3" maxHeight="2.1">
        <playerTrigger node="playerTrigger" />
        <objectTrigger node="objectTrigger" />
        <storageAreas>
            <storageArea startNode="storageAreaStart01" endNode="storageAreaEnd01" maxHeight="2.06"/>
            <storageArea startNode="storageAreaStart02" endNode="storageAreaEnd02" maxHeight="2.06"/>
            <storageArea startNode="storageAreaStart03" endNode="storageAreaEnd03" maxHeight="1.84"/>
            <storageArea startNode="storageAreaStart04" endNode="storageAreaEnd04" maxHeight="1.84"/>
            <storageArea startNode="storageAreaStart05" endNode="storageAreaEnd05" maxHeight="2.3"/>
            <storageArea startNode="storageAreaStart06" endNode="storageAreaEnd06" maxHeight="2.3"/>
        </storageAreas>
        <spawnAreas>
            <spawnArea startNode="spawnAreaStart01" endNode="spawnAreaEnd01"/>
        </spawnAreas>
    </objectStorage>

    <i3dMappings>
        <i3dMapping id="objectTrigger" node="0>0|0" />
        <i3dMapping id="playerTrigger" node="0>0|1" />
        <i3dMapping id="storageAreaStart01" node="0>0|2|0" />
        <i3dMapping id="storageAreaEnd01" node="0>0|2|0|0" />
        <i3dMapping id="storageAreaStart02" node="0>0|2|1" />
        <i3dMapping id="storageAreaEnd02" node="0>0|2|1|0" />
        <i3dMapping id="storageAreaStart03" node="0>0|2|2" />
        <i3dMapping id="storageAreaEnd03" node="0>0|2|2|0" />
        <i3dMapping id="storageAreaStart04" node="0>0|2|3" />
        <i3dMapping id="storageAreaEnd04" node="0>0|2|3|0" />
        <i3dMapping id="storageAreaStart05" node="0>0|2|4" />
        <i3dMapping id="storageAreaEnd05" node="0>0|2|4|0" />
        <i3dMapping id="storageAreaStart06" node="0>0|2|5" />
        <i3dMapping id="storageAreaEnd06" node="0>0|2|5|0" />
        <i3dMapping id="spawnAreaStart01" node="0>0|3|0" />
        <i3dMapping id="spawnAreaEnd01" node="0>0|3|0|0" />
        <i3dMapping id="infoTrigger" node="0>0|4" />
        <i3dMapping id="markers" node="0>0|5" />
        <i3dMapping id="warningStripes" node="0>0|5|0" />
        <i3dMapping id="objectTriggerMarker" node="0>0|5|1" />
        <i3dMapping id="playerTriggerMarker" node="0>0|5|2" />
        <i3dMapping id="hotspotNode" node="0>0|6" />
        <i3dMapping id="teleportNode" node="0>0|7" />
        <i3dMapping id="rackCollisions_front" node="0>0|8|1" />
        <i3dMapping id="objectStorageConfig_trigger" node="0>0|9|0" />
        <i3dMapping id="objectStorageConfig_marker" node="0>0|9|1" />
        <i3dMapping id="tipOcclusionUpdateAreaStart1" node="0>1|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd1" node="0>1|0|0" />
        <i3dMapping id="testAreaStart1" node="0>2|0" />
        <i3dMapping id="testAreaEnd1" node="0>2|0|0" />
    </i3dMappings>
</placeable>
