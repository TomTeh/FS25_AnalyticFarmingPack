<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="incomePerHourObject" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
