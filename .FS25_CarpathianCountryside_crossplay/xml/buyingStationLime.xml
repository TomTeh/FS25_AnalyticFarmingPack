<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="buyingStation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_limeStation</name>
        <image>placeables/buyingStations/mapIcon_buyingStationLime01.png</image>
        <price>1</price>
        <dailyUpkeep>0</dailyUpkeep>
        <canBeSold>false</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>placeableMisc</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>containers</tab>
        </brush>
        <vertexBufferMemoryUsage>43008</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>17152</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/buyingStations/buyingStation.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <ai>
        <updateAreas/>
    </ai>

    <triggerMarkers>
        <triggerMarker node="markerLoading" filename="placeables/sharedAssets/marker/markerIconBuyConsumable.i3d" adjustToGround="true" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="LOADING" linkNode="mapPosition" teleportNode="teleportNode" />
    </hotspots>

    <buyingStation node="buyingStation" supportsExtension="false">
        <loadTrigger triggerNode="loadingTrigger" fillTypes="LIME" fillLitersPerSecond="1000" dischargeNode="dischargeNode" infiniteCapacity="true">
            <effectNode effectClass="PipeEffect" effectNode="pipeEffect"      materialType="pipe"           fadeTime="0.5" maxBending="0" shapeScaleSpread="0.8 0.8 1 0" controlPoint="5.5 0 0 0"/>
            <effectNode                          effectNode="pipeEffectSmoke" materialType="unloadingSmoke" fadeTime="0.5" />
        </loadTrigger>
        <fillType name="LIME" priceScale="0.8" />
    </buyingStation>

    <i3dMappings>
        <i3dMapping id="buyingStation" node="0>0" />
        <i3dMapping id="loadingTrigger" node="0>0|0" />
        <i3dMapping id="dischargeNode" node="0>0|1" />
        <i3dMapping id="pipeEffect" node="0>0|2|0" />
        <i3dMapping id="pipeEffectSmoke" node="0>0|2|1" />
        <i3dMapping id="aiNodeLoading" node="0>0|3" />
        <i3dMapping id="markerLoading" node="0>1" />
        <i3dMapping id="mapPosition" node="0>2" />
        <i3dMapping id="teleportNode" node="0>3" />
    </i3dMappings>
</placeable>
