<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_bakery</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/mapIcon_bakery.png</image>
        <price>105000</price>
        <dailyUpkeep>40</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>2304</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>1280</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/bakery.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <buysFarmland>true</buysFarmland>
        <canBeDeleted>false</canBeDeleted>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas></updateAreas>
    </ai>

    <infoTrigger triggerNode="infoTrigger"/>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="hotspotNode" teleportNode="teleportNode" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
    </triggerMarkers>

    <productionPoint>
        <productions sharedThroughputCapacity="true">
            <production id="bread" name="%s (%s)" params="$l10n_fillType_bread|$l10n_fillType_flour" cyclesPerHour="6" costsPerActiveHour="3">
                <inputs>
                    <input fillType="FLOUR" amount="90" />
                </inputs>
                <outputs>
                    <output fillType="BREAD" amount="45" />
                </outputs>
            </production>
            <production id="breadRiceFlour" name="%s (%s)" params="$l10n_fillType_bread|$l10n_fillType_riceFlour" cyclesPerHour="3" costsPerActiveHour="3">
                <inputs>
                    <input fillType="RICEFLOUR" amount="68" />
                </inputs>
                <outputs>
                    <output fillType="BREAD" amount="45" />
                </outputs>
            </production>

            <production id="cake" name="%s (%s)" params="$l10n_fillType_cake|$l10n_fillType_flour" cyclesPerHour="4" costsPerActiveHour="3">
                <inputs>
                    <input fillType="FLOUR"         amount="8" />
                    <input fillType="SUGAR"         amount="8" />
                    <input fillType="MILK_BOTTLED"  amount="8" />
                    <input fillType="EGG"           amount="8" />
                    <input fillType="BUTTER"        amount="8" />
                    <input fillType="STRAWBERRY"    amount="8" />
                </inputs>
                <outputs>
                    <output fillType="CAKE" amount="21" />
                </outputs>
            </production>
            <production id="cakeRiceFlour" name="%s (%s)" params="$l10n_fillType_cake|$l10n_fillType_riceFlour" cyclesPerHour="3" costsPerActiveHour="3">
                <inputs>
                    <input fillType="RICEFLOUR"    amount="6" />
                    <input fillType="SUGAR"        amount="8" />
                    <input fillType="MILK_BOTTLED" amount="8" />
                    <input fillType="EGG"          amount="8" />
                    <input fillType="BUTTER"       amount="8" />
                    <input fillType="STRAWBERRY"   amount="8" />
                </inputs>
                <outputs>
                    <output fillType="CAKE" amount="21" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" appearsOnStats="true" supportsExtension="false" allowMissions="false" litersForFullPriceDrop="100000" fullPriceRecoverHours="48">
            <unloadTrigger exactFillRootNode="unloadTrigger" fillTypes="FLOUR RICEFLOUR SUGAR MILK_BOTTLED EGG BUTTER STRAWBERRY"/>
            <palletTrigger triggerNode="palletTrigger" fillTypes="FLOUR RICEFLOUR SUGAR MILK_BOTTLED EGG BUTTER STRAWBERRY" />
        </sellingStation>

        <palletSpawner node="palletSpawner">
            <spawnPlaces>
                <spawnPlace startNode="spawnSpace1start" endNode="spawnSpace1end" />
                <spawnPlace startNode="spawnSpace2start" endNode="spawnSpace2end" />
                <spawnPlace startNode="spawnSpace3start" endNode="spawnSpace3end" />
            </spawnPlaces>
        </palletSpawner>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="FLOUR"        capacity="50000" />
            <capacity fillType="RICEFLOUR"    capacity="50000" />
            <capacity fillType="SUGAR"        capacity="15000" />
            <capacity fillType="MILK_BOTTLED" capacity="15000" />
            <capacity fillType="EGG"          capacity="15000" />
            <capacity fillType="BUTTER"       capacity="15000" />
            <capacity fillType="STRAWBERRY"   capacity="15000" />
            <capacity fillType="BREAD"        capacity="50000" />
            <capacity fillType="CAKE"         capacity="20000" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <effectNodes>
            <effectNode effectClass="ParticleEffect" effectNode="smokeChimenyEffectShape01" particleType="SMOKE_CHIMNEY" emitCountScale="75"/>
        </effectNodes>

        <sounds>
            <idle template="bakeryIdle" linkNode="soundNode" />
            <active template="bakeryWork" linkNode="soundNode" />
        </sounds>
    </productionPoint>

    <i3dMappings>
        <i3dMapping id="sellingStation" node="0>0" />
        <i3dMapping id="unloadTrigger" node="0>0|0" />
        <i3dMapping id="palletTrigger" node="0>0|1" />
        <i3dMapping id="unloadTriggerMarker" node="0>0|2" />
        <i3dMapping id="playerTrigger" node="0>1|0" />
        <i3dMapping id="playerTriggerMarker" node="0>1|0|0" />
        <i3dMapping id="soundNode" node="0>1|1" />
        <i3dMapping id="smokeChimenyEffectShape01" node="0>1|2|0" />
        <i3dMapping id="palletSpawner" node="0>2" />
        <i3dMapping id="spawnSpace1start" node="0>2|0" />
        <i3dMapping id="spawnSpace1end" node="0>2|0|0" />
        <i3dMapping id="spawnSpace2start" node="0>2|1" />
        <i3dMapping id="spawnSpace2end" node="0>2|1|0" />
        <i3dMapping id="spawnSpace3start" node="0>2|2" />
        <i3dMapping id="spawnSpace3end" node="0>2|2|0" />
        <i3dMapping id="infoTrigger" node="0>3" />
        <i3dMapping id="hotspotNode" node="0>4" />
        <i3dMapping id="teleportNode" node="0>5" />
    </i3dMappings>
</placeable>
