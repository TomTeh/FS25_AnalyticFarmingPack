<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="bigBag" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <parentFile xmlFilename="objects/bigBag/bigBag.xml">
        <attributes>
            <set path="vehicle.storeData.name" value="$l10n_fillType_mineralFeed"/>
            <set path="vehicle.storeData.image" value="objects/bigBag/mineralFeed/store_bigBag_mineralFeed.png"/>
            <set path="vehicle.storeData.price" value="1000"/>
            <set path="vehicle.storeData.functions.function" value="$l10n_function_mineralFeedPallet"/>
            <set path="vehicle.storeData.financeCategory" value="OTHER"/>

            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit#fillTypes" value="MINERAL_FEED"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit#startFillType" value="MINERAL_FEED"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit#capacity" value="1000"/>
            <set path="vehicle.fillUnit.fillUnitConfigurations.fillUnitConfiguration(0).fillUnits.fillUnit#startFillLevel" value="1000"/>
         </attributes>
    </parentFile>

    <!-- ONLY FOR ICON GENERATION -->
    <storeData>
        <name>$l10n_fillType_mineralFeed</name>
        <image>objects/bigBag/mineralFeed/store_bigBag_mineralFeed.png</image>
        <brand>LIZARDGOODS</brand>
        <category>bigbags</category>

        <storeIconRendering>
            <settings cameraXRot="-15" cameraYRot="35"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>0</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>0</indexBufferMemoryUsage>
        <textureMemoryUsage>0</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>
</vehicle>
