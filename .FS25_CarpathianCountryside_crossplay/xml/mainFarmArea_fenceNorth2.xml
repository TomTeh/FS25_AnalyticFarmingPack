<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="simplePlaceable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_preplacedMapObject</name>
        <functions>
            <function>$l10n_function_decoration</function>
        </functions>
        <image>placeables/store_defaultMapItem.dds</image>
        <price>7000</price>
        <dailyUpkeep>0</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>decoration</category>
        <vertexBufferMemoryUsage>20480</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>4864</indexBufferMemoryUsage>
        <textureMemoryUsage>2490368</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/area/mainFarmArea_fenceNorth2.i3d</filename>
        <canBeRenamed>false</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" />

    <clearAreas/>

    <leveling/>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
        </updateAreas>
    </ai>

    <animatedObjects>
        <animatedObject saveId="mainFarm_chainlinkFenceGate_side">
            <animation duration="5">
                <part node="chainLinkGate">
                    <keyFrame time="0.0" translation="-76.926 1.553 -217.548"/>
                    <keyFrame time="1.0" translation="-69.005 1.332 -214.665"/>
                </part>
            </animation>
            <controls triggerNode="chainLinkGate_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="chainLinkGate_sound" file="sounds/placeables/gates/chainLinkFence.wav" loops="0" innerRadius="5" outerRadius="18" fadeOut="0.1" >
                    <randomization minVolume="-0.1" maxVolume="0.1" minPitch="-0.1" maxPitch="0.1" isInside="true" isOutside="true" />
                    <volume indoor="2.8" outdoor="2.8" />
                </moving>
                <posEnd linkNode="chainLinkGate_sound" file="sounds/placeables/gates/chainLinkFence_closed.wav" innerRadius="5" outerRadius="18" >
                    <randomization minVolume="-0.1" maxVolume="0.1" minPitch="-0.1" maxPitch="0.1" isInside="true" isOutside="true" />
                    <volume indoor="2.8" outdoor="2.8" />
                </posEnd>
                <negEnd linkNode="chainLinkGate_sound" file="sounds/placeables/gates/chainLinkFence_closed.wav" innerRadius="5" outerRadius="18" >
                    <randomization minVolume="-0.1" maxVolume="0.1" minPitch="-0.1" maxPitch="0.1" isInside="true" isOutside="true" />
                    <volume indoor="2.8" outdoor="2.8" />
                </negEnd>
            </sounds>
        </animatedObject>
    </animatedObjects>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="3" linkNode="propsBordersNode" filename="placeables/sharedAssets/propsBorders.i3d" />
    </dynamicallyLoadedParts>

    <i3dMappings>
        <i3dMapping id="propsBordersNode" node="0>0|0" />
        <i3dMapping id="propsPreplacedNode" node="0>0|1" />
        <i3dMapping id="chainLinkGate" node="0>1|0|0" />
        <i3dMapping id="chainLinkGate_trigger" node="0>1|0|2" />
        <i3dMapping id="chainLinkGate_sound" node="0>1|0|2" />
    </i3dMappings>
</placeable>
