                    <volume indoor="4.0" outdoor="4.0" />
                </negEnd>
            </sounds>
        </animatedObject>
        <animatedObject saveId="mainFarmGate_frontSecondary">
            <animation duration="5">
                <part node="farmGateLeftSecondary">
                    <keyFrame time="0.0" rotation="180 0 -180"/>
