            </animation>
            <controls triggerNode="farmGateSmall_trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="farmGateSmall_sound" template="metalDoorsLoop" />
                <posEnd linkNode="farmGateSmall_sound" template="metalDoorsOpen" />
                <negEnd linkNode="farmGateSmall_sound" template="metalDoorsClose" />
