    <constructible>
        <stateMachine>
            <states>
                <state name="SETUP" class="ConstructibleStateBuilding" >
                    <toggleMesh node="farmBuildingsConstructable03_lod1" active="false" updatePhysics="false"/>
                    <toggleMesh node="concreteBase"                      active="false" updatePhysics="false"/>
                    <toggleMesh node="phase07"                           active="false" updatePhysics="false"/>
                    <toggleMesh node="rainGutters"                       active="false" updatePhysics="false"/>
                    <!-- <toggleMesh node="farmhouseFeatures"                 active="false" updatePhysics="true"/> -->
                    <!-- <toggleMesh node="wardrobe"                          active="false" updatePhysics="true"/> -->
                    <toggleMesh node="doors"                             active="false" updatePhysics="true"/>
                    <toggleMesh node="clearAreas_propsFinishedNode"      active="false" updatePhysics="true"/>
                    <toggleHotspot index="1" isVisible="true" />
                    <!-- <toggleHotspot index="2" isVisible="false" /> -->

                    <input fillType="WOODBEAM" amount="1000" usagePerHour="250"/>
                    <input fillType="PLANKS"   amount="1000" usagePerHour="250"/>
                    <input fillType="BOARDS"   amount="1000" usagePerHour="250"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_1" class="ConstructibleStateBuilding" >
                    <toggleMesh node="concreteBase" active="true" updatePhysics="false"/>

                    <input fillType="CEMENT" amount="8000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_2" class="ConstructibleStateBuilding" >
                    <mesh node="phase01" indexMin="0" indexMax="26" />

                    <input fillType="WOODBEAM" amount="3000" usagePerHour="500"/>
                    <input fillType="PLANKS"   amount="3000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_3" class="ConstructibleStateBuilding" >
                    <mesh node="phase02" indexMin="0" indexMax="17" />

                    <input fillType="PREFABWALL" amount="8000" usagePerHour="500"/>
                    <input fillType="PLANKS"     amount="2000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_4" class="ConstructibleStateBuilding" >
                    <mesh node="phase03" indexMin="0" indexMax="45" />

                    <input fillType="PLANKS" amount="8000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_5" class="ConstructibleStateBuilding" >
                    <mesh node="phase04" indexMin="0" indexMax="31" />

                    <input fillType="WOODBEAM" amount="6000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_6" class="ConstructibleStateBuilding" >
                    <mesh node="phase05" indexMin="0" indexMax="58" />

                    <input fillType="PLANKS"     amount="4000" usagePerHour="500"/>
                    <input fillType="SHINGLE"    amount="7000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_7" class="ConstructibleStateBuilding" >
                    <mesh node="phase06" indexMin="0" indexMax="27" />

                    <input fillType="PLANKS" amount="2000" usagePerHour="250"/>
                    <input fillType="BOARDS" amount="3000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_8" class="ConstructibleStateBuilding" >
                    <toggleMesh node="phase07" active="true" updatePhysics="false"/>

                    <input fillType="FURNITURE" amount="5000" usagePerHour="500"/>
                    <input fillType="CHAIR"     amount="2000" usagePerHour="250"/>
                    <input fillType="TABLE"     amount="2000" usagePerHour="250"/>
                    <input fillType="ARMOIRE"   amount="2000" usagePerHour="250"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_9" class="ConstructibleStateBuilding" >
                    <mesh node="phase08" indexMin="0" indexMax="27" />

                    <input fillType="BOARDS" amount="1000" usagePerHour="250"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_10" class="ConstructibleStateBuilding" >
                    <toggleMesh node="rainGutters" active="true" updatePhysics="false"/>

                    <input fillType="BOARDS" amount="1000" usagePerHour="250"/>
                    <input fillType="PLANKS" amount="1000" usagePerHour="250"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="FINALIZE" class="ConstructibleStateFinalize" >
                    <toggleMesh node="sellingStation"                    active="false" updatePhysics="true"/> <!-- disable unload trigger -->
                    <toggleMesh node="propsConstructionNode"             active="false" updatePhysics="true"/> <!-- disable construction fence -->
                    <toggleMesh node="farmBuildingsConstructable03_lod1" active="true"  updatePhysics="true"/> <!-- enable lod1 -->
                    <!-- <toggleMesh node="farmhouseFeatures"                 active="true"  updatePhysics="true"/> --> <!-- enable farmhouse -->
                    <!-- <toggleMesh node="wardrobe"                          active="true"  updatePhysics="true"/> --> <!-- enable wardrobe -->
                    <toggleMesh node="doors"                             active="true"  updatePhysics="true"/> <!-- enable doors -->
                    <toggleMesh node="infoTrigger"                       active="false" updatePhysics="true"/> <!-- disable info trigger -->
                    <toggleMesh node="clearAreas_propsFinishedNode"                 active="true"  updatePhysics="true"/> <!-- enable propsBuilding -->
                    <toggleHotspot index="1" isVisible="false" />
                    <!-- <toggleHotspot index="2" isVisible="true" /> -->
                </state>

                <state name="DONE" class="ConstructibleState" isPreviewState="true"/>
            </states>

            <transitions>
                <transition from="SETUP"       to="BUILDING_1" />
                <transition from="BUILDING_1"  to="BUILDING_2" />
                <transition from="BUILDING_2"  to="BUILDING_3" />
                <transition from="BUILDING_3"  to="BUILDING_4" />
                <transition from="BUILDING_4"  to="BUILDING_5" />
                <transition from="BUILDING_5"  to="BUILDING_6" />
                <transition from="BUILDING_6"  to="BUILDING_7" />
                <transition from="BUILDING_7"  to="BUILDING_8" />
                <transition from="BUILDING_8"  to="BUILDING_9" />
                <transition from="BUILDING_9"  to="BUILDING_10" />
                <transition from="BUILDING_10" to="FINALIZE" />
                <transition from="FINALIZE"    to="DONE" />
            </transitions>
        </stateMachine>

