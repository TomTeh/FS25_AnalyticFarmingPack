<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="decoObject" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_streetLight</name>
        <functions>
            <function>$l10n_function_decoLight</function>
        </functions>
        <image>placeables/lights/store_streetLight.png</image>
        <price>500</price>
        <dailyUpkeep>0</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDENERGY</brand>
        <species>placeable</species>
        <category>floodLighting</category>
        <brush>
            <type>placeable</type>
            <category>decoration</category>
            <tab>lights</tab>
        </brush>
        <vertexBufferMemoryUsage>17152</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>4352</indexBufferMemoryUsage>
        <textureMemoryUsage>2162688</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/lights/streetLight.i3d</filename>
        <canBeRenamed>false</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testArea1Start" endNode="testArea1End" />
            <testArea startNode="testArea2Start" endNode="testArea2End" />
        </testAreas>

        <sounds>
            <place template="smallImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="false" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
        </levelAreas>
    </leveling>

    <indoorAreas/>

    <tipOcclusionUpdateAreas/>

    <ai>
        <updateAreas>
            <updateArea startNode="testArea1Start" endNode="testArea1End" />
        </updateAreas>
    </ai>

    <i3dMappings>
        <i3dMapping id="clearLevelAreaStart1" node="0>1|0" />
        <i3dMapping id="clearLevelAreaWidth1" node="0>1|0|0" />
        <i3dMapping id="clearLevelAreaHeight1" node="0>1|0|1" />
        <i3dMapping id="testArea1Start" node="0>2|0" />
        <i3dMapping id="testArea1End" node="0>2|0|0" />
        <i3dMapping id="testArea2Start" node="0>2|1" />
        <i3dMapping id="testArea2End" node="0>2|1|0" />
    </i3dMappings>
</placeable>
