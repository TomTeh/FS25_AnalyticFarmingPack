<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_cementFactory</name>
        <functions>
            <function>$l10n_function_productionPoint</function>
        </functions>
        <image>placeables/productionPoints/cementFactory/store_cementFactory.png</image>
        <price>295000</price>
        <dailyUpkeep>110</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-12" cameraYRot="30" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>1752320</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>433408</indexBufferMemoryUsage>
        <textureMemoryUsage>18022400</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/productionPoints/cementFactory/cementFactory.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
            <testArea startNode="testAreaStart2" endNode="testAreaEnd2" />
            <testArea startNode="testAreaStart3" endNode="testAreaEnd3" />
        </testAreas>

        <sounds>
            <place template="largeImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
        <clearArea startNode="clearLevelAreaStart2" widthNode="clearLevelAreaWidth2" heightNode="clearLevelAreaHeight2"/>
        <clearArea startNode="clearLevelAreaStart3" widthNode="clearLevelAreaWidth3" heightNode="clearLevelAreaHeight3"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30" >
        <levelAreas>
            <levelArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1" groundType="concrete"/>
            <levelArea startNode="clearLevelAreaStart2" widthNode="clearLevelAreaWidth2" heightNode="clearLevelAreaHeight2" groundType="concrete"/>
            <levelArea startNode="clearLevelAreaStart3" widthNode="clearLevelAreaWidth3" heightNode="clearLevelAreaHeight3" groundType="concrete"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1" />
        <indoorArea startNode="indoorAreaStart2" widthNode="indoorAreaWidth2" heightNode="indoorAreaHeight2" />
        <indoorArea startNode="indoorAreaStart3" widthNode="indoorAreaWidth3" heightNode="indoorAreaHeight3" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="playerTriggerMarker" filename="placeables/sharedAssets/marker/markerIconProductionPoint.i3d" adjustToGround="true" />
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconUnload.i3d" adjustToGround="true" />
        <triggerMarker node="warningStripes"/>
    </triggerMarkers>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="unloadTriggerMarker" teleportNode="playerTriggerMarker" />
    </hotspots>

    <lights>
        <group weatherRequiredFlags="NIGHT" />

        <sharedLight filename="placeables/sharedAssets/lights/warehouseWallLamp.xml" linkNode="warehouseWallLamp01" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/warehouseWallLamp.xml" linkNode="warehouseWallLamp02" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/warehouseWallLamp.xml" linkNode="warehouseWallLamp03" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/warehouseWallLamp.xml" linkNode="warehouseWallLamp04" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/warehouseWallLamp.xml" linkNode="warehouseWallLamp05" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/warehouseWallLamp.xml" linkNode="warehouseWallLamp06" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/warehouseWallLamp.xml" linkNode="warehouseWallLamp07" groupIndex="1"/>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight01" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 40" />
        </sharedLight>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight02" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 50" />
        </sharedLight>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight03" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 50" />
        </sharedLight>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight04" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 50" />
        </sharedLight>
        <sharedLight filename="placeables/sharedAssets/lights/floodLight.xml" linkNode="floodLight05" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 90" />
        </sharedLight>

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
            </high>
        </realLights>
    </lights>

    <infoTrigger triggerNode="infoTrigger" />

    <productionPoint>
        <productions sharedThroughputCapacity="false">
            <production id="cementBags" name="$l10n_fillType_cementBags" cyclesPerHour="2" costsPerActiveHour="2">
                <inputs>
                    <input fillType="LIME" amount="525" />
                    <input fillType="CLAY" amount="150" />
                    <input fillType="BLASTFURNACESLAG" amount="75" />
                </inputs>
                <outputs>
                    <output fillType="CEMENT" amount="375" />
                </outputs>
            </production>
            <production id="cementBrick" name="$l10n_fillType_cementBrick" cyclesPerHour="2" costsPerActiveHour="4">
                <inputs>
                    <input fillType="GRAVEL" amount="488" />
                    <input fillType="LIME" amount="70" />
                    <input fillType="CLAY" amount="20" />
                    <input fillType="BLASTFURNACESLAG" amount="10" />
                </inputs>
                <outputs>
                    <output fillType="CEMENTBRICKS" amount="275" />
                </outputs>
            </production>
            <production id="roofPlate" name="$l10n_fillType_roofPlate" cyclesPerHour="2" costsPerActiveHour="5">
                <inputs>
                    <input fillType="GRAVEL" amount="360" />
                    <input fillType="SAND" amount="100" />
                    <input fillType="LIME" amount="50" />
                    <input fillType="CLAY" amount="14" />
                    <input fillType="BLASTFURNACESLAG" amount="7" />
                </inputs>
                <outputs>
                    <output fillType="ROOFPLATES" amount="200" />
                </outputs>
            </production>
            <production id="clayBrick" name="$l10n_fillType_clayBrick" cyclesPerHour="2" costsPerActiveHour="5">
                <inputs>
                    <input fillType="CLAY" amount="180" />
                    <input fillType="SAND" amount="360" />
                    <input fillType="LIME" amount="60" />
                </inputs>
                <outputs>
                    <output fillType="CLAYBRICKS" amount="240" />
                </outputs>
            </production>
            <production id="clayRoofPlate" name="$l10n_fillType_clayRoofPlate" cyclesPerHour="2" costsPerActiveHour="5">
                <inputs>
                    <input fillType="CLAY" amount="320" />
                    <input fillType="SAND" amount="130" />
                </inputs>
                <outputs>
                    <output fillType="CLAYROOFPLATES" amount="180" />
                </outputs>
            </production>
        </productions>

        <sellingStation node="sellingStation" supportsExtension="false" hideFromPricesMenu="true" allowMissions="false">
            <unloadTrigger exactFillRootNode="unloadTrigger" aiNode="unloadTriggerAINode" fillTypes="LIME CLAY SAND GRAVEL BLASTFURNACESLAG" />
            <palletTrigger triggerNode="palletTrigger" aiNode="unloadTriggerAINode" fillTypes="LIME CLAY SAND GRAVEL BLASTFURNACESLAG" />
        </sellingStation>

        <palletSpawner>
            <spawnPlaces>
                <spawnPlace startNode="palletAreaStart01" endNode="palletAreaEnd01"/>
                <spawnPlace startNode="palletAreaStart02" endNode="palletAreaEnd02"/>
                <spawnPlace startNode="palletAreaStart03" endNode="palletAreaEnd03"/>
                <spawnPlace startNode="palletAreaStart04" endNode="palletAreaEnd04"/>
            </spawnPlaces>
        </palletSpawner>		

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="LIME"             capacity="105000" />
            <capacity fillType="CLAY"             capacity="100000" />
            <capacity fillType="SAND"             capacity="90000" />
            <capacity fillType="GRAVEL"           capacity="130000" />
            <capacity fillType="BLASTFURNACESLAG" capacity="60000" />
            <capacity fillType="CEMENT"           capacity="50000" />
            <capacity fillType="CEMENTBRICKS"     capacity="50000" />
            <capacity fillType="ROOFPLATES"       capacity="50000" />
            <capacity fillType="CLAYBRICKS"       capacity="50000" />
            <capacity fillType="CLAYROOFPLATES"   capacity="50000" />

            <fillPlane node="fillPlaneClay" fillType="CLAY" minY="-1.87" maxY="0" changeVisibility="true" />
            <fillPlane node="fillPlaneSand" fillType="SAND" minY="-1.86" maxY="0" changeVisibility="true" />
            <fillPlane node="fillPlaneGravel" fillType="GRAVEL" minY="-2.355" maxY="0" changeVisibility="true" />
            <fillPlane node="fillPlaneBlastFurnaceSlag" fillType="BLASTFURNACESLAG" minY="-1.925" maxY="0" changeVisibility="true" />
        </storage>

        <playerTrigger node="playerTrigger" />

        <effectNodes>
            <effectNode effectNode="smokeEffectShape01" effectClass="ParticleEffect" particleType="SMOKE" scale="0.1 0.5 0.1" emitCountScale="30"/>
            <effectNode effectNode="smokeEffectChimneyShape01" effectClass="ParticleEffect" particleType="SMOKE_CHIMNEY" emitCountScale="75"/>
            <effectNode effectNode="smokeEffectChimneyShape02" effectClass="ParticleEffect" particleType="SMOKE_CHIMNEY" emitCountScale="75"/>
        </effectNodes>

        <sounds>
            <idle   template="grainMillIdle" linkNode="soundNode" pitchScale="1.2"/>
            <active template="grainMillWork" linkNode="soundNode" pitchScale="1.2"/>
        </sounds>
    </productionPoint>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="propsNode" filename="placeables/sharedAssets/propsBuilding/propsBuilding_cementFactory.i3d" />
        <dynamicallyLoadedPart node="0" linkNode="propsNode" filename="placeables/sharedAssets/props/props_cementFactory.i3d" />
