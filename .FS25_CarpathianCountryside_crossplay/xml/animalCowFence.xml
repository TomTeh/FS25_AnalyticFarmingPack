<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="newFence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_animalCowFence</name>
        <functions>
            <function>$l10n_function_decoration</function>
        </functions>
        <image>placeables/fences/store_animalCowFence.png</image>
        <price>150</price>
        <dailyUpkeep>0</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDFARMING</brand>
        <species>PLACEABLE</species>
        <category>fences</category>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>

        <brush>
            <type>newFence</type>
            <category>decoration</category>
            <tab>newFences</tab>
        </brush>

        <storeIconRendering>
            <settings centerIcon="true"/>
            <objectBundle>
                <object filename="placeables/fences/animalCowFence.i3d">
                    <!-- poles -->
                    <node node="1|0" translation="0 0 0" rotation="0 90 0" scale="1 1 1"/>
                    <node node="1|1" translation="4 0 0" rotation="0 90 0" scale="1 1 1"/>
                    <node node="1|2" translation="8 0 0" rotation="0 90 0" scale="1 1 1"/>

                    <!-- panels -->
                    <node node="2|0" translation="0 0 0" rotation="0 90 0" scale="1 1 1"/>
                    <node node="2|1" translation="4 0 0" rotation="0 90 0" scale="1 1 1"/>
                </object>
            </objectBundle>
        </storeIconRendering>
        <vertexBufferMemoryUsage>384256</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>103168</indexBufferMemoryUsage>
        <textureMemoryUsage>1048576</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/fences/animalCowFence.i3d</filename>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <sounds>
            <place template="fenceMetalImp" />
            <destroy template="destroyFence" />
        </sounds>
    </placement>

    <fence>
        <segment id="SEGMENT" class="FenceSegment" maxVerticalAngle="45">
            <poles>
                <pole node="pole01" radius="0.0"/>
                <pole node="pole02" radius="0.0"/>
                <pole node="pole03" radius="0.0"/>
                <pole node="pole04" radius="0.0"/>
            </poles>
            <panels maxScale="1.2">
                <panel node="panel01" length="4" />
                <panel node="panel02" length="4" />
                <panel node="panel03" length="4" />
                <panel node="panel04" length="4" />
            </panels>
        </segment>
        <segment id="SEGMENT2m" class="FenceSegment" maxVerticalAngle="45">
            <poles>
                <pole node="pole01" radius="0.0"/>
                <pole node="pole02" radius="0.0"/>
                <pole node="pole03" radius="0.0"/>
                <pole node="pole04" radius="0.0"/>
            </poles>
            <panels maxScale="1.2">
                <panel node="panel05" length="2" />
                <panel node="panel06" length="2" />
            </panels>
        </segment>
        <segment id="GATE4m" class="FenceGate" maxVerticalAngle="45">
            <gate node="gate4m" length="4">
                <animatedObject saveId="animalCowFence_gate4m" useAIBlockingRegion="true" >
                    <animation duration="2.0">
                        <part node="gate4mChainLock">
                            <keyFrame time="0.0" visibility="true"/>
                            <keyFrame time="0.01" visibility="false"/>
                        </part>
                        <part node="gate4mOpenA">
                            <keyFrame time="0.0" rotation="0 0 0"/>
                            <keyFrame time="1.0" rotation="0 -140 0"/>
                        </part>
                    </animation>
                    <controls triggerNode="gate4mTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
                    <sounds>
                        <moving linkNode="gate4mSoundNode" template="fenceMetalLoop" />
                        <posEnd linkNode="gate4mSoundNode" template="fenceMetalOpen" />
                        <negEnd linkNode="gate4mSoundNode" template="fenceMetalClose" />
                    </sounds>
                </animatedObject>
            </gate>
        </segment>
        <segment id="GATE8m" class="FenceGate" maxVerticalAngle="45">
            <gate node="gate8m" length="8">
                <animatedObject saveId="animalPigFence_gate8m" >
                    <animation duration="2.5">
                        <part node="gate8mChainLock">
                            <keyFrame time="0.0" visibility="true"/>
                            <keyFrame time="0.01" visibility="false"/>
                        </part>
                        <part node="gate8mOpenA">
                            <keyFrame time="0.0" rotation="0 0 0"/>
                            <keyFrame time="1.0" rotation="0 -140 0"/>
                        </part>
                        <part node="gate8mOpenB">
                            <keyFrame time="0.0" rotation="0 0 0"/>
                            <keyFrame time="1.0" rotation="0 140 0"/>
                        </part>
                    </animation>
                    <controls triggerNode="gate8mTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
                    <sounds>
                        <moving linkNode="gate8mSoundNode" template="fenceMetalLoop" />
                        <posEnd linkNode="gate8mSoundNode" template="fenceMetalOpen" />
                        <negEnd linkNode="gate8mSoundNode" template="fenceMetalClose" />
                    </sounds>
                </animatedObject>
            </gate>
        </segment>
        <segment id="GRATE4m" class="FenceGate" maxVerticalAngle="45">
            <gate node="grate4m" length="4">
            </gate>
        </segment>
    </fence>

    <i3dMappings>
        <i3dMapping id="gate4m" node="0>0" />
        <i3dMapping id="gate4mOpenA" node="0>0|2" />
        <i3dMapping id="gate4mChainLock" node="0>0|3" />
        <i3dMapping id="gate4mTrigger" node="0>0|4" />
        <i3dMapping id="gate4mSoundNode" node="0>0|5" />
        <i3dMapping id="gate8m" node="0>1" />
        <i3dMapping id="gate8mOpenA" node="0>1|2" />
        <i3dMapping id="gate8mOpenB" node="0>1|3" />
        <i3dMapping id="gate8mChainLock" node="0>1|4" />
        <i3dMapping id="gate8mTrigger" node="0>1|5" />
        <i3dMapping id="gate8mSoundNode" node="0>1|6" />
        <i3dMapping id="grate4m" node="0>2" />
        <i3dMapping id="pole01" node="1>0" />
        <i3dMapping id="pole02" node="1>1" />
        <i3dMapping id="pole03" node="1>2" />
        <i3dMapping id="pole04" node="1>3" />
        <i3dMapping id="panel01" node="2>0" />
        <i3dMapping id="panel02" node="2>1" />
        <i3dMapping id="panel03" node="2>2" />
        <i3dMapping id="panel04" node="2>3" />
        <i3dMapping id="panel05" node="2>4" />
        <i3dMapping id="panel06" node="2>5" />
    </i3dMappings>
</placeable>
