                    </animation>
                    <controls triggerNode="gate1_5mTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
                    <sounds>
                        <moving linkNode="gate1_5mSoundNode" template="fenceLoop" />
