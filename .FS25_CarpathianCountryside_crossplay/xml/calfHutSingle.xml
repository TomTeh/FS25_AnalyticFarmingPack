<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="mapCC_calfHut" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_calfHutSingle</name>
        <image>placeables/animalHusbandry/store_calfHutSingle.png</image>
        <price>500</price>
        <functions>
            <function>$l10n_function_calfHut</function>
        </functions>
        <lifetime>1000</lifetime>
        <dailyUpkeep>5</dailyUpkeep>
        <rotation>0</rotation>
        <brand>LIZARDFARMING</brand>
        <species>placeable</species>
        <category>animalpens</category>
        <brush>
            <type>placeable</type>
            <category>animals</category>
            <tab>cows</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-20" cameraYRot="50" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>105984</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>30976</indexBufferMemoryUsage>
        <textureMemoryUsage>5111808</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/animalHusbandry/calfHutSingle.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
            <placeLayered template="cowLayer" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart1" widthNode="clearAreaWidth1" heightNode="clearAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart1" widthNode="levelAreaWidth1" heightNode="levelAreaHeight1" groundType="concrete"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="markerAnimals" filename="placeables/sharedAssets/marker/markerIconCowInOut.i3d" adjustToGround="false" />
        <triggerMarker node="markerFood" filename="$data/shared/assets/marker/markerIconFood.i3d" adjustToGround="false" />
        <triggerMarker node="markerWater" filename="$data/shared/assets/marker/markerIconWater.i3d" adjustToGround="false" />
        <triggerMarker node="markerFence" filename="$data/shared/assets/marker/markerIconExclamationMark.i3d" adjustToGround="false" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="COW" linkNode="mapPosition" teleportNode="teleportNode" />
    </hotspots>

    <animatedObjects>
        <animatedObject saveId="calfHutSingle_fence" >
            <animation duration="2">
                <part node="fenceTransform">
                    <keyFrame time="0.2" translation="0 0 0" rotation="0 0 0" />
                    <keyFrame time="1.0" translation="0 -0.13 -1.76" rotation="-2.55 0 0" />
                </part>
                <part node="railingRight">
                    <keyFrame time="0.0" translation="0.91 0 0.9" rotation="0 0 0" />
                    <keyFrame time="0.2" translation="1 0 0.9" rotation="0 -2.16 0" />
                </part>
                <part node="railingLeft">
                    <keyFrame time="0.0" translation="-0.91 0 0.9" rotation="0 0 0" />
                    <keyFrame time="0.2" translation="-1 0 0.9" rotation="0 2.16 0" />
                </part>
                <part node="markers">
                    <keyFrame time="0.0" visibility="true" />
                    <keyFrame time="0.01" visibility="false" />
                </part>
            </animation>
            <controls triggerNode="trigger" posAction="ACTIVATE_HANDTOOL" posText="action_moveFenceClean" negText="action_moveFenceBack" />
            <sounds>
                <moving linkNode="soundNode" template="metalDoorsLoop" volumeScale="0.4" />
                <posEnd linkNode="soundNode" template="fenceMetalOpen" volumeScale="0.2" />
                <negEnd linkNode="soundNode" template="fenceMetalOpen" volumeScale="0.2" />
            </sounds>
        </animatedObject>
    </animatedObjects>

    <infoTrigger triggerNode="infoTrigger" />

    <husbandry saveId="Animals_COW" hasStatistics="false">
        <storage node="storageNode" fillTypes="STRAW WATER MANURE" isExtension="false">
            <capacity fillType="STRAW" capacity="360" />
            <capacity fillType="WATER" capacity="80" />
            <capacity fillType="MANURE" capacity="600" />

            <fillPlane node="manurePlane" fillType="MANURE" changeVisibility="true" minY="-0.175" maxY="0.0"/>
        </storage>

        <unloadingStation supportsExtension="false" storageRadius="1" hideFromPricesMenu="true">
            <unloadTrigger exactFillRootNode="exactFillRootNodeStraw" fillTypes="STRAW" />
            <baleTrigger triggerNode="baleTriggerStraw" fillTypes="STRAW" />
            <palletTrigger triggerNode="palletTriggerStraw" fillTypes="STRAW"/>
            <unloadTrigger exactFillRootNode="exactFillRootNodeWater" fillTypes="WATER" />
            <palletTrigger triggerNode="palletTriggerWater" fillTypes="WATER"/>
        </unloadingStation>

        <loadingStation supportsExtension="false" storageRadius="1">
            <loadTrigger triggerNode="loadTriggerManure" fillTypes="MANURE" autoStart="true" fillLitersPerSecond="250"/>
        </loadingStation>

        <animals type="COW" maxNumAnimals="1">
            <navigation rootNode="navMeshNode" filename="placeables/animalHusbandry/calfHutSingleNavigationMesh.i3d" />
            <loadingTrigger node="animalLoadTrigger" />
        </animals>

        <food capacity="320" >
            <dynamicFoodPlane node="fillVolume" defaultFillType="FORAGE"/>
            <unloadTrigger exactFillRootNode="exactFillRootNodeFood" />
            <baleTrigger triggerNode="baleTriggerFood"/>
            <palletTrigger triggerNode="palletTriggerFood"/>
        </food>

        <water automaticWaterSupply="false" >
            <waterPlane node="waterPlane" minY="0.305" maxY="0.37" changeVisibility="true" />
        </water>

        <straw>
            <manure factor="1.5" />
            <strawPlane node="strawPlane" minY="-0.155" maxY="0.0" changeVisibility="true" />
        </straw>
    </husbandry>

    <i3dMappings>
        <i3dMapping id="fenceTransform" node="0>1|0" />
        <i3dMapping id="railingFront" node="0>1|0|0" />
        <i3dMapping id="fillVolume" node="0>1|0|0|1|1" />
        <i3dMapping id="foodPlane" node="0>1|0|0|1|2" />
        <i3dMapping id="waterPlane" node="0>1|0|0|2|1" />
        <i3dMapping id="railingRight" node="0>1|0|1" />
        <i3dMapping id="railingLeft" node="0>1|0|2" />
        <i3dMapping id="trigger" node="0>1|1" />
        <i3dMapping id="soundNode" node="0>1|2" />
        <i3dMapping id="markerFence" node="0>1|3" />
        <i3dMapping id="teleportNode" node="0>2" />
        <i3dMapping id="mapPosition" node="0>3" />
        <i3dMapping id="storageNode" node="0>4" />
        <i3dMapping id="animalLoadTrigger" node="0>5" />
        <i3dMapping id="food" node="0>6" />
        <i3dMapping id="exactFillRootNodeFood" node="0>6|0" />
        <i3dMapping id="baleTriggerFood" node="0>6|1" />
        <i3dMapping id="palletTriggerFood" node="0>6|2" />
        <i3dMapping id="straw" node="0>7" />
        <i3dMapping id="exactFillRootNodeStraw" node="0>7|0" />
        <i3dMapping id="baleTriggerStraw" node="0>7|1" />
        <i3dMapping id="palletTriggerStraw" node="0>7|2" />
        <i3dMapping id="strawPlane" node="0>7|3" />
        <i3dMapping id="water" node="0>8" />
        <i3dMapping id="exactFillRootNodeWater" node="0>8|0" />
        <i3dMapping id="palletTriggerWater" node="0>8|1" />
        <i3dMapping id="manure" node="0>9" />
        <i3dMapping id="manurePlane" node="0>9|0" />
        <i3dMapping id="loadTriggerManure" node="0>9|1" />
        <i3dMapping id="navMesh" node="0>10" />
        <i3dMapping id="navMeshNode" node="0>10|0" />
        <i3dMapping id="markers" node="0>11" />
        <i3dMapping id="markerAnimals" node="0>11|0" />
        <i3dMapping id="markerFood" node="0>11|1" />
        <i3dMapping id="markerWater" node="0>11|2" />
        <i3dMapping id="infoTrigger" node="0>12" />
        <i3dMapping id="clearAreaStart1" node="0>13|0" />
        <i3dMapping id="clearAreaWidth1" node="0>13|0|0" />
        <i3dMapping id="clearAreaHeight1" node="0>13|0|1" />
        <i3dMapping id="levelAreaStart1" node="0>14|0" />
        <i3dMapping id="levelAreaWidth1" node="0>14|0|0" />
        <i3dMapping id="levelAreaHeight1" node="0>14|0|1" />
        <i3dMapping id="indoorAreaStart1" node="0>15|0" />
        <i3dMapping id="indoorAreaWidth1" node="0>15|0|0" />
        <i3dMapping id="indoorAreaHeight1" node="0>15|0|1" />
        <i3dMapping id="tipOcclusionUpdateAreaStart1" node="0>16|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd1" node="0>16|0|0" />
        <i3dMapping id="testAreaStart1" node="0>17|0" />
        <i3dMapping id="testAreaEnd1" node="0>17|0|0" />
    </i3dMappings>
</placeable>
