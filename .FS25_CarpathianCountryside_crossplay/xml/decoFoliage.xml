        </foliageState>
        <!-- lavenderFlowers -->
        <foliageState name="lavenderFlower" width="1.3" height="1.8" numBlocksPerUnit="3.0">
            <foliageShape>
                <foliageLod blockShape="6>0|0" />
                <foliageLod blockShape="6>1|0" />
            </foliageShape>
            <foliageShape>
                <foliageLod blockShape="6>0|1" />
                <foliageLod blockShape="6>1|1" />
            </foliageShape>
            <foliageShape>
                <foliageLod blockShape="6>0|2" />
                <foliageLod blockShape="6>1|2" />
            </foliageShape>
        </foliageState>
        <!-- yellowFlower -->
        <foliageState name="yellowFlower" width="1.3" height="1.3" numBlocksPerUnit="4.0">
            <foliageShape>
                <foliageLod blockShape="7>0|0" />
                <foliageLod blockShape="7>1|0" />
            </foliageShape>
            <foliageShape>
                <foliageLod blockShape="7>0|1" />
                <foliageLod blockShape="7>1|1" />
            </foliageShape>
            <foliageShape>
                <foliageLod blockShape="7>0|2" />
                <foliageLod blockShape="7>1|2" />
            </foliageShape>
        </foliageState>
        <!-- blueFlower -->
        <foliageState name="blueFlower" width="1.3" height="1.3" numBlocksPerUnit="4.0">
            <foliageShape>
                <foliageLod blockShape="8>0|0" />
                <foliageLod blockShape="8>1|0" />
            </foliageShape>
            <foliageShape>
