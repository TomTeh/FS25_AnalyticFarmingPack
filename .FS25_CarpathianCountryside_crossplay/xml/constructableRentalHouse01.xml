    <storeData>
        <name>$l10n_constructable_rentalHouse01</name>
        <functions>
            <function>$l10n_function_buildableFarmHouse</function>
            <function>$l10n_function_rentalHouse</function>
            <function>$l10n_function_rentalHouse01Income</function>
        </functions>
        <image>placeables/constructibles/store_constructableRentalHouse01.png</image>
        <price>1000</price>
        <dailyUpkeep>70</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>farmhouses</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>constructibles</tab>
        </brush>

        <storeIconRendering>
            <objectBundle>
                <object filename="placeables/constructibles/constructableResidentialBuilding01.i3d">
                    <node node="0|10|0|0"/>
                </object>
            </objectBundle>
        </storeIconRendering>
        <vertexBufferMemoryUsage>1564416</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>430592</indexBufferMemoryUsage>
        <textureMemoryUsage>9109504</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/constructibles/constructableResidentialBuilding01.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart01Preplaced" endNode="testAreaEnd01Preplaced" />
        </testAreas>

        <sounds>
            <place template="buildableImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
        <clearArea startNode="clearAreaStart02" widthNode="clearAreaWidth02" heightNode="clearAreaHeight02"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30" >
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" />
            <levelArea startNode="levelAreaStart02" widthNode="levelAreaWidth02" heightNode="levelAreaHeight02" />
        </levelAreas>
        <paintAreas>
            <paintArea startNode="paintAreaStart01" widthNode="paintAreaWidth01" heightNode="paintAreaHeight01" />
        </paintAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01" />
        <indoorArea startNode="indoorAreaStart02" widthNode="indoorAreaWidth02" heightNode="indoorAreaHeight02" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="unloadTriggerMarker" filename="$data/shared/assets/marker/markerIconPallet.i3d" adjustToGround="true" />
        <!-- <triggerMarker node="sleepTriggerMarker" filename="$data/shared/assets/marker/markerIconSleep.i3d" adjustToGround="false"/> -->
        <!-- <triggerMarker node="wardrobeTriggerMarker" filename="$data/shared/assets/marker/markerIconWardrobe.i3d" adjustToGround="false"/> -->
        <triggerMarker node="warningStripes"/>
    </triggerMarkers>

    <hotspots>
        <hotspot type="UNLOADING_PALLET" linkNode="unloadTriggerMarker" teleportNode="unloadTriggerMarker" />
        <!-- <hotspot type="FARM"             linkNode="0>" teleportNode="spawnPoint" /> -->
    </hotspots>

    <!-- <farmhouse spawnNode="spawnPoint" isFinalized="false">
        <sleeping triggerNode="sleepingTrigger" cameraNode="sleepCamera"/>
    </farmhouse> -->

    <!-- <wardrobe triggerNode="wardrobeTrigger"/> -->

    <animatedObjects>
        <animatedObject saveId="constructibleRentalHouse01_door01" >
            <animation duration="2.5">
                <part node="door01Left">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="0.75" rotation="0 -90 0"/>
                </part>
                <part node="door01Right">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="0.75" rotation="0 90 0"/>
                </part>
            </animation>
            <controls triggerNode="door01Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds>
                <moving linkNode="door01Left" template="woodDoorSqueaksSmall" pitchScale="0.8"/>
                <posEnd linkNode="door01Left" template="woodDoorOpen" />
                <negEnd linkNode="door01Left" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>

        <animatedObject saveId="constructibleRentalHouse01_door02" >
            <animation duration="2.5">
                <part node="door02Left">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="0.75" rotation="0 -90 0"/>
                </part>
                <part node="door02Right">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="0.75" rotation="0 90 0"/>
                </part>
            </animation>
            <controls triggerNode="door02Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds>
                <moving linkNode="door02Left" template="woodDoorSqueaksSmall" pitchScale="0.8"/>
                <posEnd linkNode="door02Left" template="woodDoorOpen" />
                <negEnd linkNode="door02Left" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>

        <animatedObject saveId="constructibleRentalHouse01_door03" >
            <animation duration="2.5">
                <part node="door03">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -90 0"/>
                </part>
            </animation>
            <controls triggerNode="door03Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds>
                <moving linkNode="door03" template="woodDoorSqueaksSmall" pitchScale="0.8"/>
                <posEnd linkNode="door03" template="woodDoorOpen" />
                <negEnd linkNode="door03" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>

        <animatedObject saveId="constructibleRentalHouse01_door04" >
            <animation duration="2.5">
                <part node="door04">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 -90 0"/>
                </part>
            </animation>
            <controls triggerNode="door04Trigger" posAction="ACTIVATE_HANDTOOL" posText="action_openDoor" negText="action_closeDoor" />
            <sounds>
                <moving linkNode="door04" template="woodDoorSqueaksSmall" pitchScale="0.8"/>
                <posEnd linkNode="door04" template="woodDoorOpen" />
                <negEnd linkNode="door04" template="woodDoorCloseRandom" />
            </sounds>
        </animatedObject>
    </animatedObjects>

    <infoTrigger triggerNode="infoTrigger"/>

    <incomePerHour>104</incomePerHour>

    <constructible>
        <stateMachine>
            <states>
                <state name="SETUP" class="ConstructibleStateBuilding" >
                    <toggleMesh node="LOD1"                              active="false" updatePhysics="false"/>
                    <toggleMesh node="baseConcrete"                      active="false" updatePhysics="false"/>
                    <toggleMesh node="baseConcreteFloor"                 active="false" updatePhysics="false"/>
                    <!-- <toggleMesh node="farmhouseFeatures"                 active="false" updatePhysics="true"/> -->
                    <!-- <toggleMesh node="wardrobe"                          active="false" updatePhysics="true"/> -->
                    <toggleMesh node="phase09"                           active="false" updatePhysics="false"/>
                    <toggleMesh node="doors"                             active="false" updatePhysics="false"/>
                    <toggleMesh node="propsFinishedNode"                 active="false" updatePhysics="true"/>
                    <toggleMesh node="snow"                              active="false" updatePhysics="false"/>
                    <toggleMesh node="icicles"                           active="false" updatePhysics="false"/>
                    <toggleHotspot index="1" isVisible="true" />
                    <!-- <toggleHotspot index="2" isVisible="false" /> -->

                    <input fillType="WOODBEAM" amount="1000" usagePerHour="250"/>
                    <input fillType="PLANKS"   amount="1000" usagePerHour="250"/>
                    <input fillType="BOARDS"   amount="1000" usagePerHour="250"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_1" class="ConstructibleStateBuilding" >
                    <toggleMesh node="baseConcrete" active="true" updatePhysics="false"/>

                    <input fillType="GRAVEL" amount="15000" usagePerHour="1000"/>
                    <input fillType="CEMENT" amount="4000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_2" class="ConstructibleStateBuilding" >
                    <mesh node="phase01" indexMin="0" indexMax="22" />

                    <input fillType="WOODBEAM"     amount="1000" usagePerHour="250"/>
                    <input fillType="PLANKS"       amount="2000" usagePerHour="250"/>
                    <input fillType="CEMENTBRICKS" amount="8000" usagePerHour="500"/>
                    <input fillType="GRAVEL"       amount="3000" usagePerHour="500"/>
                    <input fillType="CEMENT"       amount="1000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_3" class="ConstructibleStateBuilding" >
                    <toggleMesh node="baseConcreteFloor" active="true" updatePhysics="false"/>

                    <input fillType="GRAVEL" amount="10000" usagePerHour="1000"/>
                    <input fillType="CEMENT" amount="3000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_4" class="ConstructibleStateBuilding" >
                    <mesh node="phase02" indexMin="0" indexMax="26" />

                    <input fillType="WOODBEAM"     amount="4000" usagePerHour="500"/>
                    <input fillType="CEMENTBRICKS" amount="6000" usagePerHour="500"/>
                    <input fillType="GRAVEL"       amount="2500" usagePerHour="500"/>
                    <input fillType="CEMENT"       amount="500" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_5" class="ConstructibleStateBuilding" >
                    <mesh node="phase03" indexMin="0" indexMax="46" />

                    <input fillType="CHIPWOODBOARDS" amount="7000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_6" class="ConstructibleStateBuilding" >
                    <mesh node="phase04" indexMin="0" indexMax="20" />

                    <input fillType="CLAYROOFPLATES" amount="7000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_7" class="ConstructibleStateBuilding" >
                    <toggleMesh node="snow"                              active="true" updatePhysics="false"/>
                    <mesh node="phase05" indexMin="0" indexMax="80" />

                    <input fillType="SAND"   amount="6000" usagePerHour="500"/>
                    <input fillType="CEMENT" amount="1500" usagePerHour="500"/>
                    <input fillType="PLANKS"     amount="2000" usagePerHour="500"/>
                    <input fillType="FLOORTILES" amount="4000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_8" class="ConstructibleStateBuilding" >
                    <mesh node="phase06" indexMin="0" indexMax="11" />

                    <input fillType="PLANKS" amount="2000" usagePerHour="500"/>
                    <input fillType="BOARDS" amount="1000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_9" class="ConstructibleStateBuilding" >
                    <mesh node="phase07" indexMin="0" indexMax="7" />

                    <input fillType="BOARDS" amount="1000" usagePerHour="250"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_10" class="ConstructibleStateBuilding" >
                    <mesh node="phase08" indexMin="0" indexMax="7" />

                    <input fillType="CEMENTBRICKS" amount="2000" usagePerHour="500"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_11" class="ConstructibleStateBuilding" >
                    <toggleMesh  node="phase09"  active="true"/>

                    <input fillType="FURNITURE" amount="5000" usagePerHour="500"/>
                    <input fillType="CHAIR"     amount="2000" usagePerHour="250"/>
                    <input fillType="TABLE"     amount="2000" usagePerHour="250"/>
                    <input fillType="ARMOIRE"   amount="2000" usagePerHour="250"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="BUILDING_12" class="ConstructibleStateBuilding" >
                    <mesh node="phase10" indexMin="0" indexMax="2" />

                    <input fillType="BOARDS" amount="1000" usagePerHour="250"/>
                    <input fillType="PLANKS" amount="1000" usagePerHour="250"/>
                    <sounds>
                        <active template="constructibleActive"/>
                    </sounds>
                </state>

                <state name="FINALIZE" class="ConstructibleStateFinalize" >
                    <toggleMesh node="sellingStation"                    active="false" updatePhysics="true"/> <!-- disable unload trigger -->
                    <toggleMesh node="propsConstructionNode"             active="false" updatePhysics="true"/> <!-- disable construction fence -->
                    <toggleMesh node="LOD1"                              active="true"  updatePhysics="true"/> <!-- enable LOD1 -->
                    <!-- <toggleMesh node="farmhouseFeatures"                 active="true"  updatePhysics="true"/> --> <!-- enable farmhouse -->
                    <!-- <toggleMesh node="wardrobe"                          active="true"  updatePhysics="true"/> --> <!-- enable wardrobe -->
                    <toggleMesh node="doors"                             active="true"  updatePhysics="true"/> <!-- enable doors -->
                    <toggleMesh node="infoTrigger"                       active="false" updatePhysics="true"/> <!-- disable info trigger -->
                    <toggleMesh node="propsFinishedNode"                 active="true"  updatePhysics="true"/> <!-- enable propsBuilding -->
                    <toggleMesh node="icicles"                           active="true"  updatePhysics="false"/>
                    <toggleHotspot index="1" isVisible="false" />
                    <!-- <toggleHotspot index="2" isVisible="true" /> -->
                </state>

                <state name="DONE" class="ConstructibleState" isPreviewState="true"/>
            </states>

            <transitions>
                <transition from="SETUP"       to="BUILDING_1" />
                <transition from="BUILDING_1"  to="BUILDING_2" />
                <transition from="BUILDING_2"  to="BUILDING_3" />
                <transition from="BUILDING_3"  to="BUILDING_4" />
                <transition from="BUILDING_4"  to="BUILDING_5" />
                <transition from="BUILDING_5"  to="BUILDING_6" />
                <transition from="BUILDING_6"  to="BUILDING_7" />
                <transition from="BUILDING_7"  to="BUILDING_8" />
                <transition from="BUILDING_8"  to="BUILDING_9" />
                <transition from="BUILDING_9"  to="BUILDING_10" />
                <transition from="BUILDING_10" to="BUILDING_11" />
                <transition from="BUILDING_11" to="BUILDING_12" />
                <transition from="BUILDING_12" to="FINALIZE" />
                <transition from="FINALIZE"    to="DONE" />
            </transitions>
        </stateMachine>

        <sellingStation appearsOnStats="true" supportsExtension="false">
            <unloadTrigger exactFillRootNode="unloadTrigger" aiNode="unloadTriggerAINode" fillTypes="GRAVEL SAND"/>
            <palletTrigger triggerNode="palletTrigger" aiNode="unloadTriggerAINode" fillTypes="WOODBEAM PLANKS BOARDS CEMENT CEMENTBRICKS FURNITURE GRAVEL SAND CLAYROOFPLATES CHIPWOODBOARDS FLOORTILES CHAIR TABLE ARMOIRE" />
        </sellingStation>

        <storage isExtension="false" fillLevelSyncThreshold="50">
            <capacity fillType="WOODBEAM"        capacity="6500" />
            <capacity fillType="PLANKS"          capacity="8500" />
            <capacity fillType="BOARDS"          capacity="4500" />
            <capacity fillType="CEMENT"          capacity="10500" />
            <capacity fillType="CEMENTBRICKS"    capacity="16500" />
            <capacity fillType="FURNITURE"       capacity="5500" />

            <capacity fillType="GRAVEL"          capacity="31000" />
            <capacity fillType="SAND"            capacity="6500" />
            <capacity fillType="CLAYROOFPLATES"  capacity="7500" />
            <capacity fillType="CHIPWOODBOARDS"  capacity="7500" />
            <capacity fillType="FLOORTILES"      capacity="4500" />
            <capacity fillType="CHAIR"           capacity="2500" />
            <capacity fillType="TABLE"           capacity="2500" />
            <capacity fillType="ARMOIRE"         capacity="2500" />
        </storage>
    </constructible>

