<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="workshop" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_repairRamp</name>
        <functions>
            <function>$l10n_function_workshop</function>
        </functions>
        <image>placeables/repairRamp/store_repairRamp.png</image>
        <price>15000</price>
        <dailyUpkeep>5</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDMOTORS</brand>
        <species>placeable</species>
        <category>placeableMisc</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>tools</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-15" cameraYRot="-40" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>201984</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>29952</indexBufferMemoryUsage>
        <textureMemoryUsage>4784128</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/repairRamp/repairRamp.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>

        <sounds>
            <place template="smallImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart1" widthNode="clearAreaWidth1" heightNode="clearAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="3" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart1" widthNode="levelAreaWidth1" heightNode="levelAreaHeight1" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1"/>
        <indoorArea startNode="indoorAreaStart2" widthNode="indoorAreaWidth2" heightNode="indoorAreaHeight2"/>
        <indoorArea startNode="indoorAreaStart3" widthNode="indoorAreaWidth3" heightNode="indoorAreaHeight3"/>
        <indoorArea startNode="indoorAreaStart4" widthNode="indoorAreaWidth4" heightNode="indoorAreaHeight4"/>
        <indoorArea startNode="indoorAreaStart5" widthNode="indoorAreaWidth5" heightNode="indoorAreaHeight5"/>
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="workshopMarker" filename="$data/shared/assets/marker/markerIconWrench.i3d" adjustToGround="false" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="SHOP" linkNode="workshopVehicleTrigger" teleportNode="workshopMarker" />
    </hotspots>

    <workshop>
        <sellingPoint playerTriggerNode="workshopPlayerTrigger" iconNode="workshopMarker" sellTriggerNode="workshopVehicleTrigger" ownWorkshop="true" mobileWorkshop="false" />
    </workshop>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="propsDecoNode" filename="placeables/sharedAssets/props/props_repairRamp.i3d"/>
    </dynamicallyLoadedParts>

    <i3dMappings>
        <i3dMapping id="propsDecoNode" node="0>1|0" />
        <i3dMapping id="propsBordersNode" node="0>1|1" />
        <i3dMapping id="propsPreplacedNode" node="0>1|2" />
        <i3dMapping id="workshopMarker" node="0>2|0" />
        <i3dMapping id="workshopVehicleTrigger" node="0>2|1" />
        <i3dMapping id="workshopPlayerTrigger" node="0>2|2" />
        <i3dMapping id="clearAreaStart1" node="0>3|0" />
        <i3dMapping id="clearAreaWidth1" node="0>3|0|0" />
        <i3dMapping id="clearAreaHeight1" node="0>3|0|1" />
        <i3dMapping id="levelAreaStart1" node="0>4|0" />
        <i3dMapping id="levelAreaWidth1" node="0>4|0|0" />
        <i3dMapping id="levelAreaHeight1" node="0>4|0|1" />
        <i3dMapping id="indoorAreaStart1" node="0>5|0" />
        <i3dMapping id="indoorAreaWidth1" node="0>5|0|0" />
        <i3dMapping id="indoorAreaHeight1" node="0>5|0|1" />
        <i3dMapping id="indoorAreaStart2" node="0>5|1" />
        <i3dMapping id="indoorAreaWidth2" node="0>5|1|0" />
        <i3dMapping id="indoorAreaHeight2" node="0>5|1|1" />
        <i3dMapping id="indoorAreaStart3" node="0>5|2" />
        <i3dMapping id="indoorAreaWidth3" node="0>5|2|0" />
        <i3dMapping id="indoorAreaHeight3" node="0>5|2|1" />
        <i3dMapping id="indoorAreaStart4" node="0>5|3" />
        <i3dMapping id="indoorAreaWidth4" node="0>5|3|0" />
        <i3dMapping id="indoorAreaHeight4" node="0>5|3|1" />
        <i3dMapping id="indoorAreaStart5" node="0>5|4" />
        <i3dMapping id="indoorAreaWidth5" node="0>5|4|0" />
        <i3dMapping id="indoorAreaHeight5" node="0>5|4|1" />
        <i3dMapping id="tipOcclusionUpdateAreaStart1" node="0>6|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd1" node="0>6|0|0" />
        <i3dMapping id="testAreaStart1" node="0>7|0" />
        <i3dMapping id="testAreaEnd1" node="0>7|0|0" />
    </i3dMappings>
</placeable>
