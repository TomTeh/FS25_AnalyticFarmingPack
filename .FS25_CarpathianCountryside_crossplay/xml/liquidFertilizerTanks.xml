            <category>buildings</category>
            <tab>containers</tab>
        </brush>

        <storeIconRendering>
            <settings cameraXRot="-10" cameraYRot="40" advancedBoundingBox="true"/>
        </storeIconRendering>
        <vertexBufferMemoryUsage>267776</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>53504</indexBufferMemoryUsage>
        <textureMemoryUsage>2228224</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
