        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true"  >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>

        <sounds>
            <place template="siloImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart1" widthNode="clearAreaWidth1" heightNode="clearAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="3" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart1" widthNode="levelAreaWidth1" heightNode="levelAreaHeight1" groundType="concrete"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1" />
        <indoorArea startNode="indoorAreaStart2" widthNode="indoorAreaWidth2" heightNode="indoorAreaHeight2" />
        <indoorArea startNode="indoorAreaStart3" widthNode="indoorAreaWidth3" heightNode="indoorAreaHeight3" />
        <indoorArea startNode="indoorAreaStart4" widthNode="indoorAreaWidth4" heightNode="indoorAreaHeight4" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <infoTrigger triggerNode="infoTrigger"/>

    <silo playerActionTrigger="refillPlayerTrigger">
        <loadingStation node="loadingTrigger" supportsExtension="false" >
            <loadTrigger triggerNode="loadingTrigger" aiNode="loadingTriggerAINode" fillLitersPerSecond="200" fillTypes="LIQUIDFERTILIZER HERBICIDE"/>
        </loadingStation>

        <unloadingStation supportsExtension="false" >
            <unloadTrigger exactFillRootNode="exactFillRootNode" aiNode="unloadingStationAINode" fillTypes="LIQUIDFERTILIZER HERBICIDE"/>
        </unloadingStation>

        <storages>
            <storage node="storageNode" fillTypes="LIQUIDFERTILIZER HERBICIDE" capacity="166000" isExtension="false">
                <startFillLevel fillType="LIQUIDFERTILIZER" fillLevel="0" />
            </storage>
        </storages>
    </silo>

    <hotspots>
        <hotspot type="LOADING" linkNode="mapPosition" teleportNode="mapPosition"/>
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="markerLoading"       filename="$data/shared/assets/marker/markerIconLoad.i3d" adjustToGround="true" />
        <triggerMarker node="refillTriggerMarker" filename="placeables/sharedAssets/marker/markerIconBuyConsumable.i3d" adjustToGround="false" />
    </triggerMarkers>

    <i3dMappings>
