        <dailyUpkeep>50</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>LIZARDSTORAGE</brand>
        <species>placeable</species>
        <category>fillableTanks</category>
        <brush>
