<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="manureHeap" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_manureStorageSpotUpper</name>
        <functions>
            <function>$l10n_function_manureHeap</function>
        </functions>
        <image>placeables/modularWalls/store_manureHeapMainFarm.png</image>
        <price>35000</price>
        <dailyUpkeep>0</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>silos</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>silos</tab>
        </brush>
        <vertexBufferMemoryUsage>13824</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>5632</indexBufferMemoryUsage>
        <textureMemoryUsage>1835008</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/modularWalls/manureStorageSpotUpper.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>

        <sounds>
            <place template="smallImp" />
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="false" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
        </levelAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart1" widthNode="indoorAreaWidth1" heightNode="indoorAreaHeight1" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart1" endNode="tipOcclusionUpdateAreaEnd1" />
        </updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="loadingTriggerMarker" filename="$data/shared/assets/marker/markerIconLoad.i3d" adjustToGround="true" />
    </triggerMarkers>

    <hotspots>
        <hotspot type="LOADING" linkNode="mapPosition" teleportNode="teleportNode" />
    </hotspots>

    <infoTrigger triggerNode="infoTrigger" />

    <manureHeap node="manureHeap" capacity="4600000" isExtension="false" needsBarn="false" >
        <area startNode="tipAreaStart" widthNode="tipAreaWidth" heightNode="tipAreaHeight" activationTriggerNode="activationTrigger" />
        <clearArea startNode="clearAreaStart" widthNode="clearAreaWidth" heightNode="clearAreaHeight" />

        <loadingStation storageRadius="10" supportsExtension="false">
            <loadTrigger triggerNode="loadingTrigger" aiNode="loadingTriggerAINode" fillTypes="MANURE" fillLitersPerSecond="2000" />
        </loadingStation>
    </manureHeap>

    <i3dMappings>
        <i3dMapping id="manureHeap" node="0>1" />
        <i3dMapping id="loadingTrigger" node="0>1|0" />
        <i3dMapping id="loadingTriggerAINode" node="0>1|1" />
        <i3dMapping id="loadingTriggerMarker" node="0>1|2" />
        <i3dMapping id="tipAreaStart" node="0>1|3|0" />
        <i3dMapping id="tipAreaWidth" node="0>1|3|0|0" />
        <i3dMapping id="tipAreaHeight" node="0>1|3|0|1" />
        <i3dMapping id="activationTrigger" node="0>1|4" />
        <i3dMapping id="clearAreaStart" node="0>1|5" />
        <i3dMapping id="clearAreaWidth" node="0>1|5|0" />
        <i3dMapping id="clearAreaHeight" node="0>1|5|1" />
        <i3dMapping id="infoTrigger" node="0>1|6" />
        <i3dMapping id="mapPosition" node="0>1|7" />
        <i3dMapping id="teleportNode" node="0>1|8" />
        <i3dMapping id="clearLevelAreaStart1" node="0>2|0" />
        <i3dMapping id="clearLevelAreaWidth1" node="0>2|0|0" />
        <i3dMapping id="clearLevelAreaHeight1" node="0>2|0|1" />
        <i3dMapping id="indoorAreaStart1" node="0>3|0" />
        <i3dMapping id="indoorAreaWidth1" node="0>3|0|0" />
        <i3dMapping id="indoorAreaHeight1" node="0>3|0|1" />
        <i3dMapping id="tipOcclusionUpdateAreaStart1" node="0>4|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd1" node="0>4|0|0" />
        <i3dMapping id="testAreaStart1" node="0>5|0" />
        <i3dMapping id="testAreaEnd1" node="0>5|0|0" />
    </i3dMappings>
</placeable>
