<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="doghouse" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_doghouse</name>
        <image>$data/placeables/brandless/animalHusbandries/doghouse/store_doghouse.png</image>
        <price>2500</price>
        <functions>
            <function>$l10n_function_dogHouse</function>
        </functions>
        <lifetime>1000</lifetime>
        <dailyUpkeep>5</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>false</showInStore>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>animalpens</category>
        <brush>
            <type>husbandry</type>
            <category>animals</category>
            <tab>others</tab>
        </brush>
        <vertexBufferMemoryUsage>54528</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>13824</indexBufferMemoryUsage>
        <textureMemoryUsage>1835008</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>$data/placeables/brandless/animalHusbandries/doghouse/doghouse.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
        <boughtWithFarmland>true</boughtWithFarmland>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>

        <sounds>
            <place template="smallImp" pitchScale="1.6"/>
            <placeLayered template="dogLayer"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="1" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="dirt"/>
        </levelAreas>
    </leveling>

    <indoorAreas />

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>

    <dogHouse>
        <dogHouseConfigurations>
            <dogHouseConfiguration name="%s (%s)" params="$l10n_configuration_dogLabradorRetriever|$l10n_configuration_dogLabradorRetrieverBlack" >
                <dog node="dogSpawnNode" previewNode="dogPreviewNode" xmlFilename="$dataS/character/animals/domesticated/dog/labradorRetriever/labradorRetriever.xml" tileUIndex="0" tileVIndex="0"/>
                <ball node="ballSpawnNode" filename="$data/placeables/brandless/animalHusbandries/doghouse/dogball.i3d" />
                <playerInteractionTrigger node="playerTrigger"/>
                <bowl foodNode="dogfood">
                    <fillSound template="dogBowlFill" linkNode="dogfood" />
                </bowl>
                <nameplate node="nameplate" />
            </dogHouseConfiguration>
            <dogHouseConfiguration name="%s (%s)" params="$l10n_configuration_dogLabradorRetriever|$l10n_configuration_dogLabradorRetrieverCharcoal">
                <dog node="dogSpawnNode" previewNode="dogPreviewNode" xmlFilename="$dataS/character/animals/domesticated/dog/labradorRetriever/labradorRetriever.xml" tileUIndex="1" tileVIndex="0"/>
                <ball node="ballSpawnNode" filename="$data/placeables/brandless/animalHusbandries/doghouse/dogball.i3d" />
                <playerInteractionTrigger node="playerTrigger"/>
                <bowl foodNode="dogfood">
                    <fillSound template="dogBowlFill" linkNode="dogfood" />
                </bowl>
                <nameplate node="nameplate" />
