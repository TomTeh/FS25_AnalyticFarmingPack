            <dogHouseConfiguration name="%s (%s)" params="$l10n_configuration_dogLabradorRetriever|$l10n_configuration_dogLabradorRetrieverChampagne">
                <dog node="dogSpawnNode" previewNode="dogPreviewNode" xmlFilename="$dataS/character/animals/domesticated/dog/labradorRetriever/labradorRetriever.xml" tileUIndex="0" tileVIndex="1"/>
