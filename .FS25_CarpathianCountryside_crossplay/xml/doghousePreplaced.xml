                <dog node="dogSpawnNode" previewNode="dogPreviewNode" xmlFilename="$dataS/character/animals/domesticated/dog/borderCollie/borderCollie.xml" tileUIndex="0" tileVIndex="0" />
                <ball node="ballSpawnNode" filename="$data/placeables/brandless/animalHusbandries/doghouse/dogball.i3d" />
                <playerInteractionTrigger node="playerTrigger"/>
                <bowl foodNode="dogfood">
                    <fillSound template="dogBowlFill" linkNode="dogfood" />
                </bowl>
                <nameplate node="nameplate" />
            </dogHouseConfiguration>
            <dogHouseConfiguration name="%s (%s)" params="$l10n_configuration_dogBorderCollie|$l10n_configuration_dogBorderCollieBlackWhiteMerle" >
                <dog node="dogSpawnNode" previewNode="dogPreviewNode" xmlFilename="$dataS/character/animals/domesticated/dog/borderCollie/borderCollie.xml" tileUIndex="1" tileVIndex="0" />
                <ball node="ballSpawnNode" filename="$data/placeables/brandless/animalHusbandries/doghouse/dogball.i3d" />
                <playerInteractionTrigger node="playerTrigger"/>
