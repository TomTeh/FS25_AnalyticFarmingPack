                <dog node="dogSpawnNode" previewNode="dogPreviewNode" xmlFilename="$dataS/character/animals/domesticated/dog/labradorRetriever/labradorRetriever.xml" tileUIndex="1" tileVIndex="1"/>
                <ball node="ballSpawnNode" filename="$data/placeables/brandless/animalHusbandries/doghouse/dogball.i3d" />
