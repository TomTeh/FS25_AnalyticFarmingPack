<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="mapCC_sleepTrigger" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_placeableObject_sleepTrigger</name>
        <image>placeables/farmOfficeBuilding/store_sleepTrigger.png</image>
        <functions>
            <function>$l10n_function_farmHouse</function>
        </functions>
        <price>1</price>
        <dailyUpkeep>0</dailyUpkeep>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>farmhouses</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>farmhouses</tab>
        </brush>
        <vertexBufferMemoryUsage>1024</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>512</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>placeables/farmOfficeBuilding/sleepTrigger.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart1" endNode="testAreaEnd1" />
        </testAreas>

        <sounds>
            <place template="smallImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1"/>
    </clearAreas>

    <leveling requireLeveling="false" maxSmoothDistance="5" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="clearLevelAreaStart1" widthNode="clearLevelAreaWidth1" heightNode="clearLevelAreaHeight1" groundType="grass"/>
        </levelAreas>
    </leveling>

    <tipOcclusionUpdateAreas/>

    <indoorAreas/>

    <ai>
        <updateAreas></updateAreas>
    </ai>

    <triggerMarkers>
        <triggerMarker node="sleepTriggerMarker" filename="$data/shared/assets/marker/markerIconSleep.i3d" adjustToGround="false"/>
    </triggerMarkers>

    <farmhouse spawnNode="spawnPoint">
        <sleeping triggerNode="sleepTrigger"/>
    </farmhouse>

    <i3dMappings>
        <i3dMapping id="sleepTrigger" node="0>0" />
        <i3dMapping id="sleepTriggerMarker" node="0>1" />
        <i3dMapping id="spawnPoint" node="0>2" />
        <i3dMapping id="doormatNode" node="0>3" />
        <i3dMapping id="clearLevelAreaStart1" node="0>5|0" />
        <i3dMapping id="clearLevelAreaWidth1" node="0>5|0|0" />
        <i3dMapping id="clearLevelAreaHeight1" node="0>5|0|1" />
        <i3dMapping id="testAreaStart1" node="0>6|0" />
        <i3dMapping id="testAreaEnd1" node="0>6|0|0" />
    </i3dMappings>
</placeable>
