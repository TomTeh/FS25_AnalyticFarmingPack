                    <differential torqueRatio="0.5" maxSpeedRatio="1.3" differentialIndex1="1" differentialIndex2="2" /> <!-- front-back -->
                </differentials>
            </differentialConfiguration>
        </differentialConfigurations>

        <motorConfigurations>
            <motorConfiguration hp="75" price="0">
                <motor torqueScale="0.304" minRpm="850" maxRpm="2300" maxForwardSpeed="22" maxBackwardSpeed="22" brakeForce="3.2" lowBrakeForceScale="0.1" lowBrakeForceSpeedLimit="1" dampingRateScale="0.2">
                    <torque normRpm="0.45" torque="0.9"/>
                    <torque normRpm="0.50" torque="0.97"/>
                    <torque normRpm="0.59" torque="1"/>
