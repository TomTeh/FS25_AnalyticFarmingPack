            <dashboard displayType="EMITTER" valueType="lightState"      node="switchWorklightFront_decals"   intensity="1"                            lightTypes="2" groups="MOTOR_ACTIVE"/>
            <dashboard displayType="EMITTER" valueType="lightState"      node="switchWorklightBack_decals"    intensity="1"                            lightTypes="1" groups="MOTOR_ACTIVE"/>
