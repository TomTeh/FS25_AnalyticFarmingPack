            <camera node="indoorCamera1" rotatable="true" limit="true" rotMinX="-1.1" rotMaxX="0.8" transMin="0" transMax="0" useMirror="true" isInside="true" useOutdoorSounds="true" shadowFocusBox="shadowFocusBox" suspensionNodeIndex="2"/>
        </cameras>

        <characterNode node="playerSkin" cameraMinDistance="0.5" >
