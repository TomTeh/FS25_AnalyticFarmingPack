            <dashboard displayType="ROT" valueType="decelerationAxis" node="pedalBrake"           minRot="0 0 0"               maxRot="25 0 0"            doInterpolation="true" groups="MOTOR_ACTIVE"/>
            <dashboard displayType="ROT" valueType="steeringAngle"    node="playerLeftHandTarget" minRot="0 45 0"            maxRot="0 0 0"                                 groups="MOTOR_ACTIVE"/>
        </dashboards>
    </drivable>

