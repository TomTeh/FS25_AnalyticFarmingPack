        </exhaustEffects>

        <dashboards>
            <dashboard displayType="EMITTER"     valueType="directionForward"  node="iconForward_decals"  intensity="1" emitColor="GREEN"         groups="MOTOR_ACTIVE" baseColor="SHARED_GREY5"/>
            <dashboard displayType="EMITTER"     valueType="directionBackward" node="iconBackward_decals" intensity="1" emitColor="GREEN"         groups="MOTOR_ACTIVE" baseColor="SHARED_GREY5"/>

