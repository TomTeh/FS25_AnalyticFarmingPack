            <dashboard displayType="ROT"     valueType="beaconLight"     node="switchBeaconlight"    minRot="0 0 0"   maxRot="20 0 0"                                        groups="MOTOR_ACTIVE"/>
            <dashboard displayType="ROT"     valueType="lightState"      node="switchWorklightBack"  minRot="0 0 0"   maxRot="-20 0 0"                        lightTypes="1" groups="MOTOR_ACTIVE"/>

